  "objects": [
    {
      "type": "tool",
      "id": "tool--c7295699-6bb7-4e84-8571-840d08234892",
      "name": "MSIXBuilder",
      "description": "MSIXBuilder is an automated solution for security teams to create, test, and validate detection coverage against MSIX-based attacks without the risk of deploying live malware. It supports both command-line and GUI interfaces, and can generate signed and unsigned MSIX packages.",
      "labels": [
        "defensive",
        "testing",
        "simulation"
      ],
      "external_references": [
        {
          "source_name": "GitHub",
          "url": "https://github.com/MHaggis/MSIXBuilder"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9f0a584b-6e75-472d-9ea1-5ffb02c8a1d7",
      "name": "Malvertising for MSIX Malware Delivery",
      "description": "Threat actors purchase legitimate ad placements for popular software searches, leading users to fake landing pages that distribute malicious MSIX packages.",
      "external_references": [
        {
          "source_name": "Microsoft Security Blog",
          "url": "https://www.microsoft.com/en-us/security/blog/2023/12/28/financially-motivated-threat-actors-misusing-app-installer/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9dbdfed0-7c7e-4d33-ac1b-c88cdfc70cf7",
      "name": "Social Engineering via Collaboration Platforms",
      "description": "Attackers exploit workplace collaboration platforms like Microsoft Teams, sending fabricated SharePoint and OneDrive sharing notifications to deliver malicious MSIX packages.",
      "external_references": [
        {
          "source_name": "Red Canary",
          "url": "https://redcanary.com/blog/threat-intelligence/msix-installers/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1f50d57c-6473-469c-8617-61de24e69f9b",
      "name": "SEO Poisoning for MSIX Malware Delivery",
      "description": "Threat actors compromise websites and inject malicious code to redirect visitors searching for specific software to fake download pages distributing MSIX malware.",
      "external_references": [
        {
          "source_name": "Sekoia Blog",
          "url": "https://blog.sekoia.io/exposing-fakebat-loader-distribution-methods-and-adversary-infrastructure/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e9d35a5e-0ed2-4693-96f2-cf991b74a201",
      "name": "Loader-as-a-Service (LaaS) using MSIX",
      "description": "Commercial malware services offer MSIX-packaged malware as a subscription, including code-signed packages and administration panels for tracking infections.",
      "external_references": [
        {
          "source_name": "Sekoia Blog",
          "url": "https://blog.sekoia.io/exposing-fakebat-loader-distribution-methods-and-adversary-infrastructure/"
        }
      ]
    },
