        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--390e45a6-dab7-42f2-b43f-d5bff940c989",
      "name": "Offline Credential Cracker",
      "description": "Malware or tool used to crack hashed credentials exported from compromised Fortinet device configurations.",
      "labels": [
        "credential access",
        "offline cracking",
        "Fortinet"
      ],
      "external_references": [
        {
