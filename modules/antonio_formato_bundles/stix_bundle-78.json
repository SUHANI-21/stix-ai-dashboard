        "SAML"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8a8e5a19-efd4-4c42-bce9-fe2a18a731e9",
      "name": "Bypass Authentication via Manipulated SAML Messages",
      "description": "Attackers exploit FortiCloud SSO vulnerabilities by sending manipulated SAML messages to bypass authentication and gain administrative access to affected Fortinet devices.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        }
      ],
