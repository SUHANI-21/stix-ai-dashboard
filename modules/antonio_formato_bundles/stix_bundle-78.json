  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--ddb00e81-0344-468d-8242-1ed17149f7a6",
      "name": "FortiCloud SSO Login Bypass in multiple Fortinet products",
      "description": "Critical vulnerabilities in the FortiCloud SSO login mechanism of several Fortinet products allow unauthenticated attackers to bypass authentication via manipulated SAML messages and gain administrative access. The vulnerabilities are actively exploited. Attackers can export device configurations, which may contain hashed credentials that could be cracked offline.",
      "created": "2025-12-19T00:00:00Z",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-59718"
        },
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-59719"
        },
        {
          "source_name": "Fortinet PSIRT Advisory FG-IR-25-647",
          "url": "https://www.fortiguard.com/psirt/FG-IR-25-647"
        },
        {
          "source_name": "Arctic Wolf Security Bulletin",
          "url": "https://arcticwolf.com/resources/blog/arctic-wolf-observes-malicious-sso-logins-%20following-disclosure-cve-2025-59718-cve-2025-59719/"
        },
        {
          "source_name": "VulnCheck Blog",
          "url": "https://www.vulncheck.com/blog/forticloud-sso-login-bypass"
        }
      ],
