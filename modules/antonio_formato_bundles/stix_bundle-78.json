    {
      "type": "indicator",
      "id": "indicator--c9bc649c-2c5e-43d8-85b9-92f0c872141a",
      "name": "Export of Device Configuration Files",
      "description": "Observation of device configuration exports following exploitation of FortiCloud SSO vulnerabilities. Exported configurations may contain hashed credentials.",
      "pattern": "[file:name = 'config*' AND file:contains_hashes = true]",
      "valid_from": "2025-12-19T00:00:00Z",
      "labels": [
        "configuration export",
        "Fortinet",
        "credential theft"
      ]
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--46c3c975-d2df-48c0-b5f0-4307525e082f",
      "name": "FortiCloud SSO Exploitation Actors",
      "description": "Unattributed threat actors actively exploiting FortiCloud SSO authentication bypass vulnerabilities (CVE-2025-59718, CVE-2025-59719) in Fortinet products to gain administrative access and export device configurations.",
      "aliases": [
        "FortiCloud SSO Exploiters"
      ],
      "external_references": [
        {
          "source_name": "Arctic Wolf Security Bulletin",
          "url": "https://arcticwolf.com/resources/blog/arctic-wolf-observes-malicious-sso-logins-%20following-disclosure-cve-2025-59718-cve-2025-59719/"
        }
      ],
      "labels": [
        "active exploitation",
        "Fortinet"
      ]
    },
    {
      "type": "course-of-action",
      "id": "course-of-action--b43be8d7-304d-43b0-81e6-b709f4e92481",
      "name": "Disable FortiCloud SSO Login",
      "description": "As a workaround, disable the FortiCloud SSO login feature via GUI (System -> Settings -> 'Allow administrative login using FortiCloud SSO' set to 'Off') or CLI (config system global; set admin-forticloud-sso-login disable; end). Reset all firewall credentials if compromise is suspected.",
      "external_references": [
        {
          "source_name": "Fortinet PSIRT Advisory FG-IR-25-647",
          "url": "https://www.fortiguard.com/psirt/FG-IR-25-647"
        }
      ],
      "labels": [
        "mitigation",
        "Fortinet",
        "authentication bypass"
      ]
    },
