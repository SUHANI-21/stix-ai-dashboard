      ]
    },
    {
      "type": "tool",
      "id": "tool--dfb7f65e-c06a-4ae5-88e0-1c88e9fc5a00",
      "name": "FortiCloud SSO Exploit Tool",
      "description": "A tool or script used to craft and send manipulated SAML messages to exploit the FortiCloud SSO vulnerabilities in Fortinet products, bypassing authentication.",
      "labels": [
        "exploit",
        "SAML",
        "authentication bypass",
        "Fortinet"
      ],
