    {
      "type": "attack-pattern",
      "id": "attack-pattern--76d3a6ae-dcc1-4b67-a017-fc919626bf0f",
      "name": "Supply Chain Compromise via Malicious NPM Packages",
      "description": "The attacker compromises popular npm packages by injecting malicious files (`setup_bun.js` and `bun_environment.js`) that appear to be introducing the Bun runtime. The code collects system and cloud secrets, exfiltrates them to public GitHub repositories, and attempts to propagate by updating other npm packages using discovered tokens. If propagation fails, destructive commands are executed to delete files and wipe disks.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        },
        {
          "kill_chain_name": "mitre-attack",
