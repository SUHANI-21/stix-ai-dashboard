      "name": "powershell.exe",
      "command_line": "powershell -ExecutionPolicy Bypass -w hidden -command \"$app[0-9]{5}=[Environment]::GetFolderPath([Environment+SpecialFolder]::ApplicationData);Start-Sleep -Seconds 60;$ws = New-Object -ComObject WScript.Shell;$lnk = $ws.CreateShortcut($app[0-9]{5}+ '\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\[0-9]{4}.lnk');$lnk.TargetPath = '\"C:\\Users\\<USER>\\AppData\\Roaming\\[0-9]{4}.exe\"';$lnk.Save()\""
    },
