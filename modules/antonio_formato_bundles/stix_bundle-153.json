  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8dde2f7b-e2d3-4edc-943f-8a514cb25b38",
      "name": "Malware Loader",
      "description": "Olymp Loader acts as a loader to execute other malware payloads on victim systems, including credential infostealers and remote-access tools.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--85d9acb1-52b1-4415-9d8c-a87efc1e7cb4",
      "name": "Crypter for Anti-Analysis and Anti-Detection",
      "description": "Olymp Loader includes crypter functionality focusing on anti-analysis and anti-detection features to evade security products.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4fdbaee2-927e-4283-ba76-5bd9816907b5",
      "name": "Browser Credential Stealer",
      "description": "Olymp Loader includes browser stealer modules written in Python and C++, targeting browser credentials and exfiltrating them via proxy URLs.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a55bb807-7828-4993-b6e7-318638587e2f",
      "name": "Telegram Data Stealer",
      "description": "Olymp Loader's Telegram stealer module queries the registry for Telegram folders, kills processes, grabs data, takes screenshots, and exfiltrates the zipped results.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--29a34904-607a-4488-a3f3-ab376afbdb0f",
      "name": "Cryptowallet Stealer",
      "description": "Olymp Loader's cryptowallet stealer module targets desktop wallets including Exodus, Electrum, Atomic, Guarda, Wasabi, Monero, BitcoinCore, and ZelCore, and exfiltrates data with screenshots.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--53199f85-8860-4420-828b-1ae2fe02fe29",
      "name": "Disabling Windows Defender",
      "description": "Olymp Loader disables Windows Defender's real-time monitoring and other protections, including removing Defender components via PowerShell and registry edits.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--47107654-3e1a-43c3-b0bc-6585e9a07312",
      "name": "Persistence via Startup Folder",
      "description": "Olymp Loader establishes persistence by creating shortcuts in the Windows Startup folder using PowerShell scripts.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--37f97983-437e-4a95-885d-c6c80a4320e6",
      "name": "Social Engineering via Mimicked Software Downloads",
      "description": "Olymp Loader is distributed using URLs and file names designed to mimic legitimate software such as Node.js, PuTTY, OpenSSL, Zoom, and Classic Offensive to trick users into downloading the malware.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ee354430-3932-433c-a55f-f25530dc90ba",
      "name": "Data Exfiltration via Embedded Proxy URL",
      "description": "Olymp Loader stealer modules exfiltrate stolen data using an embedded proxy URL marked by a __PROXY__ marker in the binary.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2320611a-9a8e-49ab-9021-925cdf6cfd4d",
      "name": "Malware Distribution via GitHub Releases",
      "description": "Olymp Loader binaries have been observed distributed via GitHub Releases, using filenames and paths mimicking legitimate developer tools.",
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/olymp-loader-emerging-malware-as-a-service-threat-in-2025"
        }
      ]
    },
