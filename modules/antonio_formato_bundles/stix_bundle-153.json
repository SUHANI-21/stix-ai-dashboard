      "name": "cmd.exe",
      "command_line": "cmd.exe /C \"timeout /T 30 >nul && copy /Y \"C:\\Users\\<USER>\\Desktop\\test.exe\" \"C:\\Users\\<USER>\\AppData\\Roaming\\[0-9]{4}.exe\" && start \"\" \"C:\\Users\\<USER>\\AppData\\Roaming\\[0-9]{4}.exe\""
    },
