    {
      "type": "intrusion-set",
      "id": "intrusion-set--f682adc7-959b-4703-9e40-94983152d817",
      "name": "Storm-2603",
      "description": "Storm-2603 is a financially motivated threat cluster observed exploiting SharePoint vulnerabilities (ToolShell) to deliver web shells, loaders, and Warlock ransomware. Activity has been tracked by Singapore government advisories.",
      "aliases": [],
      "external_references": [
        {
          "source_name": "Singapore IMDA Advisory",
          "url": "https://www.imda.gov.sg/-/media/imda/files/regulations-and-licensing/regulations/advisories/infocomm-media-cyber-security/storm-2603-exploits-sharepoint-vulnerabilities-to-deliver-backdoor-and-warlock-ransomware.pdf"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4bc13e4d-27dd-43b6-b985-9e7cca45f660",
      "name": "Exploitation of SharePoint ToolShell Vulnerability Chain",
      "description": "Threat actors exploit a chain of SharePoint vulnerabilities (ToolShell) to bypass authentication and achieve remote code execution, typically by uploading web shells to the /_layouts/15/ directory.",
      "external_references": [
        {
          "source_name": "Viettel Cyber Security",
          "url": "https://blog.viettelcybersecurity.com/sharepoint-toolshell/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--906f7f35-0e51-4480-8af8-b499e7844356",
      "name": "Exploitation of WSUS Vulnerability",
      "description": "Threat actors exploit vulnerabilities in Windows Server Update Services (WSUS) to gain initial access to target environments.",
      "external_references": [
        {
          "source_name": "Huntress Blog",
          "url": "https://www.huntress.com/blog/velociraptor-misuse-part-one-wsus-up"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3ada7196-05f9-4871-acf4-7e618144ebb5",
      "name": "Abuse of Legitimate Tools for Command and Control",
      "description": "Threat actors leverage legitimate tools such as Velociraptor, Visual Studio Code, Cloudflared, and OpenSSH to establish command-and-control channels and evade detection.",
      "external_references": []
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7e86c858-da9f-4a96-baac-ff49b25f5a76",
      "name": "Use of Encoded PowerShell Commands",
      "description": "Threat actors use Base64 encoded PowerShell commands to download files, create tunnels, and execute commands on compromised endpoints.",
      "external_references": []
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a20c2ca1-206a-4aee-b018-a7e9f64b4e57",
      "name": "Lateral Movement via New User Account Creation",
      "description": "Threat actors create new user accounts (e.g., adminbak, adminbak2) on compromised endpoints to facilitate lateral movement and persistence.",
      "external_references": []
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f8f4f5d7-7c58-4967-bbb4-d4b0873244d5",
      "name": "Disabling Security Controls",
      "description": "Threat actors disable endpoint protection solutions (e.g., Windows Defender) to facilitate installation of malicious tools and persistence.",
      "external_references": []
    },
