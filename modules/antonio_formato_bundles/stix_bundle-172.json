      "type": "intrusion-set",
      "id": "intrusion-set--b4e0033f-ebde-4785-b7a1-2e4cf9d0206a",
      "name": "Gamaredon",
      "aliases": [
        "Primitive Bear"
      ],
      "description": "Gamaredon is a Russian-aligned advanced persistent threat (APT) group active since at least 2013, primarily focused on cyber espionage. The group is believed to be part of Russia's Federal Security Service (FSB) 18th Information Security Center. Gamaredon has conducted more than 5000 cyber-attacks, mostly targeting Ukrainian government agencies, and has expanded operations to include NATO member states, likely aiming to disrupt military aid to Ukraine.",
      "first_seen": "2013-01-01T00:00:00Z",
      "goals": [
        "Cyber espionage",
        "Hybrid warfare"
      ],
      "resource_level": "nation-state",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "disruption"
      ],
      "external_references": [
        {
          "source_name": "Security Service of Ukraine",
          "url": "https://ssu.gov.ua/en/novyny/sbu-vstanovyla-khakeriv-fsb-yaki-zdiisnyly-ponad-5-tys-kiberatak-na-derzhavni-orhany-ukrainy"
        },
        {
          "source_name": "ESET",
          "url": "https://www.welivesecurity.com/en/eset-research/cyberespionage-gamaredon-way-analysis-toolset-used-spy-ukraine-2022-2023/"
        }
      ],
      "country": "Russia"
    },
