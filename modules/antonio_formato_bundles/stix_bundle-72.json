  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--322b3a4f-1ff8-4d6e-b37a-7cf1802211fe",
      "name": "Evasive Panda",
      "aliases": [
        "Bronze Highland",
        "Daggerfly",
        "StormBamboo"
      ],
      "description": "Evasive Panda is an advanced persistent threat (APT) group active since at least 2012, known for sophisticated and evolving tactics. The group has conducted highly-targeted campaigns, including adversary-in-the-middle (AitM) attacks, supply-chain compromise, and watering-hole attacks. They are known to use DNS poisoning, custom loaders, and the MgBot implant for long-term persistence and defense evasion. Victims have been observed in T\u00fcrkiye, China, and India.",
      "first_seen": "2012-01-01T00:00:00Z",
      "goals": [
        "Long-term persistence",
        "Espionage",
        "Targeting multiple industries"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage"
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--40f88b85-75bc-4878-b036-8a592160e51a",
      "name": "Adversary-in-the-Middle (AitM) Attack",
      "description": "Evasive Panda performs AitM attacks by intercepting and manipulating DNS responses, enabling delivery of malicious payloads from attacker-controlled servers. This includes DNS poisoning to redirect legitimate update requests to malicious infrastructure.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2fd2031a-ed7f-4624-8e28-934e73b6d950",
      "name": "DLL Sideloading",
      "description": "The threat actor uses DLL sideloading by placing a malicious DLL (libpython2.4.dll) alongside a legitimate signed executable (evteng.exe) to achieve code execution and evade detection.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--794e448c-dac5-4165-9a5c-2e511ff510f6",
      "name": "Multi-stage Shellcode Execution",
      "description": "The malware employs a multi-stage shellcode execution process, using XOR and LZMA for decryption and decompression, and PJW hashing for API resolution. Shellcode is injected in memory and executed after modifying memory permissions.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "execution"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--af7d4494-f56d-4e4f-a86b-004b8d2bab1f",
      "name": "Hybrid Encryption for Payload Protection",
      "description": "Payloads are encrypted using a hybrid approach combining Microsoft DPAPI and the RC5 algorithm, with the RC5 key itself encrypted by DPAPI and stored alongside the payload, ensuring payloads can only be decrypted on the infected system.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--98ce8d79-dd74-4f17-b31a-a34079234ea5",
      "name": "MgBot C2 Infrastructure",
      "description": "A set of C2 servers used by the MgBot implant to maintain communication and control over compromised systems. The infrastructure includes multiple long-lived IP addresses.",
      "infrastructure_types": [
        "command-and-control"
      ],
      "aliases": [],
      "first_seen": "2022-11-01T00:00:00Z",
      "last_seen": "2024-11-30T23:59:59Z"
    },
