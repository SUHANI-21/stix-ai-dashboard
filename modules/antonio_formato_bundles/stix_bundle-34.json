{
  "type": "bundle",
  "id": "bundle--89688884-46b6-409e-8b30-609820750720",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "campaign",
      "id": "campaign--b7435577-2b55-49be-9de9-387e1886ee86",
      "name": "SSRF campaign targeting LLM infrastructure",
      "description": "A campaign exploiting server-side request forgery (SSRF) vulnerabilities in LLM deployments, including Ollama's model pull functionality and Twilio SMS webhook integrations. Attackers injected malicious registry URLs and manipulated MediaUrl parameters to force servers to make outbound connections to attacker-controlled infrastructure. ProjectDiscovery's OAST infrastructure was used to confirm successful exploitation via callback validation. The campaign ran from October 2025 through January 2026, with a dramatic spike over Christmas.",
      "first_seen": "2025-10-01T00:00:00Z",
      "last_seen": "2026-01-31T23:59:59Z",
      "objective": "Exploit SSRF vulnerabilities to gain outbound connections from victim servers to attacker infrastructure.",
      "aliases": [
        "OAST SSRF campaign"
      ]
    },
    {
      "type": "campaign",
      "id": "campaign--90eff7f6-26a0-4afa-8c5b-609b8b4189c5",
      "name": "LLM Enumeration campaign",
      "description": "A campaign beginning December 28, 2025, involving systematic probing of over 73 LLM model endpoints to build target lists for future exploitation. Attackers tested OpenAI-compatible and Google Gemini API formats, targeting major model families. The campaign generated over 80,000 sessions in eleven days, using innocuous queries to fingerprint exposed endpoints. Infrastructure overlaps with previous CVE scanning operations.",
      "first_seen": "2025-12-28T00:00:00Z",
      "last_seen": "2026-01-07T23:59:59Z",
      "objective": "Enumerate and fingerprint exposed LLM endpoints for future exploitation.",
      "aliases": [
        "LLM Reconnaissance campaign"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c70123e9-02bd-4f6b-9817-433b1e67ef0f",
      "name": "Server-Side Request Forgery (SSRF) via malicious model registry URLs",
      "description": "Attackers inject malicious registry URLs into Ollama's model pull functionality to force servers to make HTTP requests to attacker-controlled infrastructure.",
      "aliases": [
        "SSRF via model pull"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8b8a53e0-3676-4d85-aa21-d13158e2df30",
      "name": "SSRF via Twilio SMS webhook MediaUrl manipulation",
      "description": "Attackers manipulate MediaUrl parameters in Twilio SMS webhook integrations to trigger outbound connections from victim servers.",
      "aliases": [
        "SSRF via webhook manipulation"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--01680083-a071-466d-918e-88293f7b40e5",
      "name": "LLM endpoint enumeration and fingerprinting",
      "description": "Attackers systematically probe LLM endpoints using innocuous queries to fingerprint which model responds, identifying exposed or misconfigured proxy servers.",
      "aliases": [
        "LLM reconnaissance"
      ]
    },
    {
