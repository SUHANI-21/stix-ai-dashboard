  "objects": [
    {
      "type": "malware",
      "id": "malware--3d4a6bd3-e40f-4107-b19c-48c7d5fb9e35",
      "name": "Webrat",
      "description": "Webrat is a backdoor malware family that enables attackers to control infected systems, steal data from cryptocurrency wallets, Telegram, Discord, and Steam accounts, and perform spyware functions such as screen recording, webcam and microphone surveillance, and keylogging. It is distributed via GitHub repositories disguised as exploits, game cheats, and cracked software.",
      "malware_types": [
        "backdoor",
        "spyware",
        "trojan"
      ],
      "is_family": true,
      "aliases": [],
      "first_seen": "2025-09",
      "last_seen": "2025-10",
      "operating_system_refs": [
        "windows"
      ],
      "external_references": [
        {
          "source_name": "securelist",
          "url": "https://securelist.com/webrat-distributed-via-github/118555/"
        },
        {
          "source_name": "cybersecurefox",
          "url": "https://cybersecurefox.com/en/webrat-malware-gaming-platforms-threat-analysis/"
        }
      ],
      "labels": [
        "malware",
        "backdoor",
        "spyware",
        "trojan"
      ]
    },
    {
