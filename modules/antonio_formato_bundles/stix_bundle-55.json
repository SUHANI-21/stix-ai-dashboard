  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--e4b31173-0eff-4e91-90a3-b607a923229f",
      "name": "SideWinder",
      "aliases": [
        "Rattlesnake",
        "T-APT-04"
      ],
      "description": "SideWinder is an APT group targeting South Asian governments, military, and tax agencies. The group uses phishing emails themed around tax refunds to deliver malware, leveraging techniques like DLL side-loading, Living-off-the-Land binaries, and cloud storage for payload delivery. Recent activity targeted Indian tax officials using fake tax department websites and multi-stage payloads.",
      "goals": [
        "Espionage",
        "Data theft",
        "Targeting government, military, and tax organizations"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage"
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--da3f6bb4-0e29-4a02-a712-9600ff31fd5c",
      "name": "Phishing via Tax Refund Theme",
      "description": "Use of phishing emails themed around tax refunds to lure victims into visiting fake tax department websites and downloading malicious payloads.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1566.002"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a7f6b3d5-2f16-4e52-9e6e-c7c22f65b73a",
      "name": "DLL Side-Loading",
      "description": "Abuse of legitimate signed binaries to load malicious DLLs, evading security detection.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1574.002"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--5c551332-0df5-4756-bb1b-d69b6d82cfe7",
      "name": "Geofencing Execution",
      "description": "Malware checks victim's timezone (UTC+5:30) and only executes in targeted regions, using timeapi[.]io for verification.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1614.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f27796f3-f0ec-43d0-addb-930a0c9fef06",
      "name": "Sandbox Evasion",
      "description": "Malware detects analysis tools (e.g., Procmon, Wireshark) and self-terminates to evade detection.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1497.003"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2193a11c-8df7-4e67-9ac9-54c840172bf0",
      "name": "Sleep/Delay Technique",
      "description": "Malware uses long sleep intervals (e.g., Sleep(210000) for 3.5 minutes) to evade sandboxes with short timeouts.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1622"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--5eb4e96b-e271-44b6-b865-934d40b8b9d5",
      "name": "Cloud Storage Payload Delivery",
      "description": "Malware payloads are hosted on public cloud storage (e.g., GoFile) and downloaded via legitimate-looking URLs.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1102.002"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--089c48e9-bded-4437-ae5d-2e9dea675070",
      "name": "Living-off-the-Land Binaries",
      "description": "Malware leverages trusted system binaries and signed executables to execute malicious code and evade detection.",
