      "name": "Malicious Use of Signed RMM Binaries",
      "description": "Attackers use signed RMM binaries (e.g., GoTo Technologies USA, SimpleHelp Ltd.) to evade detection and increase trust in rogue installers.",
      "x_mitre_platforms": [
        "Windows"
      ],
