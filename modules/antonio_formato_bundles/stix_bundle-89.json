    {
      "type": "attack-pattern",
      "id": "attack-pattern--789e3eda-410d-4ff9-87c3-a85c3a950dfd",
      "name": "Abuse of Remote Monitoring and Management (RMM) Tools",
      "description": "Threat actors compromise legacy RMM tools or install their own instances post-access to maintain persistence, deploy additional malware, and evade detection. Multiple RMM tools may be used in a single attack chain.",
      "x_mitre_platforms": [
        "Windows"
      ],
      "x_mitre_permissions_required": [
        "User"
      ],
      "x_mitre_detection": "Monitor for unusual RMM installations, execution from suspicious directories, and connections to attacker-controlled domains."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--19e71b9d-de42-4f5b-856d-ea485ccd8c88",
      "name": "Phishing with Malicious RMM Installers",
      "description": "Threat actors use phishing emails and social engineering lures (e.g., fake contracts, invitations, holiday themes) to trick victims into downloading and executing rogue RMM installers.",
      "x_mitre_platforms": [
        "Windows"
      ],
      "x_mitre_permissions_required": [
        "User"
      ],
      "x_mitre_detection": "Monitor for suspicious downloads and execution of RMM installers from non-standard sources."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c2c666f9-a4e9-4566-8953-c8b56898ed20",
      "name": "Chained RMM Deployment for Persistence",
      "description": "Attackers deploy multiple RMM tools in sequence (e.g., GoTo Resolve to ScreenConnect to SimpleHelp) to ensure long-term access and persistence, even if one tool is detected or blocked.",
      "x_mitre_platforms": [
        "Windows"
      ],
      "x_mitre_permissions_required": [
        "User"
      ],
      "x_mitre_detection": "Look for installation and execution of multiple RMM tools on the same host, especially from suspicious directories."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8422492c-7a34-4bd7-920b-0725a2d0ca61",
      "name": "Living-off-the-land (LotL) Techniques with RMMs",
      "description": "Threat actors use legitimate RMM installers and system utilities (e.g., msiexec) to execute and deploy rogue RMM instances, blending malicious activity with normal administrative behavior.",
      "x_mitre_platforms": [
        "Windows"
      ],
      "x_mitre_permissions_required": [
        "User"
      ],
      "x_mitre_detection": "Audit execution of RMM installers using system utilities and monitor for connections to suspicious domains."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--870be6bf-3203-498a-aca8-c11184e4af8f",
      "name": "Persistence via Scheduled Tasks for RMMs",
      "description": "Threat actors create scheduled tasks to maintain persistence of rogue RMM services (e.g., GoTo Resolve) on compromised endpoints.",
      "x_mitre_platforms": [
        "Windows"
      ],
      "x_mitre_permissions_required": [
        "User"
      ],
      "x_mitre_detection": "Monitor for creation of scheduled tasks that launch RMM services, especially those not authorized by IT."
    },
    {
