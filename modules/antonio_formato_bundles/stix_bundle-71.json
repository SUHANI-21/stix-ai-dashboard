  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--294af773-0088-49e7-ac51-c44ae56ed200",
      "name": "Supply Chain Compromise via Malicious MSI Installer",
      "description": "Attackers replaced official EmEditor MSI installation packages with malicious versions signed by 'WALSHAM INVESTMENTS LIMITED', delivering infostealer malware to sensitive users in China.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--724c8111-c13e-486d-87a7-738072568c6a",
      "name": "Credential Theft from Multiple Applications",
      "description": "Malware steals credentials from VPNs, Windows login, browsers, and various applications including Zoho Mail, Evernote, Notion, Discord, Slack, Mattermost, Skype, LiveChat, MSTeams, Zoom, WinSCP, Putty, Steam, Telegram.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--0b386e13-e735-4e3c-8f0c-ceb968341cad",
      "name": "Browser Plugin Persistence",
      "description": "Installs a browser plugin named 'Google Drive Caching' for long-term persistence and additional data theft, including system information, cookies, browsing history, extension lists, bookmarks, and more.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f01d4fa8-c3f6-4771-9cf8-71e66a5bb92d",
      "name": "Domain Generation Algorithm (DGA) for C2 Communication",
      "description": "Implements a DGA to generate backup C2 domains, changing seeds weekly to evade detection and blocking.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--11ab1283-e065-4c89-abdc-a84dc01efce4",
      "name": "Clipboard Hijacking",
      "description": "Hijacks clipboard contents, replacing cryptocurrency wallet addresses with attacker-controlled ones for over 30 types of cryptocurrencies.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--fd1023ee-1997-4b83-9d9e-7379f41c4ced",
      "name": "Keylogging and Targeted Credential Capture",
      "description": "Records keystrokes and classifies them based on specific web pages to capture sensitive credentials, including Facebook ad account theft.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--46644181-aa0c-4cd1-a9a7-8011591e527c",
      "name": "Remote Access and Control",
      "description": "Supports remote commands such as cookie/history retrieval, screenshot, cookie clearing, notification sending, file reading, malicious URL opening, proxy starting (MITM), self-uninstallation, and arbitrary JavaScript execution.",
      "external_references": [
        {
          "source_name": "QiAnXin Threat Intelligence Center",
          "url": "https://emeditorgb.com/take/mg8heP0r/"
        }
      ]
