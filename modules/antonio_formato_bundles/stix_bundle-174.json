      "name": "recv_pyobj.py",
      "extensions": {
        "python": {
          "functions": [
            {
              "name": "recv_pyobj",
              "parameters": [
                {
                  "name": "self"
                },
                {
                  "name": "flags",
                  "type": "int",
                  "default": 0
                }
              ],
              "return_type": "Any",
              "body": [
                "msg = self.recv(flags)",
                "return self._deserialize(msg, pickle.loads)"
              ]
            }
          ]
        }
