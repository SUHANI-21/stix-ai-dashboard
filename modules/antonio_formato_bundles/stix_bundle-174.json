  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--1a7114ef-f105-4174-97a1-b1d7f5b8abe7",
      "name": "ShadowMQ",
      "description": "ShadowMQ is a communication-layer flaw propagated through code reuse in AI inference servers, caused by unsafe use of ZeroMQ (ZMQ) and Python's pickle deserialization. Vulnerable code patterns were copied between projects, leading to critical Remote Code Execution (RCE) vulnerabilities in frameworks from Meta, NVIDIA, Microsoft, vLLM, SGLang, and Modular. Exploitation can lead to arbitrary code execution, privilege escalation, data exfiltration, and cryptomining.",
      "created": "2024-06-01T00:00:00.000Z",
      "modified": "2025-06-01T00:00:00.000Z"
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--c8038111-fa0b-41e6-bc02-603422ce27a3",
      "name": "CVE-2024-50050",
      "description": "Critical RCE vulnerability in Meta Llama Stack due to unsafe usage of ZMQ's recv_pyobj() and Python's pickle deserialization. Patched in October 2024 by switching to JSON-based serialization.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2024-50050",
          "url": "https://security.snyk.io/vuln/SNYK-PYTHON-LLAMASTACK-8302915"
        },
        {
          "source_name": "Meta Llama Stack Patch",
          "url": "https://www.oligo.security/blog/cve-2024-50050-critical-vulnerability-in-meta-llama-llama-stack"
        }
      ],
      "created": "2024-10-01T00:00:00.000Z",
      "modified": "2024-10-01T00:00:00.000Z"
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--f0c69a7e-cc46-4d1e-8169-7008486e939b",
      "name": "CVE-2025-30165",
      "description": "Critical RCE vulnerability in vLLM due to unsafe pickle deserialization over unauthenticated ZMQ TCP sockets. Fixed in May 2025 by replacing the vulnerable V0 engine with a safe V1 default.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-30165",
          "url": "https://nvd.nist.gov/vuln/detail/CVE-2025-30165"
        },
        {
          "source_name": "vLLM Advisory",
          "url": "https://github.com/vllm-project/vllm/security/advisories/GHSA-9pcc-gvx5-r5wm"
        }
      ],
      "created": "2025-05-01T00:00:00.000Z",
      "modified": "2025-05-01T00:00:00.000Z"
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--262ea770-9c48-4ae2-a7d2-e41a56456189",
      "name": "CVE-2025-23254",
      "description": "Critical RCE vulnerability in NVIDIA TensorRT-LLM due to unsafe pickle deserialization over unauthenticated ZMQ TCP sockets. Patched in May 2025 by implementing HMAC validation. Rated Critical (9.3) by NVD.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-23254",
          "url": "https://nvd.nist.gov/vuln/detail/CVE-2025-23254"
        },
        {
          "source_name": "NVIDIA Security Bulletin",
          "url": "https://nvidia.custhelp.com/app/answers/detail/a_id/5648/~/security-bulletin%3A-nvidia-tensorrt-llm---april-2025"
        }
      ],
      "created": "2025-05-01T00:00:00.000Z",
      "modified": "2025-05-01T00:00:00.000Z"
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--852e3433-db1b-4750-a04f-7799cfce3cf2",
      "name": "CVE-2025-60455",
      "description": "Critical RCE vulnerability in Modular Max Server due to unsafe pickle deserialization over unauthenticated ZMQ TCP sockets. Patched in June 2025 by switching to msgpack.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-60455",
          "url": "http://cve-2025-60455"
        },
