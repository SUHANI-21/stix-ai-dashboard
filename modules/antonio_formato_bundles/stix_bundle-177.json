        "file--88e0c1652eb91c517a5fec9d356c7f30c0136d544f5d55ac37f20c5612134efb"
      ]
    },
    {
      "type": "malware",
      "id": "malware--44acbe13-7564-48b6-bf99-01abb65b852a",
      "name": "LeakyStealer",
      "description": "LeakyStealer is a polymorphic information-stealing malware injected by LeakyInjector. It targets cryptocurrency wallets and browser extensions, exfiltrates browser history, establishes persistence via the Run registry key, and beacons to its C2 server at regular intervals. It implements backdoor commands for downloading/executing files and running Windows commands. It is signed with a valid EV certificate reused across multiple samples.",
      "malware_types": [
        "stealer",
        "backdoor"
      ],
      "is_family": false,
      "operating_system_refs": [
        "windows"
      ],
      "labels": [
        "LeakyStealer",
        "infostealer",
        "crypto stealer",
        "cryptowallet stealer",
        "polymorphic"
      ],
      "external_references": [
