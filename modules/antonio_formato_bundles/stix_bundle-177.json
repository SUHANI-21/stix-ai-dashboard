  "objects": [
    {
      "type": "malware",
      "id": "malware--55473ff5-985f-40cc-bf01-1ae058a212a9",
      "name": "LeakyInjector",
      "description": "LeakyInjector is a first-stage malware that uses low-level APIs for process injection to avoid detection, decrypts the ChaCha20-encrypted second stage (LeakyStealer), and injects it into explorer.exe. It is signed with a valid Extended Validation certificate and is related to multiple samples using the same certificate infrastructure.",
      "malware_types": [
        "dropper",
        "injector"
      ],
      "is_family": false,
      "operating_system_refs": [
        "windows"
      ],
      "labels": [
        "LeakyInjector",
        "dropper",
        "injector",
        "crypto stealer"
      ],
      "external_references": [
        {
          "source_name": "Hybrid Analysis",
          "url": "https://hybrid-analysis.blogspot.com/search/label/LeakyInjector"
        }
      ],
      "sample_refs": [
