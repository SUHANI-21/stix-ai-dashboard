    {
      "type": "vulnerability",
      "id": "vulnerability--d35e8464-128f-494f-9fb7-c3e467ff35af",
      "name": "React Server Components Flight protocol RCE (React2Shell)",
      "description": "A maximum-severity vulnerability in React Server Components Flight protocol, tracked as CVE-2025-55182 and also referred to as React2Shell, allows unauthenticated remote code execution in vulnerable deployments, with downstream impact across frameworks such as Next.js. The vulnerability is being actively exploited in the wild.",
      "created": "2025-12-05T00:00:00Z",
      "modified": "2025-12-09T00:00:00Z",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-55182",
          "url": "https://viz.greynoise.io/tags/react-server-components-unsafe-deserialization-cve-2025-55182-rce-attempt?days=1"
        },
        {
          "source_name": "GreyNoise",
          "url": "https://www.labs.greynoise.io/grimoire/2025-12-09-react2shell-meshcentral/"
        },
        {
          "source_name": "Censys",
          "url": "https://censys.com/advisory/cve-2025-55182"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9e282214-7317-4209-9423-95482ae6f668",
      "name": "Exploitation of React Server Components Flight Protocol RCE (React2Shell)",
      "description": "Attackers exploit CVE-2025-55182 by sending crafted POST requests to vulnerable React Server Components endpoints. Techniques include arithmetic calculations for command execution validation, system information gathering, reverse shell and downloader scripts, SSH persistence, remote script execution (often PowerShell-encoded), directory reconnaissance, and cross-platform command execution (Unix and Windows). Payloads often use encoded PowerShell commands, AMSI bypass via reflection, and download-and-execute primitives.",
      "external_references": [
        {
          "source_name": "GreyNoise",
          "url": "https://www.labs.greynoise.io/grimoire/2025-12-09-react2shell-meshcentral/"
        }
      ]
    },
