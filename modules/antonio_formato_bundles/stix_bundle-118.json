  "objects": [
    {
      "type": "malware",
      "id": "malware--1ebfa0c1-ec99-4933-87c8-68b65cd03e68",
      "name": "AshTag",
      "description": "AshTag is a modular .NET backdoor and malware suite used by Ashen Lepus for stealthy persistence, remote command execution, file exfiltration, content download, and in-memory execution of additional modules. It masquerades as a legitimate VisualServer utility and is orchestrated by the AshenOrchestrator component.",
      "malware_types": [
        "backdoor",
        "remote-access-trojan"
      ],
      "is_family": true,
      "aliases": [],
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/hamas-affiliate-ashen-lepus-uses-new-malware-suite-ashtag/"
        }
      ],
      "labels": [
        ".NET",
        "modular",
        "espionage",
        "data-exfiltration"
      ]
    },
    {
      "type": "malware",
      "id": "malware--7993ed84-d24a-42ff-a494-6a4e490d9280",
      "name": "AshenLoader",
      "description": "AshenLoader is a custom loader used by Ashen Lepus to side-load malicious DLLs, open decoy documents, and retrieve next-stage payloads. It features enhanced payload encryption (AES-CTR-256), endpoint fingerprinting, and evolving URI schemes. It is an evolution of the group's previous IronWind loader.",
      "malware_types": [
        "loader"
      ],
      "is_family": false,
      "aliases": [
        "IronWind (previous version)"
      ],
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/hamas-affiliate-ashen-lepus-uses-new-malware-suite-ashtag/"
        }
      ],
      "labels": [
        ".NET",
        "loader",
        "dll-sideloading",
        "espionage"
      ]
    },
    {
      "type": "malware",
      "id": "malware--08c95329-546b-475f-95a7-1594a6380588",
      "name": "AshenStager",
      "description": "AshenStager is a stager module side-loaded by AshenLoader, responsible for retrieving and running the AshTag payload, setting persistence via scheduled tasks, and parsing HTML responses to extract encrypted payloads hidden within HTML tags.",
      "malware_types": [
        "stager"
      ],
      "is_family": false,
      "aliases": [
        "Stager-X64"
      ],
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/hamas-affiliate-ashen-lepus-uses-new-malware-suite-ashtag/"
        }
      ],
      "labels": [
        ".NET",
        "stager",
        "dll-sideloading",
        "espionage"
      ]
    },
    {
      "type": "malware",
      "id": "malware--e661c844-28af-4cbe-8fc1-e57a28831dd6",
      "name": "AshenOrchestrator",
      "description": "AshenOrchestrator is a component of the AshTag malware suite responsible for orchestrating communication, decoding encrypted payloads from HTML content, and executing modules in memory. It uses Base64-encoded JSON configurations with parameters for C2 domains, encryption keys, and module management.",
      "malware_types": [
        "orchestrator",
        "backdoor"
      ],
      "is_family": false,
      "aliases": [],
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/hamas-affiliate-ashen-lepus-uses-new-malware-suite-ashtag/"
        }
      ],
      "labels": [
        ".NET",
        "orchestrator",
        "espionage"
      ]
    },
    {
      "type": "malware",
      "id": "malware--905f983f-1dfa-4813-9bdd-1eabab4b9b9a",
      "name": "AshTag SN Module",
      "description": "The SN module is a component of the AshTag malware suite, designed for system fingerprinting. It executes WMI queries and sends a unique victim ID back to the attackers.",
      "malware_types": [
        "fingerprinting"
      ],
      "is_family": false,
      "aliases": [],
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/hamas-affiliate-ashen-lepus-uses-new-malware-suite-ashtag/"
        }
      ],
      "labels": [
        ".NET",
        "system-fingerprinting",
        "espionage"
      ]
    },
