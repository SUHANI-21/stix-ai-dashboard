    {
      "type": "attack-pattern",
      "id": "attack-pattern--23fc4cb7-03e7-4cca-8560-3ce112f1b3c7",
      "name": "Phishing for Initial Access",
      "description": "DarkCloud is primarily distributed via phishing campaigns, often targeting HR departments, using emails with malicious attachments or links.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1566.001"
        }
      ],
      "labels": [
        "phishing",
        "initial-access"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f713b280-a26e-4668-84ef-51117fc3e1ab",
      "name": "Command and Scripting Interpreter",
      "description": "DarkCloud uses various script loaders, including PowerShell, JAR, BAT, VBS, and AutoIT, to execute malicious code and download additional payloads.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1059"
        }
      ],
      "labels": [
        "execution",
        "script"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d5192187-aecc-4c38-92a4-93c480a11a84",
      "name": "Persistence via Registry Run Keys / Startup Folder",
      "description": "DarkCloud establishes persistence by creating VBS scripts in startup folders and modifying registry RunOnce keys.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1547.001"
        }
      ],
      "labels": [
        "persistence"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--13cebd37-a09a-4198-a803-7efe6b252ce8",
      "name": "Process Injection",
      "description": "DarkCloud injects its stealer payload into legitimate processes such as svchost, InstallUtil, MSBuild, or itself to evade detection.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1055"
        }
      ],
      "labels": [
        "defense-evasion",
        "process-injection"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ce1a8f17-e5b1-4db9-9e85-a2152012dfaa",
      "name": "Obfuscated Files or Information",
      "description": "DarkCloud employs multiple obfuscation and packing techniques, including Base64 and TripleDES encryption, to hide its code and payloads.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1027"
        }
      ],
      "labels": [
        "defense-evasion",
        "obfuscation"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2d7a907b-9c0e-4032-b0cf-00a87d1aead1",
      "name": "Credential Access via Browser Data Theft",
      "description": "DarkCloud steals credentials from browsers and password managers by accessing files such as Login Data, WebData, logins.json, and key databases.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1555"
        }
      ],
      "labels": [
        "credential-access",
        "browser-data"
      ]
    },
