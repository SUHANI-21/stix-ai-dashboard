  "objects": [
    {
      "type": "malware",
      "id": "malware--189dd06b-1c20-467d-85a0-c7c3d56e3ec5",
      "name": "DarkCloud",
      "description": "DarkCloud is a stealer malware first observed in 2022, widely distributed via phishing campaigns and malvertising. It is sold on underground forums, often with transactions coordinated via Telegram. DarkCloud is typically delivered through phishing emails containing documents, compressed files, or scripts (JAR, BAT, PowerShell, VBS, AutoIT). The infection chain involves loaders that download, decrypt, and inject the stealer into memory, often using obfuscation and packing techniques. The malware targets HR departments and general users, sometimes distributed alongside other malware such as DbatLoader or ClipBanker.",
      "malware_types": [
        "stealer"
      ],
      "is_family": true,
      "first_seen": "2022-01-01T00:00:00Z",
      "last_seen": "2023-12-31T00:00:00Z",
      "aliases": [],
      "operating_system_refs": [
        "windows--"
      ],
      "capabilities": [
        "credential theft",
        "keylogging",
        "screen capture",
        "browser data theft",
        "system information discovery",
        "process injection",
        "email collection",
        "clipboard data theft",
        "persistence via registry and scheduled tasks",
        "virtualization/sandbox evasion"
      ],
      "external_references": [
        {
          "source_name": "AnyRun",
          "url": "https://app.any.run/tasks/f3c56abe-04b8-432a-8011-4135871daedc"
        },
