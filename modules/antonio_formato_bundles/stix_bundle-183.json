    {
      "type": "malware",
      "id": "malware--fc80815c-7cd1-47fa-87c5-d70f300b1d83",
      "name": "Leaked Wallpaper",
      "description": "Leaked Wallpaper is a privilege escalation tool that extracts NetNTLM hashes from any session on a computer by changing the desktop wallpaper. It exploits CVE-2024-38100, a vulnerability in explorer.exe and DCOM Desktop Wallpaper objects. First seen in August 2024, it is inspired by the Fake Potato technique and used primarily in Red Team projects.",
      "malware_types": [
        "privilege escalation tool"
      ],
      "is_family": true,
      "first_seen": "2024-08",
