    {
      "type": "malware",
      "id": "malware--9604efa4-1621-474f-ad04-eb3d8ac17748",
      "name": "GoRed",
      "aliases": [
        "Bulldog Backdoor"
      ],
      "description": "GoRed is an advanced backdoor malware written in Go, first observed in 2023 and used for cyberespionage campaigns targeting Russian organizations, especially in the software development sector. It is attributed by some security companies to ExCobalt and Shedding Zmiy, and tracked by Kaspersky as Red Likho. GoRed supports multiple protocols for C2 communication, including DNS, ICMP, QUIC, and WSS, and includes modules for DNS tunneling, data packing, proxy mode, command execution, file system monitoring, information collection, beacon mode, ICMP tunneling, data exfiltration, reverse shell, and configuration retrieval.",
      "malware_types": [
        "backdoor",
        "remote access trojan"
      ],
      "is_family": true,
      "first_seen": "2023",
      "last_seen": "2025",
      "operating_system_refs": [
        "windows",
        "linux"
      ],
      "external_references": [
        {
          "source_name": "PT Security",
          "url": "https://ptsecurity.com/research/pt-esc-threat-intelligence/ex-cobalt-go-red-tehnika-skrytogo-tunnelya/"
        },
        {
          "source_name": "Kaspersky",
          "url": "https://securelist.ru/tag/gored/"
        }
      ],
      "labels": [
