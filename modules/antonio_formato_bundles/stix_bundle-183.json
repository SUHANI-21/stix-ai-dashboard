    {
      "type": "malware",
      "id": "malware--185ea2be-e62f-4cc6-ae0c-3e1e0311349a",
      "name": "Tuoni",
      "description": "Tuoni is an advanced C2 framework agent observed since February 2024, deployed by trojanized Sysinternals tools instead of Cobalt Strike. It communicates with its C2 server via shellcode listeners and named pipes, with observed pipe names VKJWPWSYI, AWJZRPGJW, and ZNTICNMLN. Tuoni was used for reconnaissance and is linked to BO Team operations.",
      "malware_types": [
        "C2 framework",
        "backdoor"
