  "objects": [
    {
      "type": "malware",
      "id": "malware--7d6e7c76-e79f-427e-85dd-abfc392e4fa8",
      "name": "Neptune Loader",
      "description": "Neptune Loader is an innovative HTTP loader project that provides robust and efficient control over computer systems through commands administered via user-friendly web panel. First advertised in November 2023 by a forum member named 'M0HX' on hackerforums[.]net. Controllers can be fingerprinted via open port 3000 with HTTP.TITLE 'Neptune - Login'.",
      "malware_types": [
        "remote-access-trojan"
      ],
      "first_seen": "2023-11-01",
      "labels": [
        "neptune",
        "malware",
        "loader",
        "c2"
      ],
      "external_references": [
        {
          "source_name": "Cypho Analysis",
          "url": "https://www.cypho.io/blogs/neptune-loader-exposing-hidden-realms-malware-command-control-vulnerability-undercover-effected-machines"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--63c4954b-4c84-4366-b50c-f6dc7adbd17e",
      "name": "Gremlin Stealer",
      "description": "Gremlin Stealer is a malware family first observed in the wild since at least March 2025. It bypasses Chrome cookie V20 protection and steals web browser cookies, stored autofill data, clipboard data, and credentials from applications like FTP clients, Steam, Discord, and Telegram. Controllers can be fingerprinted via open port 80 with HTTP.TITLE 'Gremlin Access'.",
      "malware_types": [
        "stealer"
      ],
      "first_seen": "2025-03-01",
      "labels": [
        "gremlin",
        "malware",
        "stealer",
        "c2"
      ],
      "external_references": [
        {
          "source_name": "Palo Alto Networks Unit 42",
          "url": "https://unit42.paloaltonetworks.com/new-malware-gremlin-stealer-for-sale-on-telegram/"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--8879c2be-15bf-4f9f-a8f9-e1cdd41928ec",
      "name": "SilentCryptoMiner",
      "description": "SilentCryptoMiner is a publicly available malware used by cybercriminals to perform unauthorized cryptocurrency mining. It has been used in multiple campaigns, including distribution via YouTube tutorial videos and SEO poisoning. Managed via Unam Web Panel.",
      "malware_types": [
        "cryptominer"
      ],
      "labels": [
        "cryptominer",
        "malware",
        "mining"
      ],
      "external_references": [
        {
          "source_name": "Kaspersky",
          "url": "https://securelist.com/silentcryptominer-spreads-through-blackmail-on-youtube/115788/"
        },
        {
          "source_name": "Kaspersky",
          "url": "https://securelist.com/miner-campaign-misuses-open-source-siem-agent/114022/"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--9ec157c8-acb1-4338-b63d-7644ae20e579",
      "name": "Unam Web Panel",
      "description": "Unam Web Panel is a web panel used to monitor and manage SilentCryptoMiner. First released in November 2021 by UnamSanctum. Controllers can be fingerprinted via open port 80 with HTTP.TITLE 'Unam Web Panel - Login'.",
      "malware_types": [
        "remote-access-trojan",
        "webshell"
      ],
      "first_seen": "2021-11-01",
      "labels": [
        "unam",
        "malware",
        "web-panel",
        "c2"
      ],
      "external_references": [
        {
          "source_name": "GitHub",
          "url": "https://github.com/UnamSanctam/UnamWebPanel"
        }
      ]
    },
