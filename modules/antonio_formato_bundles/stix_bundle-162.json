{
  "type": "bundle",
  "id": "bundle--1bbe7eb8-361c-4da7-8943-d451b03d0071",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--eff3e122-a239-4100-a5fc-89e837df2242",
      "name": "Scattered Spider",
      "aliases": [
        "Scattered Lapsus$ Hunters",
        "ShinyHunters"
      ],
      "description": "Scattered Spider (also known as Scattered Lapsus$ Hunters, which includes ShinyHunters) is a threat actor group responsible for the Gainsight breach and previously the Salesloft Drift hack. The group leverages supply chain attacks, targeting OAuth integrations and API keys to exfiltrate sensitive data and extort victims.",
      "first_seen": "2025-08-01T00:00:00Z",
      "goals": [
        "Data theft",
        "Extortion",
        "Public exposure of stolen information"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b0ee79d8-78cb-4aa0-aea7-6446f7642014",
      "name": "Compromise of OAuth Tokens for API Access",
      "description": "Threat actors compromise OAuth tokens and digital keys used by third-party applications to access Salesforce data, enabling unauthorized access and data exfiltration without direct user credential theft.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a42417b1-dfd2-4aa9-bf77-cdd8eab1154a",
      "name": "Supply Chain Attack via Third-Party SaaS Integrations",
      "description": "Threat actors exploit the trust relationship between platforms and third-party integrations, leveraging stolen data and compromised tokens to move laterally and compromise additional systems.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d68fca23-a06b-4247-9fb4-1cca7b58468a",
      "name": "Bulk Data Exfiltration via API Abuse",
      "description": "Attackers use legitimate API access provided by compromised OAuth tokens to perform large-scale data retrieval, including bulk exports of reports and sensitive information such as passwords and access keys.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--17ca624e-6aeb-44cc-868a-1f9aceadc4f5",
      "name": "Credential Stuffing and Brute Force Attacks",
      "description": "Threat actors attempt to compromise accounts by performing credential stuffing and brute force attacks against Salesforce authentication mechanisms.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b284aa91-50a0-4619-904e-b2d8eb2b9bf6",
      "name": "Administrator Account Impersonation",
      "description": "Attackers attempt to impersonate Salesforce administrator accounts to escalate privileges and facilitate further compromise.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--acbbfa01-40f9-41c4-8346-86237789c046",
      "name": "Suspicious Apex Code Execution",
      "description": "Attackers execute unusual or suspicious Apex code within Salesforce environments, potentially establishing backdoor access or facilitating data theft.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6322741e-d54e-49bb-89ec-3188341881ae",
      "name": "REST API Query Abuse",
      "description": "Threat actors abuse Salesforce REST API query patterns to access and exfiltrate sensitive data.",
      "x_mitre_platforms": [
        "SaaS"
      ]
    },
    {
      "type": "campaign",
      "id": "campaign--76549a45-0867-46a4-8560-81c469151135",
      "name": "Gainsight Breach (2025)",
      "description": "A SaaS supply chain attack targeting Gainsight-published applications integrated with Salesforce. Attackers maintained access for nearly three months, leveraging compromised OAuth tokens and stolen data from previous campaigns (Salesloft Drift) to exfiltrate sensitive information from hundreds of organizations.",
      "first_seen": "2025-08-01T00:00:00Z",
      "last_seen": "2025-11-21T00:00:00Z",
      "objective": "Exfiltration of Salesforce data, extortion, and public exposure of victim information."
    },
    {
      "type": "campaign",
      "id": "campaign--3cbee785-7825-40eb-bf48-bd324c4906c7",
      "name": "Salesloft Drift Hack (2025)",
      "description": "A precursor campaign to the Gainsight breach, where attackers compromised Salesloft Drift and used stolen data to access additional systems, enabling a cascading supply chain compromise.",
      "first_seen": "2025-08-01T00:00:00Z",
      "last_seen": "2025-09-30T00:00:00Z",
      "objective": "Initial access and data theft for use in subsequent supply chain attacks."
    },
