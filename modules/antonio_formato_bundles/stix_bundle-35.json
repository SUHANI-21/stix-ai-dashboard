  "objects": [
    {
      "type": "campaign",
      "id": "campaign--9e6b4862-947d-4b88-ad0a-67dcbd7a41b7",
      "name": "Recurring Credential-Based Attacks Targeting Palo Alto and SonicWall",
      "description": "A campaign involving high-volume login and bruteforce attempts targeting Palo Alto Networks GlobalProtect portals and SonicWall SonicOS API endpoints. The campaign is characterized by the use of three identical client fingerprints across multiple events and infrastructure, indicating tooling continuity. Activity was observed in late September to mid-October 2025, with a resurgence in December 2025.",
      "first_seen": "2025-09-20T00:00:00Z",
      "last_seen": "2025-12-03T00:00:00Z",
      "objective": "Credential harvesting and unauthorized access to network infrastructure.",
      "aliases": [
        "Palo Alto Networks Login Scanner",
        "SonicWall SonicOS API Scanner"
      ]
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--159c3b8e-da39-4b25-8fe4-e239a9aa5081",
      "name": "Client Fingerprint Credential Attackers",
      "description": "An intrusion set responsible for credential-based attacks against Palo Alto Networks GlobalProtect portals and SonicWall SonicOS API endpoints. The group is identified by the recurring use of three unique client fingerprints and shifting infrastructure across several ASNs.",
      "aliases": [
        "GlobalProtect/SonicWall Credential Attackers"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f19486c9-e619-47b0-b9f4-7054be9b3082",
      "name": "Brute Force Credential Attack Against Network Authentication Portals",
      "description": "Attackers attempt to gain unauthorized access to network authentication portals (e.g., Palo Alto GlobalProtect, SonicWall SonicOS API) using high-volume login and brute-force techniques.",
      "x_mitre_id": "T1110",
      "aliases": [
        "Login Scanner",
        "API Scanner"
      ]
    },
    {
      "type": "infrastructure",
