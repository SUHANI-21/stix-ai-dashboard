  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7ab8ba64-808b-4ddc-901e-80ef0d4f5277",
      "name": "HTML Overlay Credential Theft",
      "description": "Uses persistent HTML overlays to mimic legitimate banking apps and capture user credentials. Overlays are stored locally and triggered for targeted apps, with input exfiltrated to C2 via WebView JavaScript bridge.",
      "external_references": [
        {
          "source_name": "ThreatFabric",
          "url": "https://www.threatfabric.com/hubfs/MTI_Blog_Sturnus3.jpg"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--18fb6c92-668c-4794-ac35-8f069fcb7717",
      "name": "Accessibility-Based Keylogging",
      "description": "Leverages Android Accessibility Service to capture keystrokes, UI events, and reconstruct user activity. Collects text changes, focus shifts, and UI interactions for exfiltration.",
      "external_references": [
        {
          "source_name": "ThreatFabric",
          "url": "https://www.threatfabric.com/hubfs/MTI_Blog_Sturnus3.jpg"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8098a0ec-5880-4340-b944-9c502848927f",
      "name": "Screen Capture and Streaming",
      "description": "Streams device screen to attackers in real time using display-capture and Accessibility-based screenshot techniques. Enables remote control and monitoring of user activity.",
      "external_references": [
        {
          "source_name": "ThreatFabric",
          "url": "https://www.threatfabric.com/hubfs/vnc.png"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2c3efd64-362e-48ba-945b-9b7b2c7d9b1c",
      "name": "Encrypted Messaging Bypass",
      "description": "Monitors encrypted messaging apps (WhatsApp, Telegram, Signal) by capturing decrypted content from the device screen via Accessibility logging, bypassing end-to-end encryption.",
      "external_references": [
        {
          "source_name": "ThreatFabric",
          "url": "https://www.threatfabric.com/hs-fs/hubfs/MessagingApps.png"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2dedac56-201f-4104-8e67-5426122d9f69",
      "name": "Device Administrator Abuse",
      "description": "Secures and defends Android Device Administrator privileges to block removal and persist on device. Monitors and interferes with attempts to disable admin status.",
      "external_references": [
        {
          "source_name": "ThreatFabric",
          "url": "https://www.threatfabric.com/hs-fs/hubfs/image-png-Nov-18-2025-12-47-39-4206-PM.png"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f81a0d95-059d-46fa-a5d3-ddee01a860b4",
      "name": "Environmental Monitoring",
      "description": "Continuously tracks device state, connectivity, power, SIM, app installs, USB, forensic signs, and security settings to evade analysis and adapt tactics.",
      "external_references": [
        {
          "source_name": "ThreatFabric",
          "url": "https://www.threatfabric.com/hs-fs/hubfs/env.png"
        }
      ]
    },
