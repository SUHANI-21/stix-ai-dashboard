  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d1176460-a37d-4399-b9c1-2d5cdbcc953b",
      "name": "Typosquatting in Maven Central",
      "description": "Attackers publish a malicious package under a namespace nearly identical to a popular library (org.fasterxml.jackson.core vs com.fasterxml.jackson.core), exploiting Java's reverse-domain convention and TLD prefix swaps to trick developers into installing the malware.",
      "external_references": [
        {
          "source_name": "Aikido Security Blog",
          "url": "https://www.aikido.dev/blog/maven-central-jackson-typosquatting-malware"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--dd3f12ea-35ea-4f8e-b770-fcf068b5dc87",
      "name": "Domain Typosquatting",
      "description": "Malicious infrastructure uses a domain (fasterxml.org) that closely mimics the legitimate vendor's domain (fasterxml.com) to evade casual inspection and facilitate command-and-control.",
      "external_references": [
        {
          "source_name": "Aikido Security Blog",
          "url": "https://www.aikido.dev/blog/maven-central-jackson-typosquatting-malware"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a598cc8a-b32a-4b49-aad5-0306f497e28f",
      "name": "Multi-stage Payload Delivery",
      "description": "Malware contacts a C2 server to retrieve AES-encrypted configuration, selects platform-specific payload URLs, downloads payloads, and executes them with suppressed output. Establishes persistence via marker file.",
      "external_references": [
        {
          "source_name": "Aikido Security Blog",
          "url": "https://www.aikido.dev/blog/maven-central-jackson-typosquatting-malware"
        }
      ]
    },
