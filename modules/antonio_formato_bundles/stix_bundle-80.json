    {
      "type": "attack-pattern",
      "id": "attack-pattern--ed4b6673-e281-47ae-baa6-e02782d136f7",
      "name": "Authentication Bypass via Improper Verification of Cryptographic Signature",
      "description": "Attackers may exploit improper verification of cryptographic signatures in Fortinet products to bypass FortiCloud SSO login authentication, gaining unauthorized administrative access.",
      "external_references": [
        {
          "source_name": "CWE",
          "external_id": "CWE-347"
        }
