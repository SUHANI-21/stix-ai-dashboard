    {
      "type": "vulnerability",
      "id": "vulnerability--7bd5da71-ab7e-4b37-8a81-6a6d220d0536",
      "name": "Fortinet FortiCloud SSO Login Authentication Bypass",
      "description": "An Improper Verification of Cryptographic Signature vulnerability (CWE-347) in FortiOS, FortiWeb, FortiProxy and FortiSwitchManager allows improper access control via FortiCloud SSO login authentication bypass. The vulnerability is present when FortiCloud SSO login is enabled, which is not the default setting but may be enabled during device registration. Impact includes improper access control.",
      "created": "2025-12-09T00:00:00.000Z",
      "modified": "2025-12-09T00:00:00.000Z",
      "external_references": [
        {
          "source_name": "CVE",
