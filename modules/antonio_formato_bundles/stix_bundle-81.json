  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--56b9df70-81c9-4703-b87e-6135553a92d2",
      "name": "Sandworm",
      "aliases": [
        "APT44",
        "Seashell Blizzard",
        "Curly COMrades"
      ],
      "description": "Sandworm is a Russian state-sponsored threat group assessed to be associated with Russia\u2019s Main Intelligence Directorate (GRU). The group has demonstrated sustained focus on Western critical infrastructure, particularly the energy sector, with operations spanning 2021 through 2025. The campaign involves a tactical pivot to targeting misconfigured customer network edge devices for initial access, credential harvesting, and lateral movement, while reducing vulnerability exploitation activity.",
      "first_seen": "2021-01-01T00:00:00Z",
      "last_seen": "2025-12-31T23:59:59Z",
      "goals": [
        "Persistent access to critical infrastructure networks",
        "Credential harvesting for accessing victim organizations\u2019 online services",
        "Lateral movement within victim environments"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "disruption"
      ],
      "external_references": [
        {
          "source_name": "Amazon Threat Intelligence",
          "url": "https://aws.amazon.com/security/"
        },
        {
          "source_name": "Bitdefender",
          "description": "Tracks Sandworm subcluster as 'Curly COMrades' with host-based tradecraft (Hyper-V abuse, CurlyShell/CurlCat implants)"
        }
      ],
      "threat_actor_types": [
        "nation-state"
      ],
      "roles": [
        "initial access",
        "credential harvesting",
        "lateral movement"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c70cbc44-d508-43b1-abda-71b00d2e940c",
      "name": "Compromise of Misconfigured Network Edge Devices",
      "description": "The threat actor targets misconfigured customer network edge devices (routers, VPN concentrators, remote access gateways, network management appliances) with exposed management interfaces to achieve persistent access and credential harvesting. This technique reduces exposure compared to vulnerability exploitation.",
      "x_mitre_platforms": [
        "Network",
        "Cloud"
      ],
      "x_mitre_tactic_type": [
        "Initial Access",
        "Credential Access",
        "Persistence"
      ],
      "external_references": [
        {
          "source_name": "Amazon Threat Intelligence",
          "url": "https://aws.amazon.com/security/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7e38b72e-1c88-4b6a-adf7-70fb0f66adb6",
      "name": "Exploitation of Known Vulnerabilities in Network Appliances",
      "description": "The actor has exploited vulnerabilities such as CVE-2022-26318 (WatchGuard), CVE-2021-26084 and CVE-2023-22518 (Confluence), and CVE-2023-27532 (Veeam) for initial access, although reliance on vulnerability exploitation has declined in favor of misconfiguration targeting.",
      "x_mitre_platforms": [
        "Network",
        "Cloud"
      ],
      "x_mitre_tactic_type": [
        "Initial Access"
      ],
      "external_references": [
