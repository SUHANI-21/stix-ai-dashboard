  "objects": [
    {
      "type": "malware",
      "id": "malware--dd18e091-687e-4c38-8f9f-71b898421d80",
      "name": "SwimSnake",
      "aliases": [
        "\u6e38\u86c7",
        "\u94f6\u72d0",
        "\u8c37\u843d\u5927\u76d7"
      ],
      "malware_types": [
        "remote-access-trojan",
        "trojan"
      ],
      "description": "SwimSnake (\u6e38\u86c7/\u94f6\u72d0) is a remote access trojan (RAT) and malware family operated by a Chinese-speaking cybercriminal group. It is distributed via multi-stage loader and multi-layer encryption and packing techniques. It primarily targets Chinese domestic users for fraud and credential theft, and leverages phishing, SEO poisoning, and fake download sites for delivery. SwimSnake uses a variety of anti-detection and anti-EDR techniques, including kernel-level drivers, process hiding, and BYOVD (Bring Your Own Vulnerable Driver) attacks. The malware can execute a wide range of functions, including screen capture, keylogging, audio monitoring, remote shell, DDoS, and proxy operations.",
      "is_family": true,
      "operating_system_refs": [
        "windows"
      ],
      "implementation_languages": [
        "C",
        "C++",
        "VBS"
      ],
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "SwimSnake",
        "\u6e38\u86c7",
        "\u94f6\u72d0",
        "Gh0st",
        "Winos",
        "remote-access-trojan",
        "trojan"
      ]
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--bf0582a3-4c93-4677-9967-b7f112c06cbd",
      "name": "SwimSnake Group",
      "aliases": [
        "\u6e38\u86c7\u56e2\u4f19",
        "\u94f6\u72d0",
        "\u8c37\u843d\u5927\u76d7"
      ],
      "description": "SwimSnake Group (\u6e38\u86c7\u56e2\u4f19/\u94f6\u72d0/\u8c37\u843d\u5927\u76d7) is a Chinese-speaking cybercriminal organization active since at least 2022. The group operates SwimSnake RAT and related malware, targeting domestic Chinese users for fraud, credential theft, and data exfiltration. They employ phishing emails, SEO poisoning, fake download sites, and social engineering via instant messaging platforms (WeChat, QQ) to lure victims. The group is known for Fraud-as-a-Service (FaaS) operations, selling or leasing attack tools and infrastructure to other criminal affiliates.",
      "goals": [
        "fraud",
        "credential theft",
        "data exfiltration"
      ],
      "resource_level": "organization",
      "primary_motivation": "financial",
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "\u6e38\u86c7\u56e2\u4f19",
        "\u94f6\u72d0",
        "\u8c37\u843d\u5927\u76d7",
        "FaaS",
        "Fraud-as-a-Service"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--12fcd640-0287-4e33-9d5d-d9fad4a470b0",
      "name": "SEO Poisoning for Malware Delivery",
      "description": "The attacker creates fake download sites for popular software (e.g., WPS Office, \u6709\u9053\u7ffb\u8bd1) and leverages SEO techniques to push these sites to the top of search engine results. Victims searching for legitimate software are lured into downloading trojanized installers that deliver SwimSnake malware.",
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "SEO poisoning",
        "phishing",
        "fake software download",
        "malware delivery"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3e5f2709-42e4-4d6f-80b1-cb3f62962a3b",
      "name": "Phishing via Instant Messaging",
      "description": "The attacker sends phishing messages and malicious files via instant messaging platforms (WeChat, QQ, \u4f01\u4e1a\u5fae\u4fe1) to lure users into joining fraudulent groups and downloading malware.",
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "phishing",
        "social engineering",
        "instant messaging",
        "WeChat",
        "QQ"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f74ae647-2d4f-4346-b628-e17cf6696dff",
      "name": "Multi-stage Loader with Multi-layer Encryption",
      "description": "Malicious installers (MSI, EXE) drop legitimate software and hidden VBS scripts. These scripts decrypt and load further components, using multiple layers of encryption and packing to evade detection. Core payloads include encrypted DLLs and configuration files with embedded C2 addresses.",
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "multi-stage loader",
        "encryption",
        "packing",
        "defense evasion"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8da31c1e-1ce3-4fc5-baee-3047ca564f4b",
      "name": "BYOVD (Bring Your Own Vulnerable Driver)",
      "description": "The attacker abuses legitimate but vulnerable drivers (e.g., NVIDIA.exe, BdApiUtil64.sys) to gain kernel-level privileges and terminate security software processes, evade EDR detection, and hide malicious activities.",
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "BYOVD",
        "kernel-level",
        "defense evasion",
        "driver abuse"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d55fc04e-2f0d-4013-a128-4b6b0cb7e7a2",
      "name": "Process and Network Connection Hiding",
      "description": "The malware uses malicious drivers (Cndom6.sys, XiaoH.sys) to hook Windows kernel APIs and hide its processes and network connections, preventing detection and analysis by security software.",
      "external_references": [
        {
          "source_name": "Antiy",
          "url": "https://www.antiy.cn/research/notice&report/research_report/SwimSnake_Analysis_202404.html"
        }
      ],
      "labels": [
        "process hiding",
        "network hiding",
        "kernel API hooking"
      ]
    },
