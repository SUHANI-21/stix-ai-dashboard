{
  "type": "bundle",
  "id": "bundle--634e509e-0cce-4668-acc0-c8053055d408",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "campaign",
      "id": "campaign--d3326854-4f19-4680-9ccd-c2d484e60333",
      "name": "Campaign Trio",
      "description": "Active from February\u2013March 2025, Campaign Trio involved mass impersonation of three software brands (i4tools, Youdao, DeepSeek) using over 2,000 domains to deliver Gh0st RAT to Chinese-speaking users. Attackers used aggressive infrastructure deployment, hosting all domains on three IPs, and delivered trojanized MSI installers.",
      "aliases": [
        "Trio"
      ],
      "first_seen": "2025-02-01T00:00:00Z",
      "last_seen": "2025-03-31T23:59:59Z",
      "objective": "Compromise Chinese-speaking users via brand impersonation and deliver Gh0st RAT.",
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/impersonation-campaigns-deliver-gh0st-rat/"
        }
      ]
    },
    {
      "type": "campaign",
      "id": "campaign--57437d84-9c93-4083-b219-ee1f95d78b16",
      "name": "Campaign Chorus",
      "description": "Launched in May 2025, Campaign Chorus expanded impersonation to over 40 applications, using wave-based domain registration and cloud-hosted payloads. It featured advanced multi-stage infection chains and DLL sideloading to evade detection, continuing to target Chinese-speaking users.",
      "aliases": [
        "Chorus"
      ],
      "first_seen": "2025-05-15T00:00:00Z",
      "last_seen": "2025-10-01T00:00:00Z",
      "objective": "Compromise Chinese-speaking users through sophisticated impersonation and multi-stage delivery of Gh0st RAT.",
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/impersonation-campaigns-deliver-gh0st-rat/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c3f85af8-7a4e-43e5-bdfe-5bba0f1414fa",
      "name": "DLL Side-Loading",
      "description": "DLL side-loading is an evasion technique where a legitimate, signed executable loads a malicious DLL placed in the same directory. Used in Campaign Chorus to execute Gh0st RAT under the guise of a trusted process.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1574/001/",
          "external_id": "T1574.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ba17ef67-4f12-42e5-82fc-b5bdcc9069e7",
      "name": "Phishing via Brand Impersonation",
      "description": "Attackers create malicious websites impersonating legitimate software brands to lure users into downloading trojanized installers. Used for initial access in both campaigns.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1566/",
          "external_id": "T1566"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d43211de-a5b5-44b0-9745-8425c88437de",
      "name": "User Execution: Malicious File",
      "description": "The infection chain relies on users executing downloaded MSI or EXE files, which initiate the malware installation process.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1204/002/",
          "external_id": "T1204.002"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d6b59aec-34ad-4c2c-81b1-944f5b608523",
      "name": "Command and Scripting Interpreter: PowerShell",
      "description": "PowerShell is used post-infection to add Windows Defender exclusions for the malware payload, aiding defense evasion.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1059/001/",
          "external_id": "T1059.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--baf88a72-a1dd-4472-9084-8f0f9e63c894",
      "name": "Command and Scripting Interpreter: Visual Basic",
      "description": "VBScript is embedded as a custom action in MSI installers to act as a multi-stage dropper, assembling and decrypting next-stage malware.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1059/005/",
          "external_id": "T1059.005"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1d490f06-1ef5-4807-a09d-b3930a99310d",
      "name": "System Binary Proxy Execution: Msiexec",
      "description": "Malicious MSI installers are used as the primary delivery vehicle for initial droppers, leveraging legitimate system binaries.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1218/007/",
          "external_id": "T1218.007"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--eeef75dd-824c-4bc6-8925-3d862861eafa",
      "name": "Impair Defenses: Disable or Modify Tools",
      "description": "The malware adds exclusions to Windows Defender to prevent detection of its components.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1562/001/",
          "external_id": "T1562.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--00e01bda-715f-4b6a-b360-0e2a47bc12e9",
      "name": "Application Layer Protocol: Web Protocols",
      "description": "C2 traffic is observed using standard TCP and HTTP protocols for communication between infected hosts and attacker infrastructure.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1071/001/",
          "external_id": "T1071.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--0b82f9cc-c0af-48bf-9494-017850b7aaca",
      "name": "Encrypted Channel: Symmetric Cryptography",
      "description": "C2 communication over TCP port 8080 is encrypted to evade network inspection.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1573/001/",
          "external_id": "T1573.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7afb0192-911b-45ef-a60c-ffca15d782b8",
      "name": "Acquire Infrastructure",
      "description": "The actor acquired over 2,000 domains and multiple IP addresses to host malicious websites and C2 servers.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1583/",
          "external_id": "T1583"
        }
      ]
    },
