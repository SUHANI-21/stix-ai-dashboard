  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--b88cd028-c648-45b5-a638-57eea957fd32",
      "name": "Command Injection in NASA CryptoLib",
      "description": "A critical command injection vulnerability (CVE-2025-59534) was discovered in NASA's CryptoLib software, which protects communications between spacecraft and Earth. The flaw existed for three years in authentication code, specifically in the initialize_kerberos_keytab_file_login() function, where user-controlled input was interpolated into a shell command executed via system(). This allowed attackers with configuration access to execute arbitrary commands with system privileges. The vulnerability affected all versions through v1.4.1 and was fixed in v1.4.2 by replacing system() with fork() and execlp(), and adding input validation.",
      "created": "2025-09-19T00:00:00Z",
      "modified": "2025-09-22T00:00:00Z",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-59534",
          "url": "https://nvd.nist.gov/vuln/detail/CVE-2025-59534"
        },
        {
          "source_name": "GHSA",
          "external_id": "GHSA-jw5c-58hr-m3v3",
          "url": "https://github.com/nasa/CryptoLib/security/advisories/GHSA-jw5c-58hr-m3v3"
        }
      ],
      "labels": [
        "command-injection",
        "CWE-78",
        "authentication",
        "critical-infrastructure",
        "spacecraft",
        "cryptography"
      ]
    },
    {
      "type": "software",
      "id": "software--6db371b5-9f36-4249-9225-06f9d6ec974a",
      "name": "CryptoLib",
      "description": "NASA CryptoLib implements the CCSDS Space Data Link Security protocol and is used across NASA missions and industry via cFS. It provides cryptographic protection for spacecraft-to-ground communications.",
      "cpe": "cpe:2.3:a:nasa:cryptolib:*",
      "version": "v1.4.1 and earlier (vulnerable), v1.4.2 and later (patched)",
      "external_references": [
        {
          "source_name": "GitHub",
          "url": "https://github.com/nasa/CryptoLib"
        },
        {
          "source_name": "cFS",
          "url": "https://github.com/nasa/cFS"
        }
      ],
      "labels": [
        "cryptography",
        "spacecraft",
        "CCSDS",
        "NASA"
      ]
    },
    {
      "type": "malware",
      "id": "malware--3b021abf-638c-4393-a614-f4a566fa27b3",
      "name": "Command Injection Payload via CryptoLib Configuration",
      "description": "Malicious payloads exploiting CVE-2025-59534 can be injected into CryptoLib's configuration fields (username or keytab_file_path) to execute arbitrary shell commands, such as file deletion or remote code execution.",
      "malware_types": [
        "remote-access-trojan"
      ],
      "labels": [
        "command-injection",
        "payload",
        "privilege-escalation"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2d2cad98-138c-4b29-8bf1-15ea0512fff4",
      "name": "Command Injection via Shell Metacharacters in Configuration",
      "description": "Attackers exploit the lack of input validation in CryptoLib's authentication configuration by injecting shell metacharacters into username or keytab_file_path fields, leading to arbitrary command execution when the system() call is invoked.",
      "external_references": [
        {
          "source_name": "CWE",
          "external_id": "CWE-78",
          "url": "https://cwe.mitre.org/data/definitions/78.html"
        }
      ],
      "labels": [
        "command-injection",
        "shell-metacharacter",
        "configuration-abuse"
      ]
    },
