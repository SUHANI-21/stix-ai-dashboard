{
  "type": "bundle",
  "id": "bundle--347610c6-4a73-4ba4-b14e-a8255a10fdb9",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1ec929df-39e1-434a-a5d7-5d05a575dba6",
      "name": "Malvertising via Sponsored Search Results",
      "description": "Threat actors use sponsored Google search results to redirect users to malicious LLM shared chats containing obfuscated commands and links to payloads.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Observed as initial infection vector in Shamus campaign."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--fa714a1a-907b-4fc4-ae3a-f7a7e8fb4b19",
      "name": "Social Engineering via LLM Shared Chats",
      "description": "Attackers configure public LLM shared chats to provide malicious terminal commands for common troubleshooting queries, exploiting user trust.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Used in Shamus campaign to distribute malicious instructions."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--0a335677-c694-43bf-a78f-5372c9c957f0",
      "name": "Credential Harvesting via Fake Password Prompts",
      "description": "Malware prompts users for their system password via terminal loops and fake macOS dialogs, validates and stores credentials for privilege escalation.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Implemented in Shamus AppleScript payload."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--58650915-9cab-42e8-86a5-b68307251588",
      "name": "Persistence via LaunchDaemon Installation",
      "description": "Malware installs a LaunchDaemon plist in /Library/LaunchDaemons to achieve root-level persistence and automatic execution after reboot.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Shamus campaign uses com.finder.helper LaunchDaemon for persistence."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--bcb9eccc-f9bf-4d1f-ae88-3bb661b9989d",
      "name": "Application Trojanization",
      "description": "Malware replaces legitimate cryptocurrency wallet applications (e.g., Ledger Live, Trezor Suite) with trojanized versions to intercept transactions and maintain long-term access.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Observed in Shamus campaign targeting Ledger Live and Trezor Suite."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7a78ef53-1b31-484b-a7a7-eb3a684d2c50",
      "name": "Data Exfiltration via HTTP POST",
      "description": "Stolen data is archived and exfiltrated to attacker-controlled C2 servers using HTTP POST requests with custom headers.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Shamus campaign exfiltrates to http://45.94.47.205/contact."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4a7b44b0-1e78-4fe6-ba13-43c05e203e6b",
      "name": "VM/Sandbox Detection",
      "description": "Malware performs environment checks for virtualization or sandbox indicators and exits if detected to evade analysis.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Shamus AppleScript checks for QEMU, VMware, KVM, and specific hardware strings."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3f472659-cb6c-4cb9-b545-f57cdc2c1e2e",
      "name": "Browser and Wallet Data Theft",
      "description": "Malware targets browser profiles (Chromium, Firefox) and desktop cryptocurrency wallet directories to steal cookies, credentials, extension data, and wallet files.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Shamus campaign targets Chrome, Brave, Edge, Opera, Firefox, Electrum, Exodus, Ledger Live, Trezor Suite, and more."
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--5999c6b2-e3e3-44e5-b75a-a702fd890718",
      "name": "Terminal Hiding and Process Detachment",
      "description": "Malware hides its activity by detaching from the terminal and killing the Terminal process to avoid user detection.",
      "external_references": [
        {
          "source_name": "Miguel Twitter",
          "description": "Shamus AppleScript uses 'disown; pkill Terminal'."
        }
      ]
    },
    {
