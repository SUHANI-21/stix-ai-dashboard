  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--a92fed32-9493-4ac3-82e3-1d637efa61fc",
      "name": "CVE-2025-55182",
      "description": "CVE-2025-55182 is a deserialization and object traversal vulnerability in the React Server Component (RSC) protocol, also known as the Flight protocol. The vulnerability arises from missing validation of traversal paths in the RSC parser, allowing attackers to craft custom paths that traverse JavaScript's prototype chain. This enables arbitrary code execution on the server, leading to full compromise. Applications using RSC in Next.js are especially vulnerable.",
      "created": "2025-12-01T00:00:00.000Z",
      "modified": "2025-12-01T00:00:00.000Z",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-55182"
        },
        {
          "source_name": "Seqrite Blog",
          "url": "https://www.seqrite.com/blog/category/technical/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--72cbf86a-3d78-47d8-9b1f-2eb431da7bde",
      "name": "Prototype Pollution via Flight Protocol Path Traversal",
      "description": "Attackers exploit the RSC Flight protocol by submitting crafted multipart/form-data requests containing malicious path markers, such as $1:__proto__ and $1:constructor. This enables prototype pollution and traversal of the JavaScript object graph, leading to arbitrary code execution.",
      "created": "2025-12-01T00:00:00.000Z",
      "modified": "2025-12-01T00:00:00.000Z"
    },
