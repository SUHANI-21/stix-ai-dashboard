      "name": "Signed Binary Proxy Execution",
      "description": "Abuse of trusted Windows binaries (LOLBINs) such as ftp.exe and DeviceCredentialDeployment.exe to execute malicious scripts.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1218"
        }
      ]
    },
    {
