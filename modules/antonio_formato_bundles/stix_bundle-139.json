  "objects": [
    {
      "type": "campaign",
      "id": "campaign--1a9d3b18-802d-4ed1-82e6-a5d3d5ed5bb1",
      "name": "Operation Hanoi Thief",
      "description": "A spear-phishing campaign targeting Vietnamese IT departments and HR recruiters using fake resume pseudo-polyglot type documents. The campaign delivers a multi-stage infection chain culminating in the LOTUSHARVEST DLL stealer. The campaign is attributed with medium confidence to a Chinese-origin threat actor.",
      "aliases": [
        "Hanoi Thief"
      ],
      "objective": "Harvest browser credentials and history from targeted professionals.",
      "start_time": "2025-11-03",
      "targeted_sectors": [
        "Information Technology",
        "Recruitment & HR Firms"
      ],
      "targeted_locations": [
        "Vietnam"
      ]
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--173dfa8c-93bc-4026-a4ef-b80328cb0572",
      "name": "Unattributed Chinese-origin Threat Actor",
      "description": "Threat actor assessed with medium confidence to be of Chinese origin, targeting Vietnamese IT and HR sectors with spear-phishing and credential stealing campaigns. Attribution to state sponsorship is not confirmed.",
      "aliases": [
        "Chinese-origin Hanoi Thief group"
      ],
      "goals": [
        "Credential theft",
        "Information gathering"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage"
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--04f33cf5-3295-4e7c-8507-3931d8b617e0",
      "name": "Spearphishing Attachment",
      "description": "Use of spear-phishing emails with ZIP attachments containing malicious LNK and pseudo-polyglot payloads.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1566.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4ac5698f-0298-4712-a465-bcbad8b463f1",
      "name": "Develop Payloads: Malware",
      "description": "Development of custom malware payloads for use in targeted attacks.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1587.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--258e72b8-1749-41b5-946d-78a698d1dcac",
      "name": "User Execution: Malicious File",
      "description": "Execution of malicious files by tricking users (e.g., LNK file, pseudo-polyglot payload).",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1204.002"
        }
      ]
    },
    {
      "type": "attack-pattern",
