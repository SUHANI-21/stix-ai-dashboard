    {
      "type": "intrusion-set",
      "id": "intrusion-set--1121b7e1-5f0f-4efc-b8c8-ab5385988017",
      "name": "APT41",
      "aliases": [
        "Blackfly",
        "Grayfly",
        "Redfly",
        "Earth Longzhi"
      ],
      "description": "APT41 is one of the longest-running Chinese espionage groups, believed to be composed of multiple sub-groups, including Blackfly, Grayfly, Redfly, and Earth Longzhi. The group has targeted victims in Taiwan, China, Thailand, Malaysia, Indonesia, Pakistan, Ukraine, and the United States, focusing on espionage and monitoring foreign governments' attitudes and policies toward China.",
      "first_seen": "2012-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Persistence",
        "Credential Access"
      ],
      "resource_level": "nation-state",
      "primary_motivation": "espionage"
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--204f5aa5-18b6-4817-bc1d-b7b52f851917",
      "name": "Kelp",
      "aliases": [
        "Salt Typhoon",
        "Earth Estries"
      ],
      "description": "Kelp (aka Salt Typhoon, Earth Estries) is a China-linked threat group that came to global prominence in 2024 for compromising the networks of multiple U.S. telecoms companies in the run-up to the 2024 U.S. presidential election, intercepting communications of campaign staff. The group shares tools with other Chinese actors and has targeted organizations in dozens of countries.",
      "first_seen": "2022-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Persistence"
      ],
      "resource_level": "nation-state",
      "primary_motivation": "espionage"
    },
