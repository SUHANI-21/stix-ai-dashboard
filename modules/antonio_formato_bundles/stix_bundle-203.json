      "name": "Cavalry Werewolf",
      "description": "Cavalry Werewolf is a hacker group targeting Russian government organizations. The group prefers to use open-source malware, including various backdoors, for remote command execution and persistence in compromised networks. They frequently use phishing emails with malicious attachments as an initial access vector and leverage Telegram API for C2 operations.",
      "aliases": [
        "Cavalry Werewolf"
      ],
      "goals": [
        "Collection of confidential information",
        "Network reconnaissance",
        "Persistence in target infrastructure"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "external_references": [
        {
          "source_name": "Dr.Web PDF Report",
          "url": "https://st.drweb.com/static/new-www/news/2025/october/cavalry_werewolf/Cavalry_Werewolf_ru.pdf"
        }
      ]
