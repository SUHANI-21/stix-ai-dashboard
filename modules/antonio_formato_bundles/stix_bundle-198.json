    {
      "type": "attack-pattern",
      "id": "attack-pattern--0f895a92-900a-48e5-bd81-3121ddac1f55",
      "name": "Phishing via Fake Google Play Pages",
      "description": "Adversaries create counterfeit Google Play Store pages and phishing overlays to trick users into installing Fantasy Hub. These pages may impersonate legitimate apps such as Telegram or banking applications.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1660",
          "external_id": "T1660"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2536ece8-d013-4bb2-bc7b-a490a8642349",
      "name": "Event Triggered Execution: Broadcast Receivers",
      "description": "Fantasy Hub creates broadcast receivers to receive SMS events and outgoing calls, enabling persistence and monitoring of device activity.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1624/001/",
          "external_id": "T1624.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--329d1b8e-8641-41bc-aae7-e37ec53e4d29",
      "name": "Masquerading: Match Legitimate Name or Location",
      "description": "Fantasy Hub payloads impersonate Google Play icons and names to evade detection and lower user suspicion.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1655/001/",
          "external_id": "T1655.001"
        }
      ]
    },
    {
