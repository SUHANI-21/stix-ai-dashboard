      "name": "Fantasy Hub MaaS Campaign",
      "description": "A campaign involving the distribution of Fantasy Hub Android RAT via fake Google Play pages and phishing overlays, targeting financial institutions (Alfa, PSB, Tbank, Sber) and general Android users. The campaign leverages Telegram bot subscriptions and social engineering.",
      "aliases": [
        "FantasyHub MaaS"
      ],
      "external_references": [
