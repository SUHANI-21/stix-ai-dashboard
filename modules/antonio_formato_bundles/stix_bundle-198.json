      "name": "System Information Discovery",
      "description": "Fantasy Hub collects device information such as device name, brand, Android version, and IP address.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1426/",
          "external_id": "T1426"
        }
      ]
    },
    {
