    {
      "type": "vulnerability",
      "id": "vulnerability--e00ccf92-4492-475b-9c97-c28216c3f891",
      "name": "CVE-2025-8110",
      "description": "A symlink bypass vulnerability in Gogs (<= 0.13.3) allows authenticated users to overwrite files outside the repository, leading to Remote Code Execution (RCE). The flaw is a bypass of CVE-2024-55947 and arises because the Gogs API fails to validate the destination of symbolic links when writing files.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-8110"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--cb628dcd-c4ae-448f-a8ba-31b263fe2dde",
      "name": "CVE-2024-55947",
      "description": "A path traversal vulnerability in the PutContents API of Gogs allowed attackers to write files outside the git repository directory, potentially leading to code execution. The vulnerability was patched by adding input validation on the path parameter.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2024-55947"
        },
        {
          "source_name": "wiz",
          "url": "https://www.wiz.io/vulnerability-database/cve/cve-2024-55947"
        }
      ]
    },
    {
