  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--0636f6a3-f9ce-4ac9-a854-b8851d0e5589",
      "name": "Spear-phishing via LNK file",
      "description": "Attackers deliver a ZIP archive containing a malicious Windows LNK shortcut file via spear-phishing email. When executed, the LNK file launches a browser to a legitimate-looking site to distract the user while executing malicious actions in the background.",
      "external_references": [
        {
          "source_name": "GBHackers",
          "url": "https://gbhackers.com/mastastealer-exploits-windows/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6efa6b9e-85eb-47c7-8e19-d07bc3369e8f",
      "name": "MSI-based malware deployment",
      "description": "Malicious MSI installer is downloaded from a typosquatting domain and executed to decompress contents in a temporary directory and drop the actual payload (dwm.exe) into the Windows directory.",
      "external_references": [
        {
          "source_name": "GBHackers",
          "url": "https://gbhackers.com/mastastealer-exploits-windows/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4b04f30b-f060-4e9a-a51b-67f1a13fa6eb",
      "name": "PowerShell Defender exclusion",
      "description": "During MSI installation, a PowerShell command (Add-MpPreference -ExclusionPath ...) is executed to add the malware installation path to the Windows Defender exclusion list, disabling real-time protection for the payload.",
      "external_references": [
        {
          "source_name": "GBHackers",
          "url": "https://gbhackers.com/mastastealer-exploits-windows/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--482bb5b5-e767-4550-a85d-1c84ef736d21",
      "name": "Typosquatting for malware delivery",
      "description": "The campaign uses a typosquatting domain (anydesk[.]net) to host and deliver the malicious MSI installer, mimicking the legitimate AnyDesk site.",
      "external_references": [
        {
          "source_name": "GBHackers",
          "url": "https://gbhackers.com/mastastealer-exploits-windows/"
        }
      ]
    },
