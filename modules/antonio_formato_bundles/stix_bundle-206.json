  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f1d40538-be37-45ca-ab66-41eefecfb3bb",
      "name": "Windows Management Instrumentation",
      "description": "ShellClient RAT performs fingerprinting via Windows Management Instrumentation (WMI), gathering hardware details, BIOS data, MAC addresses, installed antivirus products, and networking information.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1047",
          "url": "https://attack.mitre.org/techniques/T1047/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--80eaec43-aa30-44bf-bc6a-e36e3a611ebd",
      "name": "System Services: Service Execution",
      "description": "MalKamak uses PAExec, a redistributable variant of PsExec, to launch CMD shells with SYSTEM privileges, manage services, exfiltrate Active Directory data, verify connectivity, and collect host details.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1569.002",
          "url": "https://attack.mitre.org/techniques/T1569/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c3c8bbc0-5c3b-4962-99d2-ed23d142de02",
      "name": "Create or Modify System Process: Windows Service",
      "description": "ShellClient RAT installs itself as a Windows Service named nhdService ('Network Hosts Detection Service') using InstallUtil.exe, set to start automatically and run as LocalSystem.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1543.003",
          "url": "https://attack.mitre.org/techniques/T1543/003/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--df2f8949-80ee-4145-8577-04d4b6d9ee90",
      "name": "Obfuscated Files or Information: Encrypted/Encoded File",
      "description": "ShellClient stores most strings, including configuration data, as raw bytes and converts them to Unicode or ASCII only at runtime to evade detection.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1027.013",
          "url": "https://attack.mitre.org/techniques/T1027/013/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--34be3d59-aac6-4e9c-836f-e0f4301839e9",
      "name": "Masquerading: Match Legitimate Resource Name or Location",
      "description": "ShellClient RAT process runs as svchost.exe, with the binary's internal name set to RuntimeBroker.exe to mimic legitimate Windows processes and evade detection.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1036.005",
          "url": "https://attack.mitre.org/techniques/T1036/005/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ad193cd6-7689-4113-a174-1b01389f3aa9",
      "name": "OS Credential Dumping: LSASS Memory",
      "description": "MalKamak deployed and executed lsa.exe to perform credential dumping by extracting the memory of lsass.exe and saving it to debug.bin, possibly a variant of SafetyKatz.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1003.001",
          "url": "https://attack.mitre.org/techniques/T1003/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f53180c3-ed2a-4c89-86b9-8a5c930f278f",
      "name": "Data Staged: Local Data Staging",
      "description": "MalKamak attackers used WinRAR (rar.exe) to compress and stage sensitive files for exfiltration.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1074.001",
          "url": "https://attack.mitre.org/techniques/T1074/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4ffd4a69-daaa-464b-96bf-de1e470ef390",
      "name": "Web Service: Bidirectional Communication",
      "description": "ShellClient RAT communicates with its command and control infrastructure using the Dropbox cloud platform and official Dropbox API, sending encrypted traffic to legitimate Dropbox domains.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1102.002",
          "url": "https://attack.mitre.org/techniques/T1102/002/"
        }
      ]
    },
    {
