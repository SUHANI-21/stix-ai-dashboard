      "id": "attack-pattern--66561cc0-c0e1-44ed-8891-0d3a520d0e27",
      "name": "Input Capture: GUI Input Capture",
      "description": "BlueDelta credential harvesting pages use JavaScript to exfiltrate credentials and relay CAPTCHA information, capturing usernames, passwords, and two-factor authentication codes.",
      "external_references": [
        {
          "source_name": "mitre-attack",
