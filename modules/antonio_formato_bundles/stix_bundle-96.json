      "type": "attack-pattern",
      "id": "attack-pattern--674247fb-da01-4274-ba5e-47ef79cc1a34",
      "name": "Spearphishing Link",
      "description": "BlueDelta distributed malicious PDF lures containing embedded links to credential-harvesting pages, enabling evasion of common email filtering and sandbox detection techniques.",
      "external_references": [
        {
          "source_name": "mitre-attack",
