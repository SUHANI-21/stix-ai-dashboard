    {
      "type": "intrusion-set",
      "id": "intrusion-set--aef03c54-ed36-4a0c-b2c9-897ef9eba00b",
      "name": "APT41",
      "aliases": [
        "Wicked Panda",
        "Brass Typhoon",
        "BARIUM",
        "Amoeba",
        "BRONZE ATLAS",
        "BRONZE EXPORT",
        "Blackfly",
        "Double Dragon",
        "Earth Baku",
        "G0044",
        "G0096",
        "Grayfly",
        "HOODOO",
        "LEAD",
        "Leopard Typhoon",
        "Red Kelpie",
        "TA415",
        "TG-2633",
        "WICKED PANDA",
        "WICKED SPIDER",
        "Winnti",
        "Pigfish"
      ],
      "description": "APT41 is a prolific and highly skilled threat actor, active since at least 2007, known for both cyber espionage and financially motivated cybercrime. The group targets a wide range of sectors, including U.S. state governments, shipping, logistics, technology, and media. APT41 is noted for its agility in weaponizing vulnerabilities, including rapid exploitation of newly disclosed flaws such as Log4Shell (CVE-2021-44228). Their operations feature persistence, living off the land, multi-stage payload delivery, credential theft, and defense evasion through obfuscation and stealthy exfiltration to cloud services. They use both web-based and DNS-based C2 channels, proxies, and encrypted payloads to maintain resilient communication.",
      "first_seen": "2007-01-01T00:00:00Z",
      "goals": [
        "Cyber espionage",
        "Financially motivated cybercrime"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "financial gain"
      ],
      "external_references": [
