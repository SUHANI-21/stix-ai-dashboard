  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--749d3792-a4cc-4f3b-bac0-05fdfc9420ad",
      "name": "VNC-Based Remote Access",
      "description": "Malware installs and activates a VNC-based remote access module, enabling real-time interaction and full device takeover. Attackers use this to control the device UI, perform fraudulent transactions, and monitor user activity.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--24c7b097-38c8-406f-a3b0-f159c6cadd02",
      "name": "Overlay Attack",
      "description": "Malware deploys overlay screens to impersonate legitimate applications or system updates, harvesting credentials such as banking passwords and crypto wallet seed phrases. Overlays include system update screens, black screens for concealment, and targeted overlays for specific financial apps.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7052e4ed-5dd5-471f-8809-7c867734fdb9",
      "name": "Dropper Application",
      "description": "Malware uses dropper applications distributed via social engineering lures and fake Google Play pages. The dropper obtains critical permissions and installs the final payload on the compromised device.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--811ebfcd-30b1-4c97-8c32-9c7b2b081fac",
      "name": "On-Device Fraud (ODF)",
      "description": "Malware enables attackers to execute fraudulent actions directly within legitimate banking or cryptocurrency apps on the victim's device, bypassing authentication and fraud-detection mechanisms.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b24dcec6-0fd2-495d-be45-1cb204522f1f",
      "name": "Accessibility Abuse",
      "description": "Malware abuses Android Accessibility Services to gain enhanced control over the device, interact with UI elements, and bypass screen recording protections such as FLAG_SECURE.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--06f3e775-6573-4a39-b0aa-f6e7bb0ae5f5",
      "name": "Command and Control via TCP Socket",
      "description": "Malware establishes persistent C2 communication over unencrypted TCP sockets, using structured JSON objects for command parsing and data exfiltration. Implements handshake, heartbeat, and various device manipulation commands.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3f186637-3c59-40e1-b2db-fe74d1469943",
      "name": "Obfuscated Delivery and Dynamic Unpacking",
      "description": "Malware employs code obfuscation and dynamic unpacking techniques (e.g., JSONPacker) to evade static detection during initial installation and payload delivery.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--65786e8d-3545-4b8b-92a6-76efb902ba91",
      "name": "Credential Harvesting",
      "description": "Malware targets banking and cryptocurrency applications using overlays and remote access to harvest user credentials, including passwords and seed phrases.",
      "x_mitre_platforms": [
        "Android"
      ]
    },
