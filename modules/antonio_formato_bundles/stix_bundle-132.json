    {
      "type": "malware",
      "id": "malware--76307a51-8d71-4504-bb2e-1804ddd5aaa6",
      "name": "01flip",
      "description": "01flip is a multi-platform ransomware family written entirely in Rust. It targets both Windows and Linux systems, encrypts files using AES-128-CBC and RSA-2048, and drops ransom notes with contact information. It employs defense evasion techniques such as using low-level system APIs, encoding strings, and removing itself after execution. The ransomware has been observed targeting critical infrastructure organizations in Southeast Asia, with victims in the Philippines and Taiwan. It is associated with financially motivated attackers tracked as CL-CRI-1036.",
      "malware_types": [
        "ransomware"
      ],
      "is_family": true,
      "operating_system_refs": [
        "windows",
        "linux"
      ],
      "implementation_languages": [
        "Rust"
      ],
      "external_references": [
