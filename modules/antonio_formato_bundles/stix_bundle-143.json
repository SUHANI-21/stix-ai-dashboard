      "type": "attack-pattern",
      "id": "attack-pattern--30a6c736-9d22-4cca-89d3-d237a896c73a",
      "name": "NPM Preinstall Supply Chain Attack",
      "description": "Compromised NPM packages execute malicious code during the preinstall phase, enabling credential harvesting and persistence.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        },
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "execution"
        }
      ],
      "external_references": [
        {
          "source_name": "SentinelOne",
          "url": "https://www.sentinelone.com/wp-content/uploads/2025/11/sha1-hulud2_0-1-scaled.jpg"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d68846b4-daeb-41bb-9c7a-a1c04fc67141",
      "name": "Credential Harvesting from Cloud Providers",
      "description": "Harvests AWS, Azure, and GCP secrets from compromised development environments for lateral movement and further compromise.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "credential-access"
        },
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "lateral-movement"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--de217be7-d5fe-4416-a371-4ea4b1b9d77e",
      "name": "Persistence via Malicious GitHub Actions Workflow",
      "description": "Establishes persistence by creating a malicious workflow file (discussion.yaml) in .github/workflows, allowing remote code execution triggered by crafted GitHub discussions.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "persistence"
        },
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "execution"
        }
      ]
    },
