  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--c6dc22f0-66a4-4cfd-a2b5-c7b51a3532d4",
      "name": "4BID",
      "description": "4BID is a pro-Ukrainian hacktivist group active since early 2025. The group publicly claims attacks against Russian organizations in various sectors including manufacturing, healthcare, and government. 4BID operates mainly via Telegram and has demonstrated collaboration with other hacktivist groups such as BO Team and Red Likho.",
      "aliases": [
        "4BID"
      ],
      "goals": [
        "Disruption of Russian organizations",
        "Data encryption and destruction",
        "Public disclosure of compromised information"
      ],
      "primary_motivation": "Ideological",
      "secondary_motivation": "Political"
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--83a2cb67-383b-4e4d-95d9-35704d9e0098",
      "name": "BO Team",
      "description": "BO Team is a hacktivist group known for large-scale operations against Russian targets. They are associated with the ZeronetKit backdoor and have used ransomware such as Babuk. BO Team has demonstrated collaboration with other hacktivist clusters.",
      "aliases": [
        "BO Team"
      ]
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--5cd406df-7087-4ed7-86f9-ce539239edf1",
      "name": "Red Likho",
      "description": "Red Likho is a hacktivist group known for large-scale operations against Russian targets and is associated with the GoRed backdoor. Red Likho has collaborated with other hacktivist groups such as 4BID and BO Team.",
      "aliases": [
        "Red Likho"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c9f26da7-64f9-43de-944e-6313facf2297",
      "name": "T1003.001 OS Credential Dumping: LSASS Memory",
      "description": "Dumping LSASS process memory using rundll32.exe and comsvcs.dll to extract credentials."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--56a158de-a163-4718-85a2-5212d0c46641",
      "name": "T1003.003 OS Credential Dumping: NTDS",
      "description": "Dumping NTDS.dit database using ntdsutil.exe for Active Directory credential extraction."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ec4a2cd3-8d95-42bb-8f33-1c9175e3a2b6",
      "name": "T1003.002 OS Credential Dumping: Security Account Manager",
      "description": "Exporting the Security registry hive to extract credentials."
