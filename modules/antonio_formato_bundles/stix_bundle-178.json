    {
      "type": "intrusion-set",
      "id": "intrusion-set--90b2e287-669c-40ce-95d2-77e1ca06523f",
      "name": "UNC1549",
      "aliases": [
        "UNC1549"
      ],
      "description": "UNC1549 is a suspected Iran-nexus threat group targeting the aerospace, aviation, and defense industries in the Middle East and beyond. The group employs a dual approach for initial access, including targeted phishing and exploitation of trusted third-party relationships. UNC1549 is known for sophisticated lateral movement, custom malware deployment, and long-term persistence.",
      "first_seen": "2023-10-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Credential theft",
        "Long-term persistence",
        "Data exfiltration"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "credential access",
        "defense evasion"
      ]
    },
    {
      "type": "tool",
      "id": "tool--65e9725f-da0b-42e2-8871-a54ad0d9ae03",
      "name": "Atelier Web Remote Commander (AWRC)",
      "description": "AWRC is a commercial utility for remotely managing, auditing, and supporting Windows systems. UNC1549 used AWRC for remote connections, reconnaissance, credential theft, and malware deployment post-compromise.",
      "tool_types": [
        "remote access",
        "reconnaissance",
        "credential access"
      ],
      "aliases": [
        "AWRC"
      ],
      "labels": [
        "commercial",
        "agentless"
      ]
    },
    {
      "type": "tool",
      "id": "tool--49e7a53b-a58c-44c8-96d3-a2179f31f482",
      "name": "SCCMVNC",
      "description": "SCCMVNC is a tool that leverages Microsoft System Center Configuration Manager's Remote Control feature to achieve VNC-like remote access without requiring user consent or notifications. UNC1549 used SCCMVNC for discreet remote access and lateral movement.",
      "tool_types": [
        "remote access",
        "lateral movement"
      ],
      "labels": [
        "open-source"
      ]
    },
