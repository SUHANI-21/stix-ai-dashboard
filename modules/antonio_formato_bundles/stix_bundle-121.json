  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--84d8aed8-f173-4490-9945-1436f82c5a90",
      "name": "Storm-0249",
      "aliases": [
        "Storm-0249"
      ],
      "description": "Storm-0249 is a financially motivated initial access broker (IAB) that has evolved from mass phishing to sophisticated post-exploitation tactics. The group specializes in stealth and persistence, enabling ransomware affiliates by selling pre-built access. Storm-0249 abuses legitimate Endpoint Detection and Response (EDR) processes, including SentinelOne's SentinelAgentWorker.exe, through techniques such as DLL sideloading, fileless execution, and domain spoofing.",
      "goals": [
        "Enable ransomware affiliates",
        "Establish persistent access",
        "Evade detection"
      ],
      "resource_level": "organization",
      "primary_motivation": "financial"
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e97cd03f-08c4-48d7-879e-27c9d0336317",
      "name": "DLL Side-Loading",
      "description": "Storm-0249 abuses DLL sideloading by placing malicious DLLs alongside legitimate executables (such as SentinelAgentWorker.exe) to evade detection and execute attacker code under the guise of trusted processes.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1574.002",
          "url": "https://attack.mitre.org/techniques/T1574/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--41f8c75c-6111-4353-94f8-fde8951fbc92",
      "name": "Fileless PowerShell Execution",
      "description": "Storm-0249 uses curl.exe to download malicious scripts and pipes them directly into PowerShell for in-memory execution, avoiding disk writes and traditional signature-based detection.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1059.001",
          "url": "https://attack.mitre.org/techniques/T1059/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7889ebca-50a5-46f2-94f7-6f9df865405b",
      "name": "Domain Spoofing",
      "description": "Storm-0249 creates fake domains that mimic legitimate Microsoft URLs to trick users and security tools into trusting malicious content.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1566.001",
          "url": "https://attack.mitre.org/techniques/T1566/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--adfcd50c-65d5-418b-842a-765cfa16e63d",
      "name": "Abuse of Trusted Security Software",
      "description": "Storm-0249 abuses digitally signed, trusted security software (SentinelAgentWorker.exe) to execute malicious code and establish C2 channels, blending malicious activity with legitimate operations."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6d3eb044-17b6-4afd-af0c-9585b6eba247",
      "name": "Reconnaissance via Living off the Land Binaries (LOLBins)",
      "description": "Storm-0249 uses legitimate Windows utilities such as reg.exe and findstr.exe under trusted processes to extract system information and identifiers like MachineGuid for ransomware preparation.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1082",
          "url": "https://attack.mitre.org/techniques/T1082/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f93f7677-133c-418e-9a4b-d316cb15e4a7",
      "name": "Command and Control via Trusted Process",
      "description": "Storm-0249 establishes encrypted command-and-control (C2) channels using compromised SentinelAgentWorker.exe processes, making malicious traffic appear as legitimate EDR telemetry.",
      "external_references": [
        {
          "source_name": "mitre-attack",
