  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--586c7136-582a-49e9-a588-e1620cc9c1f5",
      "name": "ToddyCat",
      "aliases": [
        "ToddyCat APT"
      ],
      "description": "ToddyCat is an advanced persistent threat (APT) group known for evolving techniques to covertly access business correspondence and credentials from target organizations, including attacks against Microsoft Exchange Server, Microsoft 365, and Gmail. The group has deployed custom tools for credential theft, email exfiltration, and access token extraction.",
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/toddycat-apt-steals-email-data-from-outlook/118044/"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--ca0f27b2-d2d4-4b73-afd8-5c10709d8061",
      "name": "TomBerBil",
      "description": "TomBerBil is a family of credential-stealing tools used by ToddyCat APT. It extracts cookies and saved passwords from browsers (Chrome, Edge, Firefox) and collects DPAPI encryption keys. The latest variant is implemented in PowerShell and executed on domain controllers via scheduled tasks, using SMB to access remote hosts.",
      "malware_types": [
        "credential-extraction"
      ],
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/toddycat-traffic-tunneling-data-extraction-tools/112443/"
        }
      ],
      "labels": [
        "PowerShell",
        "Credential Access"
      ]
    },
    {
      "type": "malware",
      "id": "malware--14f8ac4c-3130-402d-9509-ec4a860ef474",
      "name": "TCSectorCopy",
      "description": "TCSectorCopy is a 32-bit C++ tool used by ToddyCat APT for block-by-block copying of files that may be locked by applications or the OS, such as Outlook OST files. It bypasses the standard Windows API by reading directly from the disk device.",
      "malware_types": [
        "data-exfiltration"
      ],
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/toddycat-apt-steals-email-data-from-outlook/118044/"
        }
      ],
      "labels": [
        "Collection",
        "Outlook"
      ]
    },
    {
      "type": "malware",
      "id": "malware--0d7baaf2-701d-4c71-a9a8-bfcc9baf6a98",
      "name": "SharpTokenFinder",
      "description": "SharpTokenFinder is a C# tool used by ToddyCat APT to search for and extract OAuth 2.0 access tokens from the memory of Microsoft 365-related processes by dumping their memory and searching for JWT strings.",
      "malware_types": [
        "credential-access"
      ],
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/toddycat-apt-steals-email-data-from-outlook/118044/"
        }
      ],
      "labels": [
        "Token Theft",
        "Office 365"
      ]
    },
