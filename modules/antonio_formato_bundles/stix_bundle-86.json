      "name": "LongNosedGoblin",
      "aliases": [
        "LongNosedGoblin"
      ],
      "description": "A China-aligned APT group discovered by ESET Research, active since at least September 2023, targeting governmental entities in Southeast Asia and Japan for cyberespionage. The group uses Group Policy for malware deployment and lateral movement, and cloud services like OneDrive and Google Drive for C&C.",
      "first_seen": "2023-09-01T00:00:00Z",
      "goals": [
        "Cyberespionage",
        "Information theft from governmental entities"
      ],
      "primary_motivation": "espionage",
      "secondary_motivations": [],
      "resource_level": "organization",
