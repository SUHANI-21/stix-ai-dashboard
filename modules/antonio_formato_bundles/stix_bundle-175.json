{
  "type": "bundle",
  "id": "bundle--5953e9dd-d892-4078-a7c2-93c813eaf2ac",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--16c4a522-2a06-400f-b511-dd21f5dde36e",
      "name": "CVE-2023-48022",
      "description": "A disputed vulnerability in Ray, an open-source AI framework, allowing unauthenticated remote code execution via the Jobs API. Exploited in the ShadowRay campaigns for initial access, lateral movement, and payload delivery. Remains unpatched due to Ray's design assumptions.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2023-48022",
          "url": "https://nvd.nist.gov/vuln/detail/cve-2023-48022"
        },
        {
          "source_name": "Ray Security Docs",
          "url": "https://docs.ray.io/en/latest/ray-security/index.html"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--094c167b-23c2-4f1d-a400-220161f09f0c",
      "name": "Cryptojacking via Ray Cluster Exploitation",
      "description": "Attackers exploit exposed Ray Jobs API (CVE-2023-48022) to deploy cryptocurrency miners (XMRig, Rigel) on compromised clusters, leveraging legitimate orchestration features and process masquerading.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4d2aae13-d384-4e68-8d93-ca77126c1080",
      "name": "Lateral Movement via Ray Node Scheduling",
      "description": "Weaponization of Ray's NodeAffinitySchedulingStrategy to enumerate and compromise every alive node in a cluster, spreading malware laterally.",
      "external_references": [
        {
          "source_name": "Ray Docs",
          "url": "https://docs.ray.io/en/latest/ray-core/api/doc/ray.util.scheduling_strategies.NodeAffinitySchedulingStrategy.html"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a0af7923-dad7-4feb-86d6-31fbc814e305",
      "name": "Persistence via Cron and Systemd",
      "description": "Attackers establish persistence by creating cron jobs (every 15 minutes), systemd/init.d services, and .bashrc injections to continuously re-download and execute malware.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--823849fd-82f0-4831-bcfb-dcfa2d036cec",
      "name": "Masquerading as System Processes",
      "description": "Malicious binaries and processes are renamed to appear as legitimate system components (e.g., kworker/0:0, dns-filter, .python3.6) to evade detection.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--da71a37d-efe5-490b-8455-a8ad5f987a17",
      "name": "Region-Aware Payload Delivery",
      "description": "Malware adapts payload delivery based on victim geolocation (e.g., run-CN.sh for China, run.sh for other regions), using proxies and regional CDNs to bypass censorship and optimize delivery.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d065fb65-7485-49c9-bbad-eef843e61578",
      "name": "Competition Elimination",
      "description": "Malware actively detects and terminates rival cryptominers, blocks competing mining pools via hosts file and iptables, and protects its own mining process.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--63edd804-4567-4ada-862b-bdcef946c7cb",
      "name": "Sensitive Data Exfiltration",
      "description": "Attackers discover and exfiltrate credentials, proprietary AI models, source code, and datasets from compromised Ray clusters.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7344f461-e553-4665-a273-835afba489c8",
      "name": "DDoS via Compromised Clusters",
      "description": "Deployment of sockstress and other tools to launch denial-of-service attacks from compromised Ray clusters, targeting production websites and mining pools.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d1845d8f-9d40-434f-ba18-fb1443970c02",
      "name": "Self-Propagation (Worm-like Behavior)",
      "description": "Compromised clusters scan for additional exposed Ray dashboards and propagate malware, creating an autonomous, global botnet.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--658c4e1a-6e49-4b93-9d2a-5efaaf0747e7",
      "name": "Reverse Shell Establishment",
      "description": "Attackers establish interactive reverse shells to AWS-hosted and other C2 servers, providing command-line access to compromised Ray clusters.",
      "external_references": [
        {
          "source_name": "Oligo Security",
          "url": "https://www.oligo.security/blog/shadowray-attack-ai-workloads-actively-exploited-in-the-wild"
        }
      ]
    },
