    {
      "type": "malware",
      "id": "malware--0c8775f7-fe15-47ab-a026-c1e684845d94",
      "name": "Tsunami-Framework",
      "description": "A modular malware framework in active development, linked to North Korean threat actors and the 'Contagious Interview' campaign. It relies on the TOR network and Pastebin for command and control, incorporates multiple stealers, backdoors, botnet functionality, keylogger, and deploys two cryptominers (Monero and Ethereum). Persistence is achieved via scheduled tasks and Windows Defender/Firewall exclusions.",
      "malware_types": [
        "remote-access-trojan",
        "stealer",
        "crypto-miner",
        "backdoor",
        "botnet"
      ],
      "is_family": true,
      "aliases": [
        "Tsunami"
      ],
      "implementation_languages": [
        "Python",
        ".NET"
      ],
