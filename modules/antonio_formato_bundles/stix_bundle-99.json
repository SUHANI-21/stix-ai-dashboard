      "id": "file--0f88e593-e39a-4aed-93a0-a07d41d52368",
      "name": "system call table (sys_call_table)",
      "description": "Array of pointers to system call handler functions in the Linux kernel, modified to hook getpriority and execute injected shellcode."
    },
    {
