{
  "type": "bundle",
  "id": "bundle--3e0a9bbf-0044-4c47-a430-25afe3ede714",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--044d9912-c369-450b-949a-bf622885cead",
      "name": "Stack-based buffer overflow in Unisoc UIS7862A modem RLC protocol (CVE-2024-39432)",
      "description": "A stack-based buffer overflow vulnerability exists in the 3G RLC protocol implementation of the Unisoc UIS7862A modem, allowing remote code execution at the early stages of connection before protection mechanisms are activated.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2024-39432",
          "url": "https://nvd.nist.gov/vuln/detail/CVE-2024-39432"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--a028d31d-2701-48ec-8769-4fea92865b2c",
      "name": "Remote access vulnerability in Unisoc UIS7862A modem (CVE-2024-39431)",
      "description": "A vulnerability in the Unisoc UIS7862A modem enables remote access and code execution via manipulation of the RLC protocol stack, bypassing 3G communication protection mechanisms.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2024-39431"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a59f935b-e835-4089-b158-1e4b2068c7bd",
      "name": "ROP Chain Exploitation for Remote Code Execution",
      "description": "Attackers use Return Oriented Programming (ROP) chains to exploit a stack-based buffer overflow in the modem firmware, enabling remote code execution and persistence by manipulating AT command handlers and memory protection unit (MPU) tables."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d00e0db2-9722-47b2-baf9-1852bace6370",
      "name": "Lateral Movement via Direct Memory Access (DMA)",
      "description": "Attackers leverage a hidden DMA peripheral on the modem to perform lateral movement within the System-on-Chip (SoC), enabling modification and code execution on the Application Processor (AP) from the Communication Processor (CP)."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4d6b665c-e10a-4847-8454-799b8d436719",
      "name": "Kernel Symbol Table Manipulation and System Call Hooking",
      "description": "Attackers locate and manipulate the Linux kernel symbol table (kallsyms) and system call table (sys_call_table) to inject shellcode and hook system calls, achieving persistence and arbitrary code execution in the AP kernel."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--267dfed0-e570-42cf-b2e7-64ee2e1060f8",
      "name": "SELinux Policy Bypass",
      "description": "Attackers disable SELinux enforcement by modifying the selinux_enforcing global variable in kernel memory, allowing unauthorized user-mode process launches and further exploitation."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--10fad069-04a3-47a6-9115-d0ffb9e7cc7d",
      "name": "NAS Protocol Handler Patching",
      "description": "Attackers patch the NAS protocol handler on the modem to enable two-way communication and facilitate the delivery of exploit payloads using MM information and MM status commands."
    },
    {
      "type": "software",
      "id": "software--2e867dd0-eb94-4845-b724-35edbe750cf8",
      "name": "Unisoc UIS7862A",
      "description": "A System-on-Chip (SoC) featuring an integrated 2G/3G/4G modem used in various mobile devices and vehicle head units. Vulnerabilities in its modem component enable remote code execution and full compromise of the device.",
      "cpe": "cpe:2.3:o:unisoc:uis7862a"
    },
    {
