      "id": "file--88003b0f-1d23-492e-abab-c5841d07e14d",
      "name": "MPU table",
      "description": "Memory Protection Unit table in the modem, reconfigured to allow write access to code sections and shared AP/CP memory."
    },
    {
      "type": "file",
      "id": "file--5fedb848-b375-4982-97fd-5c8cf2acfda0",
      "name": "DMA controller code fragments",
      "description": "Unused code fragments in the modem OS enabling access to the DMA controller for lateral movement within the SoC."
    },
    {
