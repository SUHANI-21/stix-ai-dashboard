      "id": "file--2f0a22ee-2d26-46ad-9820-af0d2b2f9a66",
      "name": "Linux kernel shellcode",
      "description": "Position-independent ARM64 machine code injected into the kernel code section for privilege escalation and persistence."
    },
    {
      "type": "file",
      "id": "file--576e879b-f7bd-4720-a08f-c4f0df17ba33",
      "name": "NAS protocol handler patch",
      "description": "Patch to the NAS protocol handler in the modem firmware, enabling arbitrary code execution."
    },
