  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--22077c0a-f82e-4dae-9446-6d13817e4fb5",
      "name": "Lazarus Group",
      "aliases": [
        "Lazarus",
        "APT38",
        "Hidden Cobra"
      ],
      "description": "Lazarus Group is a North Korean government-aligned advanced persistent threat (APT) group known for cyberespionage, financial theft, and disruptive attacks. In October 2025, Lazarus targeted companies supplying UAV technology to Ukraine as part of the Operation DreamJob campaign, using the ScoringMathTea RAT.",
      "goals": [
        "Espionage",
        "Theft of UAV technology know-how"
      ],
      "resource_level": "government",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "financial gain"
      ],
      "external_references": [
        {
          "source_name": "ESET Research",
          "url": "https://www.welivesecurity.com/en/eset-research/gotta-fly-lazarus-targets-uav-sector/"
        }
      ]
    },
    {
      "type": "campaign",
      "id": "campaign--0492b8c2-2a97-4344-a5e1-35db7a243dd5",
      "name": "Operation DreamJob - Gotta Fly",
      "description": "Operation DreamJob - Gotta Fly is a cyberespionage campaign attributed to the Lazarus APT group, targeting companies involved in the production of Unmanned Aerial Vehicles (UAVs) for Ukraine. The campaign leverages the ScoringMathTea RAT for espionage and theft of sensitive technology.",
      "aliases": [
        "Gotta Fly"
      ],
      "first_seen": "2025-10-01T00:00:00Z",
      "objective": "Steal UAV production know-how from companies supplying Ukraine",
      "external_references": [
        {
          "source_name": "ESET Research",
          "url": "https://www.welivesecurity.com/en/eset-research/gotta-fly-lazarus-targets-uav-sector/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--39adb348-64aa-42ea-8092-8d5ba8d306e7",
      "name": "Reflective Code Loading",
      "description": "ScoringMathTea loads plugins (DLLs) directly from memory without writing them to disk, using reflective DLL injection.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1620",
          "url": "https://attack.mitre.org/techniques/T1620/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9c819977-1d94-4def-b725-3d3ed8f7189c",
      "name": "Native API",
      "description": "Implements PEB Walking to locate kernel32.dll and its own version of GetProcAddress to bypass API hooking.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1106",
          "url": "https://attack.mitre.org/techniques/T1106/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8ed7b910-7886-4c64-9206-7afbaf4ba6e1",
      "name": "Obfuscated Files or Information: Dynamic API Resolution",
      "description": "ScoringMathTea manually implements Dynamic API Resolution through API Hashing.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1027.007",
          "url": "https://attack.mitre.org/techniques/T1027/007/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d8334eaf-fcc8-4105-92e3-0dba53936152",
      "name": "Masquerading: Browser Fingerprint",
      "description": "Spoofs a legitimate Microsoft Edge User-Agent string to make its C&C traffic blend in with normal network activity.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1036.012",
          "url": "https://attack.mitre.org/techniques/T1036/012/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2feb96b7-0c84-42c5-a68e-afba0e2d1619",
      "name": "Virtualization/Sandbox Evasion",
      "description": "Actively filters HTML tags (like <!DOCTYPE html>) from C&C responses, possibly to defeat captive portals and automated sandbox analysis.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1497",
          "url": "https://attack.mitre.org/techniques/T1497/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b5a33db7-bb31-4098-9fb0-3f9ae0cfb1e8",
      "name": "Debug Evasion",
      "description": "Calculates a CRC32 checksum of its own in-memory module after loading to detect if an analyst has applied patches or tampered with it.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1622",
          "url": "https://attack.mitre.org/techniques/T1622/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--299b89bb-655f-4fba-bef5-fd3f745e4eeb",
      "name": "Hide Artifacts: Suppress System Error Dialogs",
      "description": "Suppresses all system error dialogs to ensure the malware fails silently without alerting the user.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1564.004",
          "url": "https://attack.mitre.org/techniques/T1564/004/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--14985ecf-a3c8-454b-8d1d-f0f65fd0db3b",
      "name": "Application Layer Protocol: Web Protocols",
      "description": "Uses standard HTTP/S POST requests for all C&C communications and bypasses SSL/TLS certificate validation.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1071.001",
          "url": "https://attack.mitre.org/techniques/T1071/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--05cadf70-7c57-485c-9b27-0a39d89ca5d0",
      "name": "Encrypted Channel: Symmetric Cryptography",
      "description": "C&C payloads are protected in multiple layers: compressed, then encrypted with a symmetric algorithm (TEA/XTEA), and finally Base64 encoded.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1573.001",
          "url": "https://attack.mitre.org/techniques/T1573/001/"
        }
      ]
    },
