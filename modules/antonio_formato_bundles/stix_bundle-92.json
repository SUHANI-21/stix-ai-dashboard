  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--2a929ec0-0ea2-40ea-a0e0-26f52ec4215b",
      "name": "ForumTroll",
      "aliases": [
        "ForumTroll APT"
      ],
      "description": "ForumTroll is an advanced persistent threat (APT) group active since at least 2022, targeting organizations and individuals in Russia and Belarus. The group has conducted campaigns using spear phishing, malicious archives, and both custom and commercial malware implants. Notable tools include LeetAgent, Dante spyware, and the Tuoni framework. ForumTroll has exploited vulnerabilities such as CVE-2025-2783 in Google Chrome and used techniques like COM Hijacking for persistence.",
      "first_seen": "2022-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Data theft",
        "Compromise of targeted individuals and organizations"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/operation-forumtroll/115989/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--8a45d877-6dab-4c10-aa7f-30d125928a30",
      "name": "COM Hijacking",
      "description": "Persistence technique involving modification of registry keys (e.g., HKCR\\CLSID\\{1f486a52-3cb1-48fd-8f50-b8dc300d9f9d}\\InProcServer32) to execute malicious DLLs.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1546/015/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6e9dbafd-a418-42f8-b2dc-497533eaccc4",
      "name": "Spear Phishing via Email",
      "description": "Targeted phishing emails sent to scholars and professionals, impersonating a legitimate scientific library and containing malicious links leading to malware infection.",
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/operation-forumtroll/115989/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3008afd6-f76b-4536-9241-df9d6bf3f5ea",
      "name": "Malicious Shortcut File",
      "description": "Delivery of malware via a personalized shortcut file (.lnk) that executes a PowerShell script to download and run further payloads.",
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/operation-forumtroll/115989/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2ebd9c46-7fdb-4543-81d1-78232aeb6020",
      "name": "PowerShell-based Payload Delivery",
      "description": "Execution of PowerShell scripts to download and execute additional payloads from attacker-controlled servers.",
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/operation-forumtroll/115989/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4d518a36-e343-4994-a681-e2020ab30b60",
      "name": "Decoy Document Delivery",
      "description": "Downloading and opening a blurred PDF report as a decoy to distract victims and reduce suspicion during malware infection.",
      "external_references": [
        {
          "source_name": "Securelist",
          "url": "https://securelist.com/operation-forumtroll/115989/"
        }
      ]
    },
