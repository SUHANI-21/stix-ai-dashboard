    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--40440693-5b4b-e2f8-abac-911f0343e385",
      "created": "2026-01-14T06:12:41.387678Z",
      "modified": "2026-01-14T06:12:41.387678Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "Abuse of Residential Proxy Services for Network Probing",
      "description": "Kimwolf operators leverage residential proxy services to relay malicious commands and probe for vulnerable devices on local Wi-Fi networks. By exploiting the infrastructure of proxy networks, which route traffic through consumer devices and ISPs, Kimwolf masks its scanning activity as legitimate residential traffic. This technique allows the botnet to bypass traditional perimeter defenses and reach internal networks that would otherwise be inaccessible from the public internet. The abuse is facilitated by compromised devices and mobile apps that unwittingly enroll endpoints into proxy networks, turning them into scanning nodes. This approach enables large-scale, distributed reconnaissance and lateral movement attempts, targeting a wide range of organizations across multiple industries.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "discovery"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--fbdc8d76-ffcc-c262-ee74-184a234abdd0",
      "created": "2026-01-14T06:12:41.387795Z",
      "modified": "2026-01-14T06:12:41.387795Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "Mobile App Proxy Monetization Component as Infection Vector",
      "description": "Kimwolf takes advantage of mobile applications that include proxy-monetization SDKs, such as Byteconnect, to covertly add user devices to residential proxy networks. End users are often unaware that their devices have become proxy endpoints, which can then be used by threat actors to scan local networks for vulnerable devices. This technique leverages the widespread adoption of certain mobile apps to silently expand the botnet’s reach, as infected devices become unwitting participants in malicious network activities. The integration of proxy components into legitimate apps provides Kimwolf with a stealthy and scalable method to infiltrate enterprise and institutional environments.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--507c5097-afe2-ccc0-e3f3-9421f6f3646d",
      "created": "2026-01-14T06:12:41.387963Z",
      "modified": "2026-01-14T06:12:41.387963Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "DNS-based Probing for Vulnerable Devices",
      "description": "Kimwolf utilizes DNS queries to specific domains as a method for probing networks and identifying vulnerable devices. By sending DNS requests from compromised proxy endpoints, the botnet can scan local networks for devices susceptible to takeover. The DNS queries are often directed at domains associated with the botnet’s infrastructure, and the responses (including non-routable IPs) help operators map out potential targets. This technique allows for stealthy reconnaissance, as DNS traffic is commonly permitted and less likely to trigger security alerts compared to other scanning methods. The use of DNS telemetry also enables Kimwolf to track the spread and effectiveness of its probing activities across diverse environments.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "discovery"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1046/",
          "external_id": "T1046"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--c7223b73-cb72-cc44-cfc6-c6d7e9175b0f",
      "created": "2026-01-14T06:12:41.388030Z",
      "modified": "2026-01-14T06:12:41.388030Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "Command and Control via DNS TXT Records",
      "description": "The Aisuru botnet, referenced in the context of Kimwolf’s activity, employs DNS TXT records to deliver command-and-control (C2) locations to compromised devices. Infected endpoints query specific domains for TXT records, which contain the instructions or addresses needed to connect to the botnet’s C2 infrastructure. This technique leverages the ubiquity and flexibility of DNS, allowing for covert communication that can bypass traditional network monitoring. By embedding C2 information in DNS records, the botnet can dynamically update its infrastructure and maintain control over a distributed network of compromised devices.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "command-and-control"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1071/004/",
          "external_id": "T1071.004"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--29113d9e-299e-9ce4-57be-6469be16c59b",
      "created": "2026-01-14T06:12:41.388085Z",
      "modified": "2026-01-14T06:12:41.388085Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "Use of DNS-over-HTTPS (DOH) for C2 Evasion",
      "description": "Aisuru botnet, as mentioned in the report, utilizes Google DNS-over-HTTPS (DOH) to obscure its command-and-control communications. By sending DNS queries over encrypted HTTPS connections, the botnet can evade detection by security tools that monitor traditional DNS traffic. This technique complicates efforts to identify and block malicious domains, as DOH traffic blends in with legitimate encrypted web traffic and may bypass local DNS filtering policies. The use of DOH enables the botnet to maintain resilient and stealthy communications with its infrastructure, even in environments with strict DNS controls.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "command-and-control"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1071/001/",
          "external_id": "T1071.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--7c1eb438-d3d9-1102-1168-c38bd92284b2",
      "created": "2026-01-14T06:12:41.388140Z",
      "modified": "2026-01-14T06:12:41.388140Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "Lateral Movement via Proxy Endpoint Network Scanning",
      "description": "Kimwolf leverages compromised proxy endpoints within enterprise and institutional networks to perform lateral scans for vulnerable devices. Once a device is enrolled in a residential proxy network, it can be used by the botnet to probe its local subnet, searching for other devices (such as Android TVs) that may be susceptible to compromise. This lateral movement is facilitated by the trusted position of the proxy endpoint within the network, allowing Kimwolf to bypass external defenses and target internal assets. The success of this technique depends on the presence of vulnerable devices and the ability to resolve DNS queries within the local environment.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "lateral-movement"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1210/",
          "external_id": "T1210"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--1dc59747-55eb-5998-0013-45b566354da6",
      "created": "2026-01-14T06:12:41.388267Z",
      "modified": "2026-01-14T06:12:41.388267Z",
      "created_by_ref": "identity--4358b98f-3a2e-a388-d870-075d62c93606",
      "name": "Return of Non-Routable IPs to Obfuscate Scanning Activity",
      "description": "Kimwolf’s infrastructure sometimes responds to DNS queries with non-routable IP addresses (e.g., 127.0.0.1 or 0.0.0.0). This behavior serves to obfuscate the botnet’s scanning activity and may help evade detection by security monitoring systems. By returning benign or invalid IPs, Kimwolf can mask the true intent of its DNS-based probes, making it harder for defenders to distinguish between legitimate and malicious traffic. This technique also complicates attribution and analysis, as the scanning appears less suspicious and may be dismissed as misconfiguration or harmless activity.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ]
    },
    {
