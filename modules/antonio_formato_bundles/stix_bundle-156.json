    {
      "type": "identity",
      "id": "identity--43935be3-1870-4e9f-aadf-789a6dc3e3e2",
      "name": "Oligo Security",
      "description": "Oligo Security is a security research team that discovered and disclosed multiple critical vulnerabilities in Fluent Bit.",
      "identity_class": "organization",
      "contact_information": "info@oligosecurity.io",
      "external_references": [
        {
          "source_name": "website",
          "url": "https://oligosecurity.io/"
        }
      ]
    },
    {
      "type": "software",
      "id": "software--784c403d-cc7a-49db-b3de-d431e95ef39a",
      "name": "Fluent Bit",
      "cpe": "cpe:2.3:a:fluent:fluent-bit:*",
      "description": "Fluent Bit is an open-source log processor and forwarder, widely deployed in cloud, container, and Kubernetes environments."
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--11463ce3-4f8d-485f-9c79-e07b20434477",
      "name": "CVE-2025-12972",
      "description": "Unsanitized tag values are used to generate output filenames, allowing attackers to inject path-traversal sequences like '../' to write or overwrite arbitrary files on disk, enabling log tampering and, in many configurations, full remote code execution.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-12972"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--4d697e9c-63d4-48a9-abe1-93895cbbb17f",
      "name": "CVE-2025-12970",
      "description": "A stack buffer overflow in the Docker input enables attackers to trigger crashes or execute code by creating containers with excessively long names, giving them control over the Fluent Bit agent on the host.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-12970"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--a690939e-2a58-41cd-ac71-6cce67061df6",
      "name": "CVE-2025-12978",
      "description": "A flaw in Fluent Bit\u2019s tag-matching logic lets attackers spoof trusted tags by guessing only the first character of a Tag_Key, enabling them to reroute logs, bypass filters, and inject malicious or misleading records.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-12978"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--186804f9-f3fe-4097-9723-8e730d3993a3",
      "name": "CVE-2025-12977",
      "description": "Tags derived from user-controlled fields bypass sanitization, allowing attackers to inject newlines, traversal sequences, and control characters that corrupt downstream logs or enable broader output-based attacks.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-12977"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--8ee4fa36-4285-4e87-992f-acb2195caec9",
      "name": "CVE-2025-12969",
      "description": "Fluent Bit forwarders configured with Security.Users silently disable authentication, allowing remote attackers to send logs, inject false telemetry, or flood detection systems despite appearing secured.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-12969"
        }
      ]
    },
