  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--ca6259eb-a4b3-4e0d-8ed7-1eafaa26445a",
      "name": "MongoBleed: MongoDB Zlib Vulnerability",
      "description": "MongoBleed (CVE-2025-14847) is a critical vulnerability in MongoDB's network transport layer, specifically in the zlib decompression logic. It allows unauthenticated, network-level attackers to extract fragments of uninitialized server memory by sending specially crafted compressed payloads. The issue occurs before authentication, enabling remote exploitation. Even partial memory disclosure can reveal sensitive application data and internal server state.",
      "created": "2025-12-26T00:00:00.000Z",
      "modified": "2025-12-27T00:00:00.000Z",
      "external_references": [
        {
          "source_name": "NVD",
          "external_id": "CVE-2025-14847"
        },
        {
          "source_name": "MongoDB Advisory",
          "url": "https://jira.mongodb.org/browse/SERVER-115508"
        },
        {
          "source_name": "Aikido Intel",
          "url": "https://intel.aikido.dev/cve/AIKIDO-2025-10972"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d2a58321-a223-4d03-ae50-442619c188ae",
      "name": "Memory Disclosure via Malformed Compressed Payloads",
      "description": "Attackers send specially crafted compressed network messages to MongoDB instances with zlib compression enabled. The malformed payloads cause MongoDB to miscalculate decompressed data length, resulting in the server returning uninitialized heap memory to the client. This attack does not require authentication and can be performed remotely if the MongoDB service is network-exposed.",
      "created": "2025-12-26T00:00:00.000Z",
      "modified": "2025-12-26T00:00:00.000Z",
      "external_references": [
        {
          "source_name": "MongoBleed Blog",
          "url": "https://www.aikido.dev/blog/mongobleed-mongodb-zlib-vulnerability-cve-2025-14847"
        }
      ]
    },
    {
      "type": "software",
      "id": "software--79ba7c85-c154-4426-92a4-62d6c8167723",
      "name": "MongoDB",
      "description": "MongoDB is an open-source, document-oriented database program. Multiple versions are affected by the MongoBleed vulnerability (CVE-2025-14847) in the zlib compression logic of its network transport layer.",
      "created": "2025-12-26T00:00:00.000Z",
      "modified": "2025-12-26T00:00:00.000Z",
