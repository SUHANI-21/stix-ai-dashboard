  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4b150058-6165-431e-bfca-7f0119655b00",
      "name": "DLL Side-Loading",
      "description": "The campaign abuses Foxit PDF Reader by including a renamed FoxitPDFReader.exe and a malicious msimg32.dll in archive files. The executable loads the malicious DLL through DLL side-loading, enabling execution of ValleyRAT.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1574.002",
          "url": "https://attack.mitre.org/techniques/T1574/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--fc8adfba-30b2-4f60-be9b-22556e8bc1f6",
      "name": "Spearphishing Attachment",
      "description": "Attackers use email-based lures targeting job seekers and HR professionals, sending archive files disguised as HR documents (e.g., job applications, skills assessments) containing malicious executables and DLLs.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1566.001",
          "url": "https://attack.mitre.org/techniques/T1566/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6f4036d7-6fc0-4ece-83ba-bbe660c03c60",
      "name": "Obfuscated Files or Information",
      "description": "The campaign uses deeply nested directory paths, hidden folders, and files with misleading names (e.g., document.docx as a disguised 7zip executable) to conceal malicious components and evade detection.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1027",
          "url": "https://attack.mitre.org/techniques/T1027/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9592687a-28dd-4640-842e-69c069c6bb1b",
      "name": "User Execution: Malicious File",
      "description": "Victims are lured into executing disguised executables that appear to be legitimate documents, triggering the infection chain.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1204.002",
          "url": "https://attack.mitre.org/techniques/T1204/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6d886279-5e3c-42da-a1cc-8006f5938226",
      "name": "Command and Scripting Interpreter: Windows Command Shell",
      "description": "A batch file (document.bat) is used to automate extraction and execution of the malicious payload, invoking the Python interpreter to run further scripts.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1059.003",
          "url": "https://attack.mitre.org/techniques/T1059/003/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--37a44b20-45d7-41d7-83db-1b4728d4f4ca",
      "name": "Command and Scripting Interpreter: Python",
      "description": "The infection chain includes a disguised Python environment and scripts, enabling execution of malicious Python code even if Python is not pre-installed.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1059.006",
          "url": "https://attack.mitre.org/techniques/T1059/006/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--95f85353-c817-495a-a1fd-5474c6820d64",
      "name": "Persistence via Registry Run Keys",
      "description": "The renamed Python executable (zvchost.exe) creates an autorun registry entry to maintain persistence on the infected system.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1547.001",
          "url": "https://attack.mitre.org/techniques/T1547/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--550e9e28-873c-4bb2-8e1f-b7437f97ac02",
      "name": "Exfiltration from Web Browsers",
      "description": "ValleyRAT steals data from the user's internet browsers after successful infection.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "external_id": "T1539",
          "url": "https://attack.mitre.org/techniques/T1539/"
