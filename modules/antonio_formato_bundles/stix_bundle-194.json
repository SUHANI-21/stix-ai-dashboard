  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a6ae0eb3-50cb-44e3-a06e-39ce4a6407fb",
      "name": "Time Based Evasion",
      "description": "Lokibot begins by checking if it was executed with the -u parameter. If present, it pauses for 10 seconds before running its main code.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1497.003",
          "url": "https://attack.mitre.org/techniques/T1497/003/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e41f9e6c-8e81-4a7b-9ff5-3ba2cce80bbb",
      "name": "System Information Discovery",
      "description": "Lokibot collects system information including username, token membership, system details, OS version, and machine GUID (used for mutex generation).",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1082",
          "url": "https://attack.mitre.org/techniques/T1082/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--910ae8e7-117c-4e5a-8e28-a9c01fca0f6c",
      "name": "Credentials from Password Stores",
      "description": "Lokibot collects sensitive information from web browsers, FTP clients, vaults, and password managers. It loads sqlite3.dll, mozsqlite3.dll, and nss3.dll to access and decrypt stored browser data.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1555",
          "url": "https://attack.mitre.org/techniques/T1555/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--db870e51-cad2-4a0d-9029-473edacaf8bb",
      "name": "Ingress Tool Transfer",
      "description": "Lokibot can download additional malware, plugins, or malicious components using the UrlDownloadToFileW Windows API, saving files in the %temp% folder and executing them.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1105",
          "url": "https://attack.mitre.org/techniques/T1105/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--82d355e5-1343-4692-bf05-72d9f47aedae",
      "name": "Access Token Manipulation",
      "description": "Lokibot attempts to enable the SeDebugPrivilege token to gain higher-level permissions and interact with system processes such as lsass.exe.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1134",
          "url": "https://attack.mitre.org/techniques/T1134/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--27d6aa85-67a5-4da4-8cf3-768408f1f9c4",
      "name": "Process Injection",
      "description": "Lokibot injects shellcode into lsass.exe for credential dumping and injects itself into a newly created vbc.exe process for defense evasion.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1055",
          "url": "https://attack.mitre.org/techniques/T1055/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--5f658248-02da-41b0-a4b2-af7fffea1a71",
      "name": "Credentials in Registry",
      "description": "Lokibot accesses Outlook profile information stored in the Windows registry to extract email account credentials and configuration data.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1552.002",
          "url": "https://attack.mitre.org/techniques/T1552/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--5b27c1ae-eaef-4af4-aad6-2b856aa1a481",
      "name": "Scheduled Task/Job",
      "description": "Lokibot creates a scheduled task pointing to a dropped copy of itself to maintain persistence and privilege escalation.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1053",
          "url": "https://attack.mitre.org/techniques/T1053/"
        }
      ]
    },
