      "name": "Telegram-based Data Exfiltration",
      "description": "Attackers use Telegram bots or channels as command-and-control (C2) infrastructure to receive stolen credit card details, OTPs, and victim metadata.",
      "external_references": [
        {
          "source_name": "malwr-analysis.com",
          "url": "https://malwr-analysis.com/wp-content/uploads/2025/12/blgde10.jpg"
