    {
      "type": "attack-pattern",
      "id": "attack-pattern--c6a5c908-e04f-43b8-9796-d0c826c45259",
      "name": "Brand Impersonation via Display Name Spoofing",
      "description": "Threat actors impersonate WordPress.com in phishing emails by spoofing the display name and using urgency-based language to trick victims into clicking malicious links.",
      "aliases": [
        "WordPress Brand Impersonation"
      ],
      "external_references": [
        {
          "source_name": "malwr-analysis.com",
          "url": "https://malwr-analysis.com/wp-content/uploads/2025/12/blgde1.jpg"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--5a86455d-5b42-43ef-a55c-2a29fb671fc4",
      "name": "Credit Card Phishing",
      "description": "Victims are lured to a fake payment portal mimicking WordPress, where their credit card information is harvested via JavaScript and exfiltrated to attackers.",
      "external_references": [
        {
          "source_name": "malwr-analysis.com",
          "url": "https://malwr-analysis.com/wp-content/uploads/2025/12/blgde2.jpg"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--240c6014-ef25-4ce4-a51c-77a5f20c83e8",
      "name": "3-D Secure OTP Interception",
      "description": "Phishing site simulates a fake 3-D Secure modal to trick victims into entering SMS OTPs, which are then exfiltrated to attackers via Telegram.",
      "external_references": [
        {
          "source_name": "malwr-analysis.com",
          "url": "https://malwr-analysis.com/wp-content/uploads/2025/12/blgde3.jpg"
        }
      ]
    },
    {
