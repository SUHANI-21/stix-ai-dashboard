{
  "type": "bundle",
  "id": "bundle--f9f57891-9bf2-472c-bcaa-b67230a36448",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--738d2856-cb89-446a-8aff-ded8f5ed35e9",
      "name": "Typosquatting",
      "description": "Threat actors register lookalike domains (typosquats) of popular brands to lure users into visiting malicious parked domains. Examples include scotaibank[.]com (Scotiabank), gmai[.]com (Gmail), and domaincntrol[.]com (GoDaddy)."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--489ff9ab-0475-4cd8-b695-a3f80ea9cb90",
      "name": "Malvertising via Parked Domains",
      "description": "Malicious advertisers deliver scams, malware, and unwanted content to users redirected from parked domains through advertising networks and traffic distribution systems (TDSs)."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c6dc8b13-c08a-47ff-9c97-fd3ab18f1bfe",
      "name": "Device Fingerprinting for Traffic Distribution",
      "description": "Actors use device fingerprinting and IP geolocation to selectively redirect visitors from parked domains to malicious content, decoy pages, or further profiling systems."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--a6b45b60-04b7-4835-a51c-fc1c320d10e0",
      "name": "Double Fast Flux DNS",
      "description": "Actors rapidly rotate both authoritative name servers and IP addresses for parked domains to evade detection and blocking, as seen with ic3[.]org and related infrastructure."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--945033be-e303-4523-a1af-6fe77cb11b21",
      "name": "Business Email Compromise via Typosquat MX Records",
      "description": "Actors configure MX records for typosquat domains (e.g., gmai[.]com) to collect misdirected emails and conduct business email compromise campaigns."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--dfd5cc01-a9a9-420d-a913-ede42cce0bf5",
      "name": "Exploitation of DNS Configuration Typos",
      "description": "Actors register domains similar to major DNS providers (e.g., domaincntrol[.]com vs domaincontrol[.]com) to capture traffic from DNS misconfigurations and redirect users to malicious content."
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--33c1d9a2-2e61-47dc-b958-a2f9dd631c2a",
      "name": "Torresdns[.]com Name Server Infrastructure",
      "description": "Name servers under torresdns[.]com are used by a domain portfolio holder to serve nearly three thousand lookalike domains, including scotaibank[.]com and gmai[.]com, and perform visitor profiling and selective redirection.",
      "infrastructure_types": [
        "dns"
      ],
      "aliases": [
        "torresdns"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--6cdd9f20-99ac-436c-aa54-e7dd6837c229",
      "name": "Koaladns[.]com and Associated Fast Flux Name Servers",
      "description": "Name servers such as koaladns[.]com, weaponizedcow[.]com, numbatdns[.]com, and others are used by a domain portfolio actor to implement double fast flux DNS for parked domains including ic3[.]org.",
      "infrastructure_types": [
        "dns"
      ],
      "aliases": [
        "koaladns",
        "weaponizedcow",
        "numbatdns",
        "quokkadns",
