        "milesmx"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--8d469876-2fcb-4ebd-b800-127b22b8b2e4",
      "name": "Domaincntrol[.]com Name Server Infrastructure",
      "description": "Domaincntrol[.]com is a typosquat of GoDaddy's domaincontrol[.]com and is used to capture DNS traffic from misconfigured domains and selectively target Cloudflare DNS users for device fingerprinting and redirection to malicious content.",
      "infrastructure_types": [
        "dns"
      ],
      "aliases": [
        "domaincntrol"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--512deea1-eecd-48c9-8c50-d9fbb04bd697",
      "name": "Traffic Distribution Systems (TDS)",
      "description": "Third-party advertising platforms and TDSs such as Zeropark, Trillion Direct Search, ExplorAds, AdventureFeeds, click-v4.junclikrmedi[.]com, quotes[.]com, www[.]toroexoclk[.]com are used to funnel traffic from parked domains to malicious content.",
      "infrastructure_types": [
        "advertising-network"
      ]
    },
    {
