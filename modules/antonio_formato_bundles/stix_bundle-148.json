    {
      "type": "attack-pattern",
      "id": "attack-pattern--d5723cd0-ccdb-42ec-98ad-3a52d963e643",
      "name": "Cyber-Enabled Kinetic Targeting",
      "description": "A campaign model where cyber operations are specifically designed to enable and enhance kinetic military operations, such as using compromised digital infrastructure (e.g., CCTV, AIS platforms) to provide intelligence for physical attacks.",
      "x_mitre_detection": "Monitor for suspicious access to critical infrastructure systems, such as maritime platforms and surveillance cameras. Correlate cyber intrusions with subsequent physical incidents.",
      "aliases": [
        "Cyber-Enabled Kinetic Targeting"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--4d9a0b7d-2dfe-4727-8b44-c2bc887708ba",
      "name": "Anonymizing VPN Networks",
      "description": "VPN services used by threat actors to route traffic and obscure their true origins, making attribution more difficult.",
      "infrastructure_types": [
        "anonymizing network"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--668c9cc8-dd9b-412a-aa44-43ee9f46a547",
      "name": "Actor-Controlled Servers",
      "description": "Dedicated servers provisioned by threat actors to provide persistent access and command-and-control capabilities for ongoing operations.",
      "infrastructure_types": [
        "command and control"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--2a64b5e8-2043-43c8-9760-0e1f55f0e502",
      "name": "Compromised Enterprise Systems",
      "description": "Enterprise servers hosting critical infrastructure such as CCTV systems and maritime platforms, targeted and compromised to provide intelligence for kinetic operations.",
      "infrastructure_types": [
        "targeted enterprise systems"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--7cc74efe-5975-4164-91bb-9ae0cc31d170",
      "name": "Real-Time Data Streaming",
      "description": "Live feeds from compromised cameras and sensors used by threat actors to provide actionable intelligence for adjusting kinetic targeting in near real time.",
