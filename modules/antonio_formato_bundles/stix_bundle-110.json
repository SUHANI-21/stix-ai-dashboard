    {
      "type": "attack-pattern",
      "id": "attack-pattern--e94d7dfd-9f3b-4c71-8c79-07d0768ab07e",
      "name": "ViewState Deserialization Attack",
      "description": "Abuse of machine keys obtained from web.config to perform ASPX ViewState deserialization, allowing remote code execution on the server.",
      "external_references": [
        {
          "source_name": "Huntress Blog",
