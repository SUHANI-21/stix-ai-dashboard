    {
      "type": "vulnerability",
      "id": "vulnerability--cb685b90-87a7-413d-a53e-6716ccf5d67b",
      "name": "Gladinet CentreStack and Triofox hardcoded AES keys",
      "description": "Gladinet CentreStack and Triofox products contain hardcoded cryptographic keys in their AES implementation. Attackers can abuse this to access the web.config file, enabling deserialization and remote code execution. The vulnerability allows attackers to generate tickets that never expire and impersonate users, potentially leading to compromise of sensitive files and credentials.",
      "created": "2025-12-12T16:00:00Z",
      "modified": "2025-12-12T16:00:00Z",
      "external_references": [
        {
          "source_name": "CVE",
