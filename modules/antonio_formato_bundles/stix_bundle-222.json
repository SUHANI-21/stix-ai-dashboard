    {
      "type": "attack-pattern",
      "id": "attack-pattern--56768a97-3ba5-4f74-9c52-38c06f37855f",
      "name": "Volume Shadow Copy Deletion via WMI",
      "description": "VanHelsing ransomware deletes Windows Volume Shadow Copies using WMI queries and cmd.exe spawning wmic.exe with a delete command, sabotaging recovery efforts.",
      "external_references": [
        {
          "source_name": "picussecurity",
          "url": "https://www.picussecurity.com/resource/multi-platform-vanhelsing-ransomware-raas-analysis"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c1366019-3f00-43bf-a859-870969b6bc03",
      "name": "SMB Lateral Movement and Propagation",
      "description": "VanHelsing scans local networks for SMB servers, enumerates shares, and propagates by copying itself to writable shares and executing via embedded psexec.exe, excluding NETLOGON and sysvol shares.",
      "external_references": [
        {
          "source_name": "picussecurity",
          "url": "https://www.picussecurity.com/resource/multi-platform-vanhelsing-ransomware-raas-analysis"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--cb357d53-6c10-4d56-9fc9-94d34a3c027d",
      "name": "Silent Two-Stage Encryption and Renaming",
      "description": "VanHelsing ransomware can operate in a silent mode, performing encryption and file renaming in two separate stages to evade endpoint detection and response (EDR) behavioral analysis.",
      "external_references": [
        {
          "source_name": "picussecurity",
          "url": "https://www.picussecurity.com/resource/multi-platform-vanhelsing-ransomware-raas-analysis"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--fe638205-9b48-4c21-941f-46493cd1c4a0",
      "name": "Hybrid File Encryption Scheme",
      "description": "VanHelsing uses a hybrid encryption scheme with ChaCha20 for file content and Curve25519 for key exchange, storing encrypted keys and nonces in file headers.",
      "external_references": [
        {
          "source_name": "picussecurity",
          "url": "https://www.picussecurity.com/resource/multi-platform-vanhelsing-ransomware-raas-analysis"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1aa5ad10-6ad3-4d9d-b4d4-76def7d18b0b",
      "name": "Mutex Creation for Single Instance Execution",
      "description": "VanHelsing creates a named mutex (Global\\VanHelsing) to ensure only a single instance runs on a system, which can be bypassed via command-line argument.",
      "external_references": [
        {
          "source_name": "picussecurity",
          "url": "https://www.picussecurity.com/resource/multi-platform-vanhelsing-ransomware-raas-analysis"
        }
      ]
    },
    {
      "type": "mutex",
      "id": "mutex--7d4eb11a-0d24-4215-82af-d86582144e37",
      "name": "Global\\VanHelsing"
    },
    {
      "type": "file",
      "id": "file--a393883f-7c70-4ee8-b771-8ce82caacb98",
      "name": "1-locker.pdb",
      "path": "C:\\Users\\ADMINI~1\\AppData\\Local\\Temp\\2\\cd9563b4cbc415b3920633b93c0d351b\\1-locker\\Release\\1-locker.pdb"
    },
    {
      "type": "file",
      "id": "file--4348ff17-3eb7-477d-9ad7-e7337bf143cc",
      "name": "vanlocker.exe",
      "path": "$SHARE\\vanlocker.exe"
    },
    {
      "type": "file",
      "id": "file--5cb350b9-68d9-4a32-b0a2-60c937233891",
      "name": "psexec.exe",
      "path": "$TEMP/psexec.exe"
    },
    {
      "type": "file",
      "id": "file--47aa426b-29ef-457b-b48f-9912e8737a07",
      "name": "WMIC.exe",
      "path": "C:\\Windows\\System32\\wbem\\WMIC.exe"
    },
    {
      "type": "file",
      "id": "file--c90d4709-67a3-4974-ac4f-f1c02cded376",
      "name": "cmd.exe",
      "path": "cmd.exe"
    },
    {
      "type": "process",
      "id": "process--019abc96-6593-4e1e-8170-4e3c3089149b",
      "command_line": "cmd.exe /c C:\\Windows\\System32\\wbem\\WMIC.exe shadowcopy where \"ID='%s'\" delete"
    },
    {
      "type": "process",
      "id": "process--ebfca605-36ec-4bfe-87cc-bea3c6260b99",
      "command_line": "cmd.exe /c $TEMP/psexec.exe -accepteula \\\\$SHARE -c -f $SHARE\\vanlocker.exe -d --no-mounted --no-network < NUL"
    },
    {
