  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6bcb7ac2-d07e-4da7-a724-8ba97daa24ad",
      "name": "WhatsApp Worm Propagation",
      "description": "Malware propagates via WhatsApp by automating messaging, stealing contact lists, and distributing malicious files to contacts using personalized greetings and social engineering.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--41f41e06-719d-4757-a4f9-a8dbd0066382",
      "name": "Banking Overlay Injection",
      "description": "Malware injects fake overlays over legitimate banking windows to steal credentials, including password prompts and input fields positioned to mimic legitimate applications.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9d9bda64-a595-4c04-9e00-704da23cc1ab",
      "name": "Credential Harvesting via Process Hollowing",
      "description": "Malware uses a Delphi injector to perform process hollowing, running the final stealer payload in the context of svchost.exe to harvest credentials from banking, payment, and cryptocurrency applications.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e91985b5-e34b-44e6-8e1f-f4cbebcb244d",
      "name": "Dynamic C2 Retrieval via IMAP",
      "description": "Malware retrieves command-and-control server addresses dynamically by logging into email accounts using hardcoded IMAP credentials and extracting the C2 address from emails.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3d638add-7b30-4bfb-8c93-297fbe0fd0af",
      "name": "Geofencing and Locale Checks",
      "description": "Malware checks system locale and only executes if the victim's OS is set to Brazilian Portuguese, aborting otherwise. C2 infrastructure restricts access to Brazil and Argentina.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--760911af-7b10-415c-9eda-c6fd0951b252",
      "name": "Automated Security Product Enumeration",
      "description": "Malware enumerates running processes, registry uninstall keys, and WMI to detect installed antivirus, firewall, and anti-spyware products for anti-detection and evasion.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b1121a2b-7a31-48e9-af8c-03c4e42eecf5",
      "name": "System Telemetry and Host Profiling",
      "description": "Malware gathers system information including computer name, OS version/build, username, IP addresses, installed security software, RAM capacity, and logon domain, sending it to the C2.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6ebd83b9-c35c-4af4-bdeb-936f4554da20",
      "name": "Encrypted C2 Communications and Command Execution",
      "description": "Malware uses custom stream cipher and rotating XOR with hardcoded key and salt to encrypt C2 communications and commands, including info collection, overlays, keylogging, file transfer, and chat features.",
      "external_references": [
        {
          "source_name": "Trustwave SpiderLabs",
          "url": "https://www.trustwave.com/en-us/resources/blogs/spiderlabs-blog/spiderlabs-ids-new-banking-trojan-distributed-through-whatsapp"
        }
      ]
    },
