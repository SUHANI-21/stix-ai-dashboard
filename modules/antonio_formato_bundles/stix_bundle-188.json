      "name": "MuddyWater",
      "aliases": [
        "Static Kitten",
        "MERCURY"
      ],
      "description": "MuddyWater is a suspected Iran-backed APT group active since at least early 2017. It primarily targets the Middle East, but also attacks Europe and North America, focusing on government, military, telecommunications, and oil industries. The group is known for phishing attacks using highly obfuscated techniques and custom malware payloads, including the UDPGangster and Phoenix backdoors.",
      "first_seen": "2017-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Data theft",
        "Long-term access"
      ],
      "resource_level": "government",
      "primary_motivation": "espionage"
    },
