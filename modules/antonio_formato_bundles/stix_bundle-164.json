      "name": "Downloader execution via hijacked update",
      "description": "Hijacking nodes process redirected traffic and instruct legitimate software to download and execute malware such as LittleDaemon.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1608.001",
          "external_id": "T1608.001"
