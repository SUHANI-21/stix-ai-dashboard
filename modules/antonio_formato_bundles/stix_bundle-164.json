  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--df7bf2c4-d5b0-49c8-a597-95ccc7cf6e24",
      "name": "PlushDaemon",
      "aliases": [
        "PlushDaemon APT"
      ],
      "description": "PlushDaemon is a China-aligned threat actor active since at least 2018, engaging in espionage operations against individuals and entities in China, Taiwan, Hong Kong, Cambodia, South Korea, the United States, and New Zealand. The group uses custom backdoors such as SlowStepper and leverages adversary-in-the-middle attacks via network implants like EdgeStepper to hijack legitimate update mechanisms.",
      "first_seen": "2018-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Compromise software updates",
        "Supply-chain attacks"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "financial gain"
      ],
      "external_references": [
        {
          "source_name": "ESET Research",
          "url": "https://www.welivesecurity.com/en/eset-research/plushdaemon-compromises-network-devices-for-adversary-in-the-middle-attacks/"
        }
      ],
      "object_marking_refs": []
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--075ed3bb-86e0-4a9c-8cb3-f7ab8e28d45c",
      "name": "Adversary-in-the-middle via DNS hijacking",
      "description": "PlushDaemon compromises network devices (e.g., routers) and deploys EdgeStepper to redirect DNS queries to malicious nodes, hijacking traffic intended for legitimate software update infrastructure.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1659",
          "external_id": "T1659"
        }
      ],
      "object_marking_refs": []
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--cc3dc97d-e2a6-48de-9256-b857253e4b4c",
      "name": "Supply-chain compromise",
      "description": "PlushDaemon performed a supply-chain attack in 2023, compromising the update mechanism of a South Korean VPN service.",
      "external_references": [
        {
          "source_name": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1195",
          "external_id": "T1195"
