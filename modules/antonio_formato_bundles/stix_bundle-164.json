    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e56cebaf-b37f-4306-9596-bb96f703b163",
      "name": "Masquerading and encrypted payloads",
      "description": "DaemonicLogistics and SlowStepper's loader decrypt files that masquerade as ZIP and GIF files, and embed encrypted components.",
      "external_references": [
        {
