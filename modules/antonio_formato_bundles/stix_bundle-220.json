    {
      "type": "intrusion-set",
      "id": "intrusion-set--41d684c3-0775-40e8-b176-3c6822f2569c",
      "name": "Scattered LAPSUS$ Hunters",
      "aliases": [
        "SLH",
        "Scattered LAPSUS$ Hunters \u2013 The Com HQ SCATTERED SP1D3R HUNTERS"
      ],
      "description": "Scattered LAPSUS$ Hunters (SLH) is a federated cybercriminal brand that emerged in August 2025, appropriating reputational assets from Scattered Spider, ShinyHunters, and LAPSUS$. SLH operates primarily on Telegram, leveraging cycles of channel creation and removal to maintain public presence. The group blends technical signaling and social performance, focusing on data theft, extortion, and credential harvesting, often using AI-automated vishing and spearphishing. SLH has announced an Extortion-as-a-Service (EaaS) model and claims capabilities in exploit development targeting SaaS, CRM, and database systems. The group is characterized by fluid collaboration, brand-sharing, and situational alliances with other The Com-adjacent clusters.",
      "first_seen": "2025-08-08T00:00:00Z",
      "goals": [
        "Data theft",
        "Extortion",
        "Credential harvesting",
        "Social engineering",
        "Exploit development"
      ],
      "resource_level": "organization",
      "primary_motivation": "financial gain",
      "secondary_motivations": [
        "attention-driven hacktivism",
        "social validation"
      ],
