{
  "type": "bundle",
  "id": "bundle--49ff4f62-33f3-4275-8768-80cf7ff284c6",
  "spec_version": "2.1",
  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--9b78caad-eca2-4d00-93b3-e6a09b5d8c28",
      "name": "Kimsuky",
      "description": "Kimsuky is a North Korea-linked threat actor (DPRK nexus) known for targeting South Korean organizations and individuals with spear-phishing, credential theft, and malware campaigns. Kimsuky has consistently operated since at least the 2010s and is attributed with the development and deployment of KimJongRAT and related malware families. The group employs sophisticated social engineering, infrastructure leveraging cloud services, and tailored spear-phishing using victims\u2019 personal information.",
      "aliases": [
        "Thallium",
        "Black Banshee",
        "Velvet Chollima"
      ],
      "first_seen": "2013-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Credential Theft",
        "Data Exfiltration",
        "Targeting South Korean entities"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/new-babyshark-malware-targets-u-s-national-security-think-tanks/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e45a8164-dbe5-4ff3-ab7c-c907a1c05664",
      "name": "Phishing: Spearphishing Link",
      "description": "Kimsuky leverages spear-phishing emails impersonating public institutions and services to lure victims into clicking malicious links or downloading malware-laden archives. Attacks often include credential phishing pages and prompt for extra actions such as entering passwords or enabling macros.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1566.002",
          "url": "https://attack.mitre.org/techniques/T1566/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--574c3f18-e825-43c3-b538-2a0816f5c152",
      "name": "Command and Scripting Interpreter: PowerShell",
      "description": "KimJongRAT variants include PowerShell script-based malware, which decodes and executes payloads, collects system and browser data, and communicates with C2 servers.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1059.001",
          "url": "https://attack.mitre.org/techniques/T1059/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d2265de0-4189-439f-bf1b-f916e6ae0486",
      "name": "User Execution: Malicious File",
      "description": "Attackers distribute malicious shortcut (LNK) files and password-protected decoy documents to trick users into executing malware.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1204.002",
          "url": "https://attack.mitre.org/techniques/T1204/002/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--fec532aa-7cc9-4c36-b11b-6e11c7e59de7",
      "name": "Boot or Logon Autostart Execution: Registry Run Keys / Startup Folder",
      "description": "KimJongRAT establishes persistence by registering autorun entries in the Windows registry to execute malware on system startup.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1547.001",
          "url": "https://attack.mitre.org/techniques/T1547/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--347b056b-9901-48b9-8617-62d6200bb55d",
      "name": "Clipboard Data",
      "description": "KimJongRAT variants collect clipboard contents at frequent intervals and exfiltrate them to C2 infrastructure.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1115",
          "url": "https://attack.mitre.org/techniques/T1115/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--f1cbbc07-fd63-446d-894f-495052f5658c",
      "name": "Input Capture: Keylogging",
      "description": "KimJongRAT includes modules for keylogging, capturing keystrokes and active window titles, and exfiltrating logs to C2 servers.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1056.001",
          "url": "https://attack.mitre.org/techniques/T1056/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e3a66ad5-5220-4bed-87d4-b019a51556bb",
      "name": "Exfiltration Over C2 Channel",
      "description": "Collected data and files are exfiltrated over HTTP POST requests to attacker-controlled C2 domains, with additional encryption and chunking mechanisms.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1041",
          "url": "https://attack.mitre.org/techniques/T1041/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--909c87c9-5ec7-4701-a5a3-a8148b5d0a18",
      "name": "Obfuscated Files or Information: Dynamic API Resolution",
      "description": "KimJongRAT uses API name obfuscation and dynamic resolution to evade detection and analysis.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1027.007",
          "url": "https://attack.mitre.org/techniques/T1027/007/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e5525b4d-6212-43a8-9588-ad6032b13c73",
      "name": "Virtualization/Sandbox Evasion: System Checks",
      "description": "KimJongRAT performs anti-VM checks and terminates execution if a virtualized environment is detected.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1497.001",
          "url": "https://attack.mitre.org/techniques/T1497/001/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--4e0f31fe-3498-4812-9c81-79be34223622",
      "name": "Web Service: Use of Cloud and Public Infrastructure",
      "description": "Kimsuky leverages GitHub Releases and Google Drive for malware distribution and payload delivery.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1102",
          "url": "https://attack.mitre.org/techniques/T1102/"
        }
      ]
    },
    {
      "type": "campaign",
      "id": "campaign--24f63b20-6299-41f4-939b-0a28fb1a7b7d",
      "name": "KimJongRAT 2024-2025 Expansion Campaign",
      "description": "A campaign attributed to Kimsuky, active from 2024 through 2025, involving the distribution of KimJongRAT variants via spear-phishing, credential phishing, and cloud infrastructure. The campaign targets South Korean institutions and individuals, with evidence of merged PE and PowerShell workflows, credential theft, and broad targeting using personal information.",
      "first_seen": "2024-01-01T00:00:00Z",
      "last_seen": "2025-11-21T00:00:00Z",
      "objective": "Espionage, credential theft, and data exfiltration against South Korean entities."
    },
