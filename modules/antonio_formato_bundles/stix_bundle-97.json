  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6f10cbfa-c0be-45e3-befd-59f6c2bab503",
      "name": "DNS over TLS (DoT) for C2 communication",
      "description": "Kimwolf uses DNS over TLS to encapsulate DNS requests, evading traditional security detection and making C2 infrastructure more resilient to blocking.",
      "external_references": [
        {
          "source_name": "Cloudflare DNS over TLS",
          "url": "https://developers.cloudflare.com/radar/glossary/#domain-rankings"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--dd71a64c-caa8-457c-803d-1a7d096eff9a",
      "name": "Blockchain-based C2 infrastructure (ENS/EtherHiding)",
      "description": "Kimwolf leverages Ethereum Name Service (ENS) and EtherHiding technology to store and update C2 information on the blockchain, making takedown and blocking extremely difficult.",
      "external_references": [
        {
          "source_name": "ENS",
          "url": "https://ens.domains/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1adab40f-65c0-44f7-9e7c-1b10ae2a93f5",
      "name": "Elliptic Curve Digital Signature for C2 Authentication",
      "description": "Kimwolf implements a digital signature protection mechanism based on elliptic curves, requiring bots to verify C2 instructions before accepting commands, protecting C2 from takeover."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--366da583-4b76-47e6-ab86-f6033f881acf",
      "name": "Stack XOR String Encryption",
      "description": "Kimwolf encrypts sensitive strings such as C2 domains and DNS resolvers using a simple Stack XOR operation, complicating static analysis and detection."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9d1cad0e-c401-466f-8520-cfa420afcd50",
      "name": "Single Instance Control via Unix Domain Socket",
      "description": "Kimwolf ensures only one instance runs per device by creating a Unix domain socket named '@niggaboxv[number]', and disguises its process name as 'netd_services' or 'tv_helper'."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6e7042c3-ca3e-4886-8341-514a09532d0a",
      "name": "TLS-encrypted C2 Communication",
      "description": "Kimwolf uses TLS encryption for all network communication, including websocket handshakes and custom protocol headers."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d9f2d592-e70d-4584-a7b6-19ba88dc31cd",
      "name": "Mirai-style DDoS Attacks",
      "description": "Kimwolf supports 13 DDoS attack methods, using a structure derived from Mirai for attack payloads and command execution."
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--44444b34-34b7-4f0f-88d5-f4b6d75ed340",
      "name": "Proxy Monetization via ByteConnect SDK",
      "description": "Infected devices are monetized using ByteConnect SDK, which forms a proxy network and generates revenue for attackers."
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--1ef7a21d-761f-4ed9-b9ce-2d5ad22b7f1f",
      "name": "Kimwolf/Aisuru Group",
      "description": "A threat actor group operating the Kimwolf and Aisuru botnets, responsible for large-scale infections, DDoS attacks, and proxy monetization. The group demonstrates advanced infrastructure resilience and rapid evolutionary capability.",
      "aliases": [
        "Aisuru",
        "Kimwolf"
      ],
      "external_references": [
        {
          "source_name": "XLab Blog",
          "url": "https://blog.xlab.qianxin.com/super-large-scale-botnet-aisuru/"
        }
      ]
    },
