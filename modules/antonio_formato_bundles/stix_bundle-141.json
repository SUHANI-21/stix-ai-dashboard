  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--8074ace3-c783-484d-a1fd-86dd16030e93",
      "name": "Tomiris",
      "description": "Tomiris is an APT group active since at least 2021, known for targeting government, diplomatic, and intergovernmental organizations in Russia and Central Asia. The group leverages multi-language malware, spear-phishing, and public services (Telegram, Discord) for C2. Tomiris is associated with tools such as JLORAT, reverse shells, file grabbers, and post-exploitation frameworks like AdaptixC2 and Havoc.",
      "aliases": [
        "Tomiris APT"
      ],
      "goals": [
        "Espionage",
        "Remote access",
        "Persistence",
        "Data exfiltration"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage"
    },
    {
      "type": "malware",
      "id": "malware--a28a7c49-7de5-4ce9-b22c-c6d8f0f7a1fc",
      "name": "Tomiris C/C++ ReverseShell",
      "description": "A reverse shell written in C/C++ used by Tomiris. Provides remote console access, collects system info, and downloads next-stage payloads such as AdaptixC2. Does not persist by itself; persistence is established by registry modification after further payload delivery.",
      "malware_types": [
        "remote-access-trojan",
        "backdoor"
      ],
      "is_family": false,
      "operating_system_refs": [
        "windows"
      ],
      "labels": [
        "reverse shell",
        "C/C++",
        "Tomiris"
      ],
