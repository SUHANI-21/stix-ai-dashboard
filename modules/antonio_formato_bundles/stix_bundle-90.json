  "objects": [
    {
      "type": "malware",
      "id": "malware--abcff602-9390-4141-96a5-4b9234f0960e",
      "name": "AuraStealer",
      "malware_types": [
        "infostealer",
        "malware-as-a-service"
      ],
      "description": "AuraStealer is an emerging infostealer-as-a-service (MaaS) malware, first observed in July 2025, actively promoted on underground forums. Developed in C++ (~500-700kB), it targets Windows 7-11 and is marketed as a highly efficient, low-footprint stealer capable of stealing data from over 110 browsers, 70 applications (including wallets and 2FA tools), and 250+ browser extensions. It employs advanced obfuscation and anti-analysis techniques, including indirect control flow obfuscation, exception-driven API hashing, anti-debug, anti-tamper, anti-VM, anti-sandbox, and string encryption. Distribution occurs via Scam-Yourself campaigns (notably TikTok videos), cracked games/software, and malicious IDE/browser extensions. It uses AES-CBC encryption for configuration and network traffic, and is capable of executing additional payloads.",
      "is_family": true,
      "aliases": [
        "Aura Stealer"
      ],
      "operating_system_refs": [
        "windows"
      ],
      "implementation_languages": [
        "C++"
      ],
      "capabilities": [
        "Steals credentials, session tokens, recovery data, clipboard contents, screenshots, password manager databases, VPN configs, system/process info",
        "Targets Chromium/Gecko browsers, cryptocurrency wallets, 2FA tokens, remote access/FTP configs",
        "Supports custom configuration modules for file theft",
        "Executes additional payloads",
        "Uses dynamically generated mutexes",
        "Bypasses Application-Bound Encryption (ABE) in Chromium browsers",
        "Uses Heaven's Gate technique for NTDLL calls"
      ],
      "labels": [
        "infostealer",
        "malware-as-a-service",
        "obfuscated",
        "Windows"
      ],
      "external_references": [
        {
          "source_name": "Gen Digital Blog",
