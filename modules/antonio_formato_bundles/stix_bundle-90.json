    {
      "type": "attack-pattern",
      "id": "attack-pattern--1f94b3fc-2941-4fe9-a76a-d376cc305bcc",
      "name": "Indirect Control Flow Obfuscation",
      "description": "AuraStealer uses indirect control flow obfuscation by replacing direct jumps and calls with indirect ones, where target addresses are computed at runtime using arithmetic and conditional instructions. This disrupts static analysis and control-flow graph reconstruction.",
      "x_mitre_detection": "Requires advanced reverse engineering and symbolic execution to reconstruct original control flow.",
      "labels": [
        "obfuscation",
        "defense-evasion"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e5ec372f-6b13-4cbc-8d44-ce019cea6af8",
      "name": "Exception-Driven API Hashing",
      "description": "AuraStealer obfuscates its WinAPI usage by resolving functions via hash-based lookup tables and triggering deliberate exceptions intercepted by a custom handler, which then dispatches the correct API address.",
      "x_mitre_detection": "Analysis of exception handler routines and hash tables required.",
      "labels": [
        "obfuscation",
        "defense-evasion"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--31401f2d-8309-4b44-831d-e106ecc070c1",
      "name": "String Encryption (XOR Stack-Based)",
      "description": "Most strings in AuraStealer are encrypted using stack-based XOR routines, requiring emulation or symbolic execution for decryption.",
      "x_mitre_detection": "Emulation or decryption scripts needed to recover strings.",
      "labels": [
        "obfuscation",
        "defense-evasion"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ef265a23-a3c2-4d3c-b412-45a7caf27d35",
      "name": "Anti-Tampering Check",
      "description": "AuraStealer verifies integrity using MapFileAndCheckSumW, comparing file checksum against PE header value. If tampering is detected, execution is halted.",
      "x_mitre_detection": "Monitor for checksum validation API usage and tampering.",
      "labels": [
        "defense-evasion",
        "anti-analysis"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--84a7480c-06b5-45f3-9d5c-76110efc6f5c",
      "name": "Dialog Box Human Verification",
      "description": "When unprotected, AuraStealer displays a dialog box requiring user input of a randomly generated code, impeding automated sandbox analysis.",
      "x_mitre_detection": "Detection via automated sandbox instrumentation.",
      "labels": [
        "defense-evasion",
        "anti-sandbox"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7a683f3a-ffb0-447b-bbae-2768d496f5af",
      "name": "Geolocation Blacklist Check",
      "description": "AuraStealer retrieves system/user language and country codes via WinAPI and terminates if a blacklisted country is detected (CIS, Baltic states).",
      "x_mitre_detection": "Monitor locale-based execution logic.",
      "labels": [
        "defense-evasion",
        "geo-fencing"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1c9023d8-113e-417f-bc92-aed8a51198e6",
      "name": "Anti-Sandbox Checks",
      "description": "Checks for hooked Sleep function, emulator artifacts (JohnDoe, HAL9TH), and blacklisted DLLs to evade sandbox and emulation environments.",
      "x_mitre_detection": "Monitor for time-based checks and DLL enumeration.",
      "labels": [
        "defense-evasion",
        "anti-sandbox"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b414534b-06c2-4bf0-b688-3e238b01be4c",
      "name": "Anti-VM Checks",
      "description": "AuraStealer checks for hypervisor presence (cpuid), desktop window size, physical memory, processor count, and process count to evade virtualized environments.",
      "x_mitre_detection": "Monitor for environment fingerprinting and VM detection logic.",
      "labels": [
        "defense-evasion",
        "anti-virtualization"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--00fae58c-f287-49fa-8710-01cb833cfd88",
      "name": "Anti-Debug Checks",
      "description": "Inspects debug flags in PEB, KUSER_SHARED_DATA, creates debug objects, and checks for blacklisted processes. Also inspects opcodes at function return addresses for breakpoints.",
      "x_mitre_detection": "Monitor for anti-debugging API usage and process enumeration.",
      "labels": [
        "defense-evasion",
        "anti-debugging"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--96d274db-1f50-4995-91d9-f97c3d506b80",
      "name": "Application-Bound Encryption Bypass",
      "description": "AuraStealer bypasses Chromium Application-Bound Encryption by injecting shellcode into suspended browser processes and invoking IElevator::Decrypt, allowing theft of protected data.",
      "x_mitre_detection": "Monitor for process injection and API abuse in browsers.",
      "labels": [
        "credential-access",
        "defense-evasion"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9dff49d6-b8cb-44c6-916f-c4537f428271",
      "name": "Mutex Creation for Execution Control",
      "description": "Creates dynamically generated mutexes based on build ID and time to prevent multiple instances and limit execution duration.",
      "x_mitre_detection": "Monitor for mutex creation with changing names.",
      "labels": [
        "defense-evasion"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--36443797-4276-4cc1-9af3-7f38b18b1eff",
      "name": "Encrypted Configuration and Network Traffic",
      "description": "Configuration and exfiltrated data are encrypted using AES-CBC and Base64 encoding, with keys generated at runtime.",
      "x_mitre_detection": "Monitor for AES-CBC encrypted traffic and config blocks.",
      "labels": [
        "defense-evasion",
        "exfiltration"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d958ae63-d84f-448f-b12d-1b809289e059",
      "name": "Data Collection and Exfiltration",
      "description": "Steals credentials, session tokens, recovery data, clipboard, screenshots, password manager databases, VPN configs, system/process info, and custom files. Exfiltrates data via encrypted network traffic to C2 servers.",
      "x_mitre_detection": "Monitor for suspicious file access and encrypted outbound traffic.",
      "labels": [
        "collection",
        "exfiltration"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--719d8605-de76-4697-8f33-28b29f84ab4c",
      "name": "Execution of Additional Payloads",
      "description": "AuraStealer is capable of executing additional payloads via ShellExecuteExW after initial data theft.",
      "x_mitre_detection": "Monitor for process creation and payload execution.",
      "labels": [
        "execution"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--2729d5ed-1e2f-4257-acff-9532e8104893",
      "name": "Scam-Yourself Campaign Delivery",
      "description": "AuraStealer is distributed via TikTok videos disguised as product activation guides, instructing victims to run malicious PowerShell commands.",
      "x_mitre_detection": "Monitor for suspicious PowerShell command execution from clipboard or user input.",
      "labels": [
        "initial-access",
        "social-engineering"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9059e3c8-acea-44a2-ba8c-8927523ceb8a",
      "name": "Malicious Software/Extension Delivery",
      "description": "AuraStealer is also delivered via cracked games/software and malicious browser/IDE extensions, sometimes alongside other malware such as GlassWorm.",
      "x_mitre_detection": "Monitor for execution of packed binaries and suspicious extensions.",
      "labels": [
        "initial-access"
      ]
    },
    {
      "type": "infrastructure",
      "id": "infrastructure--b0a432b2-73b8-48bc-ab1a-3dea951d55e6",
      "name": "AuraStealer C2 Infrastructure",
      "description": "AuraStealer uses a set of dedicated command and control servers for configuration retrieval and data exfiltration. The web panel is built on the Tabler template and supports Russian and English.",
      "infrastructure_types": [
        "command-and-control"
      ],
      "aliases": [
        "AuraStealer Panel"
      ],
