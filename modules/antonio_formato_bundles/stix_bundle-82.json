  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--fd9a569f-fb02-419a-924c-0915b6212152",
      "name": "Improper IOMMU Initialization in UEFI Firmware Enables Early-Boot DMA Attacks",
      "description": "A vulnerability in certain UEFI-supported motherboard models leaves systems vulnerable to early-boot DMA attacks. Although the firmware indicates that DMA protection is active, it fails to correctly initialize the IOMMU. This allows a malicious PCIe device with physical access to read or modify system memory before the operating system's defenses load, exposing sensitive data and enabling pre-boot code injection.",
      "created": "2025-12-17T00:00:00Z",
      "modified": "2025-12-19T00:00:00Z",
      "external_references": [
        {
