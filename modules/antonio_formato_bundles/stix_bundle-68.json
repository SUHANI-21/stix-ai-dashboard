      "name": "WEBJACK",
      "aliases": [
        "BadIIS"
      ],
      "description": "An evolving IIS hijacking campaign abusing SEO for fraud and monetization. Operators compromise IIS servers to deploy malicious modules, conduct SEO poisoning, redirect users to gambling sites, and monetize traffic. The campaign uses Chinese red-team tools and targets high-profile sites, predominantly in Vietnam, Latin America, and Asia.",
      "goals": [
        "SEO poisoning",
        "fraud",
        "monetization",
        "traffic redirection",
        "concealment"
      ],
      "resource_level": "organization",
      "primary_motivation": "financial",
      "secondary_motivations": [
        "fraud"
      ],
      "external_references": [
        {
          "source_name": "WithSecure STINGR",
          "url": "https://www.enable-javascript.com/"
        }
      ]
    },
