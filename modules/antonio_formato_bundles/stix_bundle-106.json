    {
      "type": "attack-pattern",
      "id": "attack-pattern--281cba52-ab38-4ffc-bdf2-511a232418d8",
      "name": "Credential Harvesting via WebView Injection",
      "description": "Frogblight injects JavaScript into WebView instances of official government and banking websites to capture user credentials and transmit them to its C2 server.",
      "external_references": [
        {
          "source_name": "Kaspersky Securelist",
          "url": "https://securelist.com/frogblight-banker/118440/"
