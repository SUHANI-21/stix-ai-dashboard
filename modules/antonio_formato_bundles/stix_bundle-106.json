  "objects": [
    {
      "type": "malware",
      "id": "malware--0cdf6752-ff1a-4963-a2f3-ebc50653e9d6",
      "name": "Frogblight",
      "description": "Frogblight is an Android banking Trojan first observed in August 2025 targeting individuals in Turkey. It is distributed via phishing SMS messages (smishing) and fake apps, such as those masquerading as court case file viewers or the Chrome browser. Frogblight steals banking credentials by using official government websites as intermediaries and has extensive spyware capabilities, including collecting SMS messages, installed apps list, device filesystem information, sending arbitrary SMS, and remote device control. It uses both REST API and WebSocket protocols for C2 communication and is under active development, with indications it may be distributed under a Malware-as-a-Service (MaaS) model.",
      "malware_types": [
        "banking",
        "spyware",
        "trojan"
      ],
      "is_family": true,
      "aliases": [
        "HEUR:Trojan-Banker.AndroidOS.Frogblight.*",
        "HEUR:Trojan-Banker.AndroidOS.Agent.eq",
        "HEUR:Trojan-Banker.AndroidOS.Agent.ep",
        "HEUR:Trojan-Spy.AndroidOS.SmsThief.de"
      ],
      "operating_system_refs": [
        "android"
      ],
      "first_seen": "2025-08",
      "last_seen": "2025-09",
      "capabilities": [
        "credential-access",
        "spyware",
        "send-sms",
        "collect-sms",
        "collect-call-logs",
