      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--ea5560e7-534f-4b24-8dbe-70c8c2c86662",
      "name": "Remote Device Control via C2",
      "description": "Frogblight enables remote device control, including sending SMS, collecting data, and executing commands, using REST API and WebSocket protocols for C2 communication.",
