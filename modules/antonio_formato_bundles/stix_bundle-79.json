      "type": "vulnerability",
      "id": "vulnerability--77283dae-5327-4973-b0f3-af1c2b7248a3",
      "name": "FortiCloud SSO Login Authentication Bypass",
      "description": "Critical vulnerabilities affecting Fortinet products with FortiCloud SSO login feature enabled. CVE-2025-59718 and CVE-2025-59719 allow unauthenticated attackers to bypass FortiCloud SSO login authentication via a crafted SAML response message due to improper verification of cryptographic signature (CWE-347).",
      "created": "2025-12-15T00:00:00Z",
      "modified": "2025-12-15T00:00:00Z",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-59718"
        },
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-59719"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--7e058369-342b-41a8-a229-969f509a7196",
      "name": "Authentication Bypass via Crafted SAML Response",
      "description": "An attacker exploits improper verification of cryptographic signature in FortiCloud SSO login authentication by sending a crafted SAML response message, allowing bypass of authentication.",
      "created": "2025-12-15T00:00:00Z",
      "modified": "2025-12-15T00:00:00Z",
      "external_references": [
        {
          "source_name": "CWE",
          "external_id": "CWE-347"
        }
      ]
