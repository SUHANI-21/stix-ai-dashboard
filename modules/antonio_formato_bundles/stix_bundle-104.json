  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--56ccf444-1f0f-428b-808d-32f7c4a0a09a",
      "name": "CVE-2025-66516",
      "description": "A critical XML External Entity (XXE) injection vulnerability in Apache Tika, rated CVSS 10.0. The vulnerability affects tika-core (versions 1.13-3.2.1), tika-pdf-module (versions 2.0.0-3.2.1), and tika-parsers (versions 1.13-1.28.5). Exploitation is unauthenticated and remote, requiring only the processing of a specially crafted PDF file. Attackers can read arbitrary files, conduct SSRF attacks, and cause denial of service via entity expansion.",
      "created": "2025-12-05T00:00:00Z",
      "modified": "2025-12-05T00:00:00Z",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-66516"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--31b669ce-8814-4052-8b78-e2256a3eb093",
      "name": "CVE-2025-54988",
      "description": "An earlier XXE vulnerability in Apache Tika, rated CVSS 8.4, originally identified in the PDF parser module. The full scope was later clarified to include tika-core, meaning patching only the PDF module does not fully mitigate the issue.",
      "created": "2025-08-01T00:00:00Z",
      "modified": "2025-12-05T00:00:00Z",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-54988"
        }
      ]
    },
    {
      "type": "software",
      "id": "software--3deaa736-1613-487b-90c5-a94f89a6ff5b",
      "name": "Apache Tika",
      "description": "Apache Tika is a widely used document processing framework for content extraction, metadata analysis, and indexing. It is affected by XXE vulnerabilities in multiple core components.",
      "created": "2025-12-05T00:00:00Z",
      "modified": "2025-12-05T00:00:00Z",
      "cpe": "cpe:2.3:a:apache:tika:*:*:*:*:*:*:*:*",
      "external_references": [
        {
          "source_name": "vendor",
          "url": "https://tika.apache.org/"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--90fe6e46-34f3-4ff7-9809-b875b5994676",
      "name": "XML External Entity (XXE) Injection via PDF XFA",
      "description": "Attackers craft malicious PDF files with XFA content containing external XML entity references. When processed by vulnerable Apache Tika instances, these entities are resolved, enabling file read, SSRF, and denial of service.",
      "created": "2025-12-05T00:00:00Z",
      "modified": "2025-12-05T00:00:00Z",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1224/"
        }
      ]
    },
    {
