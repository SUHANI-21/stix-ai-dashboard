    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--72e780e3-d65e-dec7-488f-fbeab940e5d0",
      "created": "2026-01-17T16:23:15.290595Z",
      "modified": "2026-01-17T16:23:15.290595Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Typosquatting Malicious npm Packages",
      "description": "NeoShadow attackers published malicious npm packages with names closely resembling popular legitimate libraries (e.g., 'viem-js', 'cyrpto', 'tailwin', 'supabase-js'). This technique exploits developer mistakes or autocomplete to trick users into installing the malicious package. The initial JavaScript payload is embedded in these packages, triggering the infection chain upon installation or use. The packages are distributed via the official npm registry, leveraging trust in open-source ecosystems to achieve initial access.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1195/002/",
          "external_id": "T1195.002"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--76a1ccfa-0ced-79ea-a2fb-719aa5191bcb",
      "created": "2026-01-17T16:23:15.290716Z",
      "modified": "2026-01-17T16:23:15.290716Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Platform and Anti-Analysis Validation",
      "description": "Before proceeding, the malware checks if it is executing on a Windows platform. It then performs an anti-analysis heuristic by counting Windows System Event Log entries using PowerShell. If the event count is unusually low (indicative of a sandbox or analysis environment), the malware exits early. This ensures that the payload only runs in real user environments and evades automated analysis or sandboxes commonly used by security researchers.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1497/001/",
          "external_id": "T1497.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--d21bf28f-0084-d54e-ce4b-5ae73288037e",
      "created": "2026-01-17T16:23:15.290807Z",
      "modified": "2026-01-17T16:23:15.290807Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Dynamic C2 Configuration via Blockchain Smart Contract",
      "description": "Instead of hardcoding command-and-control (C2) infrastructure, the malware queries an Ethereum smart contract using Etherscan’s eth_call API. The smart contract stores a dynamically changeable string, which the malware decodes and treats as the C2 base URL. If the blockchain lookup fails, it falls back to a hardcoded domain. This technique allows the attacker to update C2 endpoints on the fly without modifying the malware, and leverages the resilience and anonymity of public blockchains.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "command-and-control"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--29fd0255-a3bd-96ba-5d8d-6e485f1232e2",
      "created": "2026-01-17T16:23:15.290859Z",
      "modified": "2026-01-17T16:23:15.290859Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Covert Payload Delivery via JavaScript Block Comment",
      "description": "The malware retrieves a remote JavaScript file that masquerades as an analytics script. Instead of executing code, the file contains a Base64-encoded payload hidden inside a block comment. The loader extracts and decodes this blob, which serves as the actual malicious payload. This method avoids detection by static code scanners and signature-based defenses, as the payload is not present in executable code but concealed within a comment.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1027/",
          "external_id": "T1027"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--ff48d5ec-6eb8-5bf6-41ad-e58996517321",
      "created": "2026-01-17T16:23:15.290916Z",
      "modified": "2026-01-17T16:23:15.290916Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Living-off-the-Land Execution via MSBuild Inline C#",
      "description": "To execute the next-stage payload, the malware writes a temporary MSBuild project file (.proj) containing inline C# code via CodeTaskFactory. It then launches MSBuild.exe, a trusted Windows binary, to execute the embedded code. This approach avoids dropping or compiling a standalone executable, leveraging legitimate system tools to run malicious code and evade application whitelisting and some endpoint protections.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "execution"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1127/001/",
          "external_id": "T1127.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--29fd0255-a3bd-96ba-5d8d-6e485f1232e2",
      "created": "2026-01-17T16:23:15.290966Z",
      "modified": "2026-01-17T16:23:15.290966Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Payload Decryption Using RC4 with XOR-masked Key",
      "description": "After extracting the Base64-encoded payload, the malware derives an RC4 decryption key by XOR-masking the first 16 bytes of the blob. The remainder of the payload is decrypted in memory, ensuring that the actual shellcode or executable is never written to disk in plaintext. This technique complicates detection and analysis, as the payload is both encoded and encrypted, and the key is dynamically derived.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1027/",
          "external_id": "T1027"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--10d5b7dc-52e7-628a-e7d3-459a81cf3691",
      "created": "2026-01-17T16:23:15.291013Z",
      "modified": "2026-01-17T16:23:15.291013Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Process Injection via APC (Asynchronous Procedure Call)",
      "description": "The decrypted shellcode is injected into a newly spawned instance of RuntimeBroker.exe, which is created in a suspended state. The malware allocates memory in the remote process, writes the shellcode, and then uses the QueueUserAPC technique to schedule execution of the shellcode when the thread resumes. This method allows code execution in the context of a legitimate Windows process, helping evade behavioral detection and increasing stealth.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "execution"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1055/014/",
          "external_id": "T1055.014"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--88dcfda0-30cb-6f83-a147-d80650806f81",
      "created": "2026-01-17T16:23:15.291060Z",
      "modified": "2026-01-17T16:23:15.291060Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "Persistence via Dropped Configuration File",
      "description": "After successful execution, the malware optionally downloads a secondary configuration file and persists it under the path %APPDATA%\\Microsoft\\CLR\\config.proj. This artifact may be used for future configuration changes, updates, or additional payload delivery, enabling the attacker to maintain control and adapt the malware’s behavior over time.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "persistence"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1053/005/",
          "external_id": "T1053.005"
        }
      ]
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--21896c67-0c44-515c-3fcb-60c49e8ffdc8",
      "created": "2026-01-17T16:23:19.014028Z",
      "modified": "2026-01-17T16:23:19.014028Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "NeoShadow",
      "description": "NeoShadow is the primary malware family deployed via typo-squatting npm packages in this supply-chain attack. It acts as a multi-stage Windows-only loader, leveraging JavaScript, blockchain-based dynamic configuration, and MSBuild for covert payload delivery and execution. The malware performs anti-analysis checks, downloads and decrypts payloads, injects shellcode into system processes, and establishes persistence.",
      "malware_types": [
        "trojan",
        "downloader",
        "dropper",
        "backdoor"
      ],
      "is_family": true,
      "x_capabilities": [
        "anti-analysis",
        "command-and-control",
        "remote-access",
        "persistence"
      ]
    },
    {
      "type": "threat-actor",
      "spec_version": "2.1",
      "id": "threat-actor--21896c67-0c44-515c-3fcb-60c49e8ffdc8",
      "created": "2026-01-17T16:23:27.657648Z",
      "modified": "2026-01-17T16:23:27.657648Z",
      "created_by_ref": "identity--03f067d6-efe5-77be-641e-966194463145",
      "name": "NeoShadow",
      "description": "NeoShadow is the threat actor attributed to the npm supply-chain attack described in this article. The group released multiple malicious npm packages and used novel techniques such as blockchain-based dynamic configuration and MSBuild-based process injection. Their role was to orchestrate a multi-stage Windows malware delivery campaign via typo-squatting npm packages.",
      "threat_actor_types": [
        "unknown"
      ],
      "goals": [
        "Compromise Windows systems via malicious npm packages",
        "Evade detection and analysis using anti-analysis heuristics",
        "Establish covert command-and-control channels using blockchain",
        "Deploy multi-stage payloads and achieve process injection"
      ],
      "sophistication": "advanced",
      "primary_motivation": "unknown"
    },
    {
