    {
      "type": "intrusion-set",
      "id": "intrusion-set--b9f953dd-0eac-4cc6-8aa5-c0ddf998dca8",
      "name": "UAT-7290",
      "aliases": [
        "Red Foxtrot"
      ],
      "description": "UAT-7290 is a China-nexus Advanced Persistent Threat (APT) group active since at least 2022, primarily targeting telecommunications and critical infrastructure in South Asia and Southeastern Europe. The group conducts espionage, initial access operations, and establishes Operational Relay Box (ORB) nodes for use by other China-nexus actors. UAT-7290 shares TTPs, victimology, infrastructure, and tooling with other China-nexus adversaries, including APT10.",
      "first_seen": "2022-01-01T00:00:00Z",
      "goals": [
        "Espionage",
        "Initial Access",
        "Establishing ORB nodes"
      ],
      "resource_level": "organization",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "initial-access"
      ],
      "external_references": [
        {
          "source_name": "Cisco Talos",
          "url": "https://blog.talosintelligence.com/"
        },
        {
          "source_name": "Recorded Future",
          "url": "https://go.recordedfuture.com/hubfs/reports/cta-2021-0616.pdf",
          "description": "Red Foxtrot linked to Chinese PLA Unit 69010"
        }
      ]
