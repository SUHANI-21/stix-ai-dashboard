  "spec_version": "2.1",
  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--aba09aa8-f254-4518-8496-9da5b880e28a",
      "name": "Omnissa Workspace One UEM Path Traversal Vulnerability",
      "description": "A critical vulnerability (CVE-2025-25231) in Omnissa Workspace One UEM (formerly VMware Workspace One UEM) allows unauthenticated attackers to perform path traversal attacks within a secondary context, leading to information disclosure and potential Remote Code Execution (RCE). The flaw resides in the SystemAppMetadataV1Controller, specifically in the handling of the packageId parameter during request routing.",
      "created": "2025-12-19T00:00:00Z",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-25231"
        },
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/omnissa-workspace-one-cve-2025-25231-path-traversal-exploit"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9d804505-54b0-4a6a-9af1-46c7587a9830",
      "name": "Path Traversal via packageId Parameter Manipulation",
      "description": "Attackers exploit the SystemAppMetadataV1Controller by manipulating the packageId parameter in the DevicesGateway application. By overriding the path parameter via the URL query string and injecting traversal characters, attackers trick the system into routing requests to unintended internal endpoints with elevated privileges, bypassing authentication.",
      "x_mitre_platforms": [
        "Windows",
        "Linux"
      ],
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/omnissa-workspace-one-cve-2025-25231-path-traversal-exploit"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--1299dad8-9a1c-40fe-826c-a36f582a16fd",
      "name": "Password Spraying for Global Administrator Access",
      "description": "After retrieving a list of admin users via the path traversal exploit, attackers perform password spraying attacks against the /AirWatch/Login/Login/Login-User endpoint to gain Global Administrator access.",
      "x_mitre_platforms": [
        "Windows",
        "Linux"
      ],
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/omnissa-workspace-one-cve-2025-25231-path-traversal-exploit"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--0d9d0a75-4067-418c-944f-f131441a0ead",
      "name": "Remote Code Execution via Malicious File Upload",
      "description": "With Global Administrator access, attackers modify the Blob Cache Store Path to a web-accessible directory and upload a malicious file (e.g., webshell). File upload restrictions are bypassed by generating valid encrypted strings for executable file extensions using a hardcoded master key found in the code.",
      "x_mitre_platforms": [
        "Windows",
        "Linux"
      ],
      "external_references": [
        {
          "source_name": "Picus Security",
          "url": "https://www.picussecurity.com/resource/blog/omnissa-workspace-one-cve-2025-25231-path-traversal-exploit"
        }
      ]
    },
