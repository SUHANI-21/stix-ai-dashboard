  "objects": [
    {
      "type": "vulnerability",
      "id": "vulnerability--75101c24-1e78-412a-ab9d-14e40f35e8b6",
      "name": "CVE-2025-21042",
      "description": "A zero-day vulnerability in Samsung\u2019s Android image processing library exploited by LANDFALL malware. The flaw allowed attackers to deliver spyware via malformed DNG image files sent through WhatsApp. The vulnerability affected Samsung Galaxy S22, S23, S24, Z Fold4, and Z Flip4 models and was patched in April 2025.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-21042"
        },
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/landfall-is-new-commercial-grade-android-spyware/"
        }
      ]
    },
    {
      "type": "vulnerability",
      "id": "vulnerability--671f0e06-d16c-458b-8f43-041881545b30",
      "name": "CVE-2025-21043",
      "description": "A related vulnerability in Samsung\u2019s image processing library, patched in September 2025, further protecting users from similar attack vectors as those used by LANDFALL.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-21043"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--58d07eea-ddde-45f0-ac80-7e29c7e49062",
      "name": "Malicious Image File Delivery via Messaging Platform",
      "description": "Attackers embedded spyware within malformed DNG image files and delivered them to targets through WhatsApp messages, exploiting vulnerabilities in Samsung\u2019s image processing library.",
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/landfall-is-new-commercial-grade-android-spyware/"
        }
      ]
    },
    {
      "type": "intrusion-set",
      "id": "intrusion-set--4e5c3c3d-968c-42b0-aa3b-6439a8e97992",
      "name": "CL-UNK-1054",
      "description": "Unit 42 tracks the LANDFALL Android spyware activity as CL-UNK-1054. The campaign shares infrastructure and tradecraft patterns with commercial spyware operations associated with private sector offensive actors (PSOAs), with possible links to Stealth Falcon and the Variston spyware framework.",
      "aliases": [
        "CL-UNK-1054"
      ],
      "external_references": [
        {
          "source_name": "Unit 42",
          "url": "https://unit42.paloaltonetworks.com/landfall-is-new-commercial-grade-android-spyware/"
        }
      ]
    },
