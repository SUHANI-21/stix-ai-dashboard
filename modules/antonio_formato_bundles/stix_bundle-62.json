    {
      "type": "vulnerability",
      "id": "vulnerability--971916c3-4906-4d64-8ff9-650166c026e4",
      "name": "React2Shell",
      "description": "React2Shell (CVE-2025-55182) is a critical vulnerability in React server components that allows unauthenticated remote code execution through crafted HTTP POST requests. The vulnerability is innate in affected versions of React and can be exploited before any authentication, enabling attackers to execute arbitrary commands on vulnerable servers.",
      "created": "2025-11-30T00:00:00Z",
      "modified": "2025-12-03T00:00:00Z",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2025-55182"
        }
      ],
      "labels": [
        "remote-code-execution",
        "web-application",
        "critical"
      ]
    },
    {
      "type": "malware",
      "id": "malware--99cb3deb-ba7b-43cd-857e-3dda6f325463",
      "name": "xmrig",
      "description": "xmrig is a legitimate Monero cryptocurrency mining application that is heavily abused by threat actors for cryptojacking. In this campaign, xmrig was deployed to compromised Windows servers to mine Monero and deposit it into the C3pool mining pool.",
      "malware_types": [
        "cryptominer"
      ],
      "is_family": false,
      "labels": [
        "monero",
        "cryptojacking",
        "resource-theft"
      ],
      "external_references": [
        {
          "source_name": "C3pool",
          "url": "https://auto.c3pool.org"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--6326f211-e1d1-4d24-92de-96f5f893c5b6",
      "name": "PowerShell Reverse Shell",
      "description": "A rudimentary PowerShell reverse shell was observed as a persistence mechanism after other remote access software was blocked. It enabled remote access to compromised Windows hosts.",
      "malware_types": [
        "remote-access-trojan"
      ],
      "is_family": false,
      "labels": [
        "reverse-shell",
        "powershell",
        "windows"
      ]
    },
    {
      "type": "malware",
      "id": "malware--2422d604-2fd4-40cc-adc8-761fda46034a",
      "name": "AnyDesk",
      "description": "AnyDesk is a legitimate remote access software that was downloaded and attempted to be executed for persistence on compromised hosts. Execution was blocked by application control.",
      "malware_types": [
        "remote-access-trojan"
      ],
      "is_family": false,
      "labels": [
        "remote-access",
        "persistence",
        "windows"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--86775477-8480-4e61-8dfe-269a8e549086",
      "name": "Cryptojacking via React2Shell",
      "description": "Attackers exploit React2Shell (CVE-2025-55182) by sending malicious HTTP POST requests to IIS servers running vulnerable React server components. After gaining code execution, they deploy cryptomining malware, attempt persistence through remote access tools, and use evasion techniques such as process hiding, tool renaming, and disabling firewalls.",
      "external_references": [
        {
          "source_name": "CVE",
          "external_id": "CVE-2025-55182"
        }
      ],
      "labels": [
        "initial-access",
        "execution",
        "persistence",
        "defense-evasion",
        "cryptojacking"
      ]
    },
