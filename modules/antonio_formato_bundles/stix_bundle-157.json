  "objects": [
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c437df7b-5b74-4caa-aa62-a0cf104ff59b",
      "name": "ClickFix Social Engineering",
      "description": "ClickFix is a social engineering technique that tricks users into pasting and running a malicious command (typically via Win+R and Ctrl+V) in the Windows Run prompt. It is used to initiate multi-stage malware execution chains.",
      "aliases": [
        "ClickFix Lure"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--c3b20c9b-3347-45b2-a142-cfc300561873",
      "name": "Steganographic Loader",
      "description": "A custom loader that uses steganography to conceal malware payloads within the pixel data of PNG images. The loader extracts and decrypts shellcode from specific colour channels, complicating detection and analysis.",
      "aliases": [
        "Stego Loader"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--6290fb7b-f46f-4148-8b3e-32150b370671",
      "name": "Process Injection via Reflective .NET Assembly",
      "description": "Malicious .NET assemblies are dynamically decrypted and reflectively loaded to inject shellcode into target processes (such as explorer.exe) using Win32 API calls.",
      "x_mitre_platforms": [
        "Windows"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--b8e15d82-bb7c-40e3-a5c7-2606de523b65",
      "name": "Donut Shellcode Packing",
      "description": "Malware payloads are packed using Donut shellcode, which allows .NET assemblies to be executed in-memory and evades traditional detection mechanisms.",
      "external_references": [
        {
          "source_name": "github",
          "url": "https://github.com/TheWover/donut"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--067857a7-7678-4363-9a24-d02c05852c41",
      "name": "User Execution via Windows Run Box",
      "description": "Threat actors instruct victims to manually execute malicious commands by pasting them into the Windows Run prompt, leveraging social engineering to bypass technical controls.",
      "x_mitre_platforms": [
        "Windows"
      ]
    },
