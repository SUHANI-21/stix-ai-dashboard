    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--3bc042f4-f2c8-b113-fadc-3e86e729d706",
      "created": "2026-01-14T20:20:23.143302Z",
      "modified": "2026-01-14T20:20:23.143302Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Abuse of Virtual Desktop Infrastructure for Initial Access",
      "description": "RedVDS attackers leveraged compromised accounts and misconfigured access controls on a global virtual desktop provider to gain initial access to victim environments. By targeting the provider’s infrastructure, attackers were able to bypass traditional network perimeter defenses and directly access virtual desktops used by employees at manufacturing companies and other organizations. This technique allowed them to masquerade as legitimate users and blend into normal activity, making detection significantly more difficult. The attackers exploited weak authentication mechanisms and reused credentials to access multiple organizations via the provider’s platform.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "initial-access"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--a4d8ab64-586d-28f5-ce94-3a20016ef9ea",
      "created": "2026-01-14T20:20:23.143452Z",
      "modified": "2026-01-14T20:20:23.143452Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Credential Harvesting from Virtual Desktop Sessions",
      "description": "Once inside the virtual desktop environment, RedVDS actors deployed custom scripts and tools to harvest credentials stored within user sessions. This included extracting saved passwords from browsers, credential managers, and cached authentication tokens. By operating within the virtual desktop context, attackers could access sensitive internal resources and escalate privileges by capturing credentials used for both local and cloud-based services. The harvested credentials were then used to pivot to other systems or sold to other cybercriminals.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "credential-access"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1003/",
          "external_id": "T1003"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--1d74e0bd-50d8-89e8-14a9-2cfac7644e3d",
      "created": "2026-01-14T20:20:23.143664Z",
      "modified": "2026-01-14T20:20:23.143664Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Deployment of Remote Access Tools via Virtual Desktop",
      "description": "RedVDS attackers installed remote access tools and malware directly onto compromised virtual desktops, enabling persistent access and control over victim environments. These tools were often disguised as legitimate software or were installed using elevated privileges obtained from harvested credentials. The remote access tools allowed attackers to maintain a foothold, exfiltrate data, and launch further attacks, including ransomware deployment and lateral movement within the victim’s network.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "persistence"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1219/",
          "external_id": "T1219"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--f3e51dd3-9141-39a0-926c-db80fac12aba",
      "created": "2026-01-14T20:20:23.143737Z",
      "modified": "2026-01-14T20:20:23.143737Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Lateral Movement through Shared Virtual Desktop Infrastructure",
      "description": "After gaining access to one virtual desktop, RedVDS actors exploited the interconnected nature of the provider’s infrastructure to move laterally between different organizations and user accounts. By abusing trust relationships and shared resources within the virtual desktop provider’s environment, attackers were able to compromise additional targets without needing to breach each organization individually. This lateral movement technique enabled rapid expansion of their foothold and increased the scale of impact.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "lateral-movement"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1021/001/",
          "external_id": "T1021.001"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--1a318bb6-79b6-0366-00e5-26086e2476c0",
      "created": "2026-01-14T20:20:23.143793Z",
      "modified": "2026-01-14T20:20:23.143793Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Data Exfiltration via Virtual Desktop Channels",
      "description": "RedVDS attackers exfiltrated sensitive data directly through virtual desktop sessions, bypassing traditional network monitoring and data loss prevention systems. By leveraging the provider’s infrastructure, attackers could transfer files and information out of victim environments using encrypted channels and legitimate protocols, making detection and attribution challenging. The exfiltrated data included intellectual property, financial records, and employee information, which was then monetized or used for further attacks.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "exfiltration"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1041/",
          "external_id": "T1041"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--dfdc97e5-454f-a092-bd9a-cd3bf4a3a613",
      "created": "2026-01-14T20:20:23.143893Z",
      "modified": "2026-01-14T20:20:23.143893Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Custom Virtual Desktop Provider Account Enumeration",
      "description": "RedVDS actors developed custom scripts to enumerate user accounts and organizations hosted on the virtual desktop provider’s platform. By systematically probing for active accounts and misconfigured access controls, attackers identified high-value targets and vulnerable entry points. This reconnaissance allowed them to prioritize attacks and maximize the effectiveness of their operations, targeting manufacturing companies and other critical infrastructure organizations.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "discovery"
        }
      ]
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--f2363849-3e34-538e-fbf7-058c3307e8fe",
      "created": "2026-01-14T20:20:23.143944Z",
      "modified": "2026-01-14T20:20:23.143944Z",
      "created_by_ref": "identity--5f532a3f-c4f1-ea40-3f37-070f59a7a53a",
      "name": "Evasion of Security Controls via Provider Infrastructure",
      "description": "RedVDS attackers exploited the trusted relationship between organizations and the virtual desktop provider to evade security controls. By operating within the provider’s infrastructure, attackers bypassed endpoint protection, network segmentation, and monitoring tools that were not configured to inspect traffic or activity originating from virtual desktops. This technique allowed them to maintain stealthy access and avoid detection for extended periods.",
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "defense-evasion"
        }
      ],
      "external_references": [
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/techniques/T1070/004/",
          "external_id": "T1070.004"
        }
      ]
    },
