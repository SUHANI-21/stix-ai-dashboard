    {
      "type": "attack-pattern",
      "id": "attack-pattern--b87572f7-f372-4028-9fb4-5e949a0b4249",
      "name": "DLL Sideloading",
      "description": "Threat actors place a malicious DLL named identically to a legitimate one in the same directory as an application, causing the application to load the attacker's DLL. In NotDoor, OneDrive.exe is vulnerable to loading a malicious SSPICLI.dll.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1574.001",
          "url": "https://attack.mitre.org/techniques/T1574/001/"
        }
      ],
      "x_mitre_platforms": [
        "Windows"
      ],
      "labels": [
        "dll-sideloading"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--3f823038-2a1b-48b6-8360-928793d3e58d",
      "name": "Encoded PowerShell",
      "description": "Malware executes base64-encoded PowerShell commands to obfuscate activity and evade detection. NotDoor uses encoded PowerShell for network checks, file copying, and command execution.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1027.010",
          "url": "https://attack.mitre.org/techniques/T1027/010/"
        }
      ],
      "x_mitre_platforms": [
        "Windows"
      ],
      "labels": [
        "powershell",
        "obfuscation"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--dad2a897-d583-43c7-9463-43552463a7eb",
      "name": "Outlook Macro Persistence",
      "description": "Malicious VBA macros are placed in Outlook's VbaProject.OTM file, enabling persistence and command execution via email triggers. NotDoor uses this technique for C2 and data exfiltration.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1137.005",
          "url": "https://attack.mitre.org/techniques/T1137/005/"
        }
      ],
      "x_mitre_platforms": [
        "Windows"
      ],
      "labels": [
        "outlook-macro",
        "persistence"
      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--d92968c6-3e46-496c-8f12-c330dfb6f6b6",
      "name": "Registry Modification",
      "description": "Malware modifies registry keys related to Outlook macro loading, macro security level, and dialog suppression to enable automatic macro execution and reduce user notifications. NotDoor sets LoadMacroProviderOnBoot, Level, and PONT_STRING keys.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1112",
          "url": "https://attack.mitre.org/techniques/T1112/"
        }
      ],
      "x_mitre_platforms": [
        "Windows"
      ],
      "labels": [
        "registry-modification",
        "persistence",
        "defense-evasion"
      ]
    },
